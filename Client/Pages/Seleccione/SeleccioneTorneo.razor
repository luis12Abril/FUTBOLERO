@if (listaEstados == null)
{
    <div class="torneo-loading">
        <div class="spinner-border text-primary" role="status"></div>
        <span class="ml-2">Cargando torneos...</span>
    </div>
}
else
{
    <section class="torneo-page">
        <div class="torneo-card">
            <div class="torneo-header">
                <h2>Selecciona tu Torneo</h2>
                <p>Elige estado, municipio, liga y torneo para continuar.</p>
            </div>

            <EditForm Model="oTorneoCLS" OnValidSubmit="VerTorneo">
                <div class="torneo-form-grid">
                    <div class="form-group torneo-field">
                        <label>Estados</label>
                        <InputSelect class="form-control torneo-select" ValueChanged="@((string idEstado)=>CambiaEstado(idEstado))" ValueExpression="@(()=>idEstado)" Value="@idEstado">
                            <option value="0">--- Seleccione ---</option>
                            @foreach (EstadoCLS oEstadoCLS in oListaEstados)
                            {
                                if (idEstado == oEstadoCLS.idestado.ToString())
                                {
                                    <option selected value="@oEstadoCLS.idestado">@oEstadoCLS.nombre</option>
                                }
                                else
                                {
                                    <option value="@oEstadoCLS.idestado">@oEstadoCLS.nombre</option>
                                }
                            }
                        </InputSelect>
                    </div>

                    <div class="form-group torneo-field">
                        <label>Municipios</label>
                        <InputSelect class="form-control torneo-select" ValueChanged="@((string idMunicipio)=>CambiaMunicipio(idMunicipio))" ValueExpression="@(()=>idMunicipio)" Value="@idMunicipio">
                            <option value="0">--- Seleccione ---</option>
                            @foreach (MunicipioCLS oMunicipioCLS in oListaMunicipios)
                            {
                                <option value="@oMunicipioCLS.idmunicipio">@oMunicipioCLS.nombre</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="form-group torneo-field">
                        <label>Ligas</label>
                        <InputSelect class="form-control torneo-select" ValueChanged="@((string idLiga)=>CambiaLiga(idLiga))" ValueExpression="@(()=>idLiga)" Value="@idLiga">
                            <option value="0">--- Seleccione ---</option>
                            @foreach (LigaCLS oLigaCLS in oListaLigas)
                            {
                                <option value="@oLigaCLS.idliga">@oLigaCLS.nombre</option>
                            }
                        </InputSelect>
                    </div>

                    <div class="form-group torneo-field">
                        <label>Torneos</label>
                        <InputSelect class="form-control torneo-select" @bind-Value="@idTorneo">
                            <option value="0">--- Seleccione ---</option>
                            @foreach (TorneoCLS otorneoCLS in oListaTorneos)
                            {
                                <option value="@otorneoCLS.idtorneo">@otorneoCLS.nombre</option>
                            }
                        </InputSelect>
                    </div>
                </div>

                <button type="submit" class="btn torneo-submit-btn" name="ingresar">Ver Torneo</button>
            </EditForm>
        </div>
    </section>
}

<style>
    .torneo-page {
        max-width: 920px;
        margin: 1.5rem auto 0 auto;
        padding: 0 1rem;
    }

    .torneo-card {
        background: linear-gradient(145deg, #ffffff 0%, #f8fbff 100%);
        border: 1px solid #dbeafe;
        border-radius: 20px;
        padding: 2rem;
        box-shadow: 0 18px 40px rgba(30, 58, 138, 0.12);
    }

    .torneo-header {
        text-align: center;
        margin-bottom: 1.5rem;
    }

    .torneo-header h2 {
        margin: 0;
        color: #1d4ed8;
        font-weight: 700;
    }

    .torneo-header p {
        margin-top: 0.5rem;
        margin-bottom: 0;
        color: #64748b;
    }

    .torneo-form-grid {
        display: grid;
        gap: 1rem;
    }

    .torneo-field {
        margin-bottom: 0;
    }

    .torneo-field label {
        display: block;
        margin-bottom: 0.45rem;
        color: #1e3a8a;
        font-weight: 600;
    }

    .torneo-select {
        border-radius: 10px;
        border: 1px solid #cbd5e1;
        height: 44px;
    }

    .torneo-select:focus {
        border-color: #2563eb;
        box-shadow: 0 0 0 0.2rem rgba(37, 99, 235, 0.15);
    }

    .torneo-submit-btn {
        width: 100%;
        margin-top: 1.5rem;
        background: linear-gradient(90deg, #16a34a 0%, #22c55e 100%);
        border: 0;
        border-radius: 10px;
        color: #ffffff;
        font-weight: 700;
        height: 46px;
        box-shadow: 0 10px 20px rgba(22, 163, 74, 0.28);
    }

    .torneo-submit-btn:hover {
        background: linear-gradient(90deg, #15803d 0%, #16a34a 100%);
    }

    .torneo-loading {
        margin-top: 2rem;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1e3a8a;
        font-weight: 600;
    }

    @@media (max-width: 576px) {
        .torneo-card {
            padding: 1.2rem;
        }
    }
</style>

