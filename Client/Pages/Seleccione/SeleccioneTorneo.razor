            oListaTorneos = await http.GetFromJsonAsync<List<TorneoCLS>>("api/TorneoSeleccionado/MiTorneo/" + valorLiga);
        }

    }


    public async Task VerTorneo()
    {
        if (idTorneo == "" || idTorneo == "0")
        {
            await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "No ha seleccionado un torneo", "error");
        }
        else
