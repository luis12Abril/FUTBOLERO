    public async Task CambiaEstado(string valorEstado)
    {
        idEstado = valorEstado;
        if (string.IsNullOrEmpty(valorEstado))
        {
            oListaMunicipios.Clear();
            idMunicipio = "";
            oListaLigas.Clear();
            idLiga = "";
            oListaTorneos.Clear();
            idTorneo = "";
        }
        else
        {
            oListaMunicipios.Clear();
            idMunicipio = "";
            oListaMunicipios = await http.GetFromJsonAsync<List<MunicipioCLS>>("api/TorneoSeleccionado/MunicipioEstado2/" + valorEstado);
            oListaLigas.Clear();
            idLiga = "";
            oListaTorneos.Clear();
            idTorneo = "";
        }

    }


    public async Task CambiaMunicipio(string valorMunicipio)
    {
        idMunicipio = valorMunicipio;
        if (string.IsNullOrEmpty(valorMunicipio))
        {
            oListaLigas.Clear();
            idLiga = "";
            oListaTorneos.Clear();
            idTorneo = "";
        }
        else
        {
            oListaLigas.Clear();
            idLiga = "";
            oListaTorneos.Clear();
            idTorneo = "";
            oListaLigas = await http.GetFromJsonAsync<List<LigaCLS>>("api/TorneoSeleccionado/LigaMunicipio/" + valorMunicipio);
        }

    }

    public async Task CambiaLiga(string valorLiga)
    {
        idLiga = valorLiga;
        if (string.IsNullOrEmpty(valorLiga))
        {
            oListaTorneos.Clear();
            idTorneo = "";
        }
        else
        {
            oListaTorneos.Clear();
            idTorneo = "";
            oListaTorneos = await http.GetFromJsonAsync<List<TorneoCLS>>("api/TorneoSeleccionado/MiTorneo/" + valorLiga);
        }

    }


    public async Task VerTorneo()
    {
        if (idTorneo == "" || idTorneo == "0")
        {
            await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "No ha seleccionado un torneo", "error");
        }
        else
        {
            var authuser = await auth1;
            var user = authuser.User;
            string idtorneocadena = idTorneo.ToString();
            string nombreTorneo = oListaTorneos.Where(p => p.idtorneo == int.Parse(idTorneo)).First().nombre;



            ((Autenticacion)auth).Entrar(user.Identity.Name, nombreTorneo, idtorneocadena);      /*user.Identity.Name ES EL ID DEL USUARIO*/

            // SE LE SUMA UNA VISITA MAS AL TORNEO
            int visitas = await http.GetFromJsonAsync<int>("api/Torneo/VisitasTorneo/" + idtorneocadena);

            string paginaEnviar = "ListaPosiciones";
            int idPag = await http.GetFromJsonAsync<int>("api/Pagina/RecuperarIdPagina/" + paginaEnviar);
            ruta = paginaEnviar + "/" + idPag;

            navigate.NavigateTo(ruta);
        }


    }



