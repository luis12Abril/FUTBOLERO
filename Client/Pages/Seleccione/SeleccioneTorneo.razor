            var authuser = await auth1;
            var user = authuser.User;
            string idtorneocadena = idTorneo.ToString();
            string nombreTorneo = oListaTorneos.Where(p => p.idtorneo == int.Parse(idTorneo)).First().nombre;



            ((Autenticacion)auth).Entrar(user.Identity.Name, nombreTorneo, idtorneocadena);      /*user.Identity.Name ES EL ID DEL USUARIO*/

            // SE LE SUMA UNA VISITA MAS AL TORNEO
            int visitas = await http.GetFromJsonAsync<int>("api/Torneo/VisitasTorneo/" + idtorneocadena);

            string paginaEnviar = "ListaPosiciones";
            int idPag = await http.GetFromJsonAsync<int>("api/Pagina/RecuperarIdPagina/" + paginaEnviar);
            ruta = paginaEnviar + "/" + idPag;

            navigate.NavigateTo(ruta);
        }


    }



