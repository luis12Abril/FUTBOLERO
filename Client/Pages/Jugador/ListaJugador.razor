@page "/ListaJugador/{Id}"
@using FUTBOLERO.Shared
@using Microsoft.AspNetCore.Components.Forms
@using System.IO
@using System.Linq
@inject HttpClient http
@inject IJSRuntime ijsruntime

@{
    string[] cabeceras = { "Nombre", "Equipo", "Fecha Nacimiento", "Años" };


    // ESTAS PROPIEDADES TIENEN QUE SER IGUAL A LAS QUE ESTAN EN EL CONTROLADOR
    string[] propiedades = { "nombrecompleto", "equipo", "fnacimientocadena", "años" };
  
}

<AuthorizeView>
    <Authorized>
        <section class="catalogo-page mt-3">
            <div class="catalogo-header-card">
                <div>
                    <p class="catalogo-kicker">Panel de administración</p>
                    <h3>Jugadores</h3>
                    <span>Administra el listado de jugadores registrados en el torneo.</span>
                </div>
                <div class="catalogo-header-right">
                    <div class="catalogo-badge">
                        <span>Catálogo</span>
                    </div>
                    <button class="catalogo-help-btn" @onclick="() => showHelp = true" title="Ayuda">
                        <span>?</span>
                    </button>
                </div>
            </div>

            @if (listadoJugador == null)
            {
                <div class="catalogo-loading">
                    <div class="spinner-border text-primary" role="status"></div>
                    <span class="ml-2">Cargando jugadores...</span>
                </div>
            }
            else
            {
                @if (permitirAgregar)
                {
                    <div class="importar-card mb-3">
                        <h5>Carga masiva de jugadores por Excel</h5>
                        <span>Selecciona el equipo, carga la plantilla y registra jugadores en bloque.</span>

                        <div class="importar-grid mt-2">
                            <div>
                                <label class="importar-label">Equipo destino</label>
                                <select class="form-control" @bind="equipoSeleccionadoImportacion">
                                    <option value="">--- Seleccione ---</option>
                                    @if (oEquipoCLS != null)
                                    {
                                        @foreach (var equipo in oEquipoCLS)
                                        {
                                            <option value="@equipo.idequipo">@equipo.nombre</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div>
                                <label class="importar-label">Archivo Excel (.xlsx o .xlsm)</label>
                                <InputFile OnChange="SeleccionarArchivoExcel" accept=".xlsx,.xlsm" />
                                @if (!string.IsNullOrWhiteSpace(nombreArchivoExcel))
                                {
                                    <small class="text-muted">Archivo seleccionado: @nombreArchivoExcel</small>
                                }
                            </div>

                            <div class="importar-actions">
                                <button class="btn btn-success" @onclick="ImportarJugadoresExcel">Importar jugadores</button>
                            </div>
                        </div>

                        <small class="text-muted d-block mt-2">
                            Columnas requeridas en la plantilla: Nombre, ApellidoPaterno, ApellidoMaterno, FechaNacimiento.
                        </small>
                    </div>
                }

                <div class="catalogo-list-card">
                    <Listados cabeceras=cabeceras
                              nombrePropiedadesMostrar=propiedades
                              lista=listadoJugador
                              type="combobox" button=false label="Seleccione un equipo"
                              combobox="oEquipoCLS" displayMember="nombre" valueMember="idequipo"
                              eventBusqueda="BuscarListaJugador"
                              permitirAgregar=@permitirAgregar rutaAgregar="AgregarJugador"
                              permitirEditar=@permitirEditar rutaEditar="EditarJugador"
                              permitirEliminar=@permitirEliminar eventEliminar="EliminarListaJugador"
                              permitirExportarExcel=@permitirExportarExcel
                              permitirExportarWord=@permitirExportarWord
                              permitirExportarPdf=@permitirExportarPDF
                              tituloReporte="Listado de Jugadores" />
                </div>
            }
        </section>

        @* ── MODAL DE AYUDA ── *@
        @if (showHelp)
        {
            <div class="ayuda-overlay" @onclick="() => showHelp = false">
                <div class="ayuda-modal" @onclick:stopPropagation="true">

                    <div class="ayuda-modal-header">
                        <div>
                            <span class="ayuda-kicker">Guía de uso</span>
                            <h4>Módulo de Jugadores</h4>
                        </div>
                        <button class="ayuda-close-btn" @onclick="() => showHelp = false">✕</button>
                    </div>

                    <div class="ayuda-modal-body">

                        <div class="ayuda-section">
                            <h5>📋 ¿Qué es esta pantalla?</h5>
                            <p>
                                La pantalla <strong>Jugadores</strong> te permite consultar, registrar, modificar y
                                eliminar los jugadores registrados en el torneo activo. También permite importar
                                jugadores de forma masiva desde un archivo Excel.
                                Solo verás los botones de acción para los que tengas permiso asignado.
                            </p>
                        </div>

                        <div class="ayuda-section">
                            <h5>🔍 Buscar un jugador</h5>
                            <p>
                                Usa el <strong>selector de equipo</strong> para filtrar jugadores por equipo.
                                Elige un equipo del listado desplegable y la tabla se actualizará automáticamente.
                                Si seleccionas la opción vacía regresa al listado completo de todos los jugadores.
                            </p>
                        </div>

                        <div class="ayuda-section">
                            <h5>➕ Agregar un jugador (uno a uno)</h5>
                            <p>
                                Haz clic en el botón <strong>Agregar</strong>. Solo el administrador o la persona
                                con permiso puede registrar jugadores. El formulario solicita los siguientes datos:
                            </p>
                            <table class="ayuda-table">
                                <thead>
                                    <tr><th>Campo</th><th>Obligatorio</th><th>Descripción</th></tr>
                                </thead>
                                <tbody>
                                    <tr><td>Nombre</td><td>✅ Sí</td><td>Nombre del jugador. Máximo 50 caracteres.</td></tr>
                                    <tr><td>Apellido Paterno</td><td>✅ Sí</td><td>Apellido paterno. Máximo 50 caracteres.</td></tr>
                                    <tr><td>Apellido Materno</td><td>❌ No</td><td>Apellido materno. Máximo 50 caracteres.</td></tr>
                                    <tr><td>Fecha de Nacimiento</td><td>✅ Sí</td><td>Se usa para calcular la edad del jugador en el torneo.</td></tr>
                                    <tr><td>Equipo</td><td>✅ Sí</td><td>Selecciona el equipo al que pertenece el jugador.</td></tr>
                                </tbody>
                            </table>
                            <p>Presiona <strong>Guardar</strong> para confirmar. Los campos marcados con * son obligatorios; el sistema mostrará un aviso si alguno está vacío.</p>
                        </div>

                        <div class="ayuda-section">
                            <h5>🔑 Captura delegada (acceso para encargado del equipo)</h5>
                            <p>
                                Si no quieres registrar tú mismo los jugadores de un equipo, puedes asignarle
                                un <strong>usuario y clave</strong> al encargado del equipo directamente desde
                                el módulo de <strong>Equipos</strong> (campo <em>Acceso para capturista</em>).
                                Ese usuario podrá iniciar sesión y ver únicamente los jugadores de su equipo
                                hasta la <strong>fecha de vigencia</strong> que le hayas configurado.
                            </p>
                            <div class="ayuda-tip">
                                📌 La vigencia controla hasta qué fecha el encargado puede acceder al sistema.
                                Pasada esa fecha, el acceso queda bloqueado automáticamente.
                            </div>
                        </div>

                        <div class="ayuda-section">
                            <h5>📥 Importar jugadores desde Excel (carga masiva)</h5>
                            <p>
                                Si necesitas registrar muchos jugadores a la vez, usa la sección
                                <strong>Carga masiva de jugadores por Excel</strong> que aparece arriba del listado.
                                Pasos:
                            </p>
                            <ol class="ayuda-ol">
                                <li>Selecciona el <strong>equipo destino</strong> en el selector.</li>
                                <li>Prepara tu archivo Excel con las columnas exactas indicadas (ver tabla abajo).</li>
                                <li>Haz clic en <strong>Seleccionar archivo</strong> y elige tu archivo <em>.xlsx</em> o <em>.xlsm</em>.</li>
                                <li>Haz clic en <strong>Importar jugadores</strong>.</li>
                                <li>El sistema te mostrará cuántos jugadores se insertaron y cuántos fueron rechazados.</li>
                            </ol>

                            <p><strong>Columnas requeridas en el archivo Excel:</strong></p>
                            <table class="ayuda-table">
                                <thead>
                                    <tr><th>Columna</th><th>Tipo</th><th>Ejemplo</th></tr>
                                </thead>
                                <tbody>
                                    <tr><td>Nombre</td><td>Texto</td><td>Carlos</td></tr>
                                    <tr><td>ApellidoPaterno</td><td>Texto</td><td>Ramírez</td></tr>
                                    <tr><td>ApellidoMaterno</td><td>Texto</td><td>Torres</td></tr>
                                    <tr><td>FechaNacimiento</td><td>Fecha</td><td>15/03/2005</td></tr>
                                </tbody>
                            </table>

                            <div class="ayuda-tip">
                                💡 <strong>Ejemplo de cómo debe verse tu archivo Excel:</strong>
                            </div>
                            <table class="ayuda-table ayuda-table-example">
                                <thead>
                                    <tr>
                                        <th>A — Nombre</th>
                                        <th>B — ApellidoPaterno</th>
                                        <th>C — ApellidoMaterno</th>
                                        <th>D — FechaNacimiento</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    <tr><td>Carlos</td><td>Ramírez</td><td>Torres</td><td>15/03/2005</td></tr>
                                    <tr><td>Luis</td><td>González</td><td>Herrera</td><td>22/07/2006</td></tr>
                                    <tr><td>Miguel</td><td>López</td><td>Díaz</td><td>08/11/2004</td></tr>
                                    <tr><td>Andrés</td><td>Martínez</td><td> </td><td>30/01/2007</td></tr>
                                </tbody>
                            </table>
                            <div class="ayuda-tip ayuda-tip-warning">
                                ⚠️ <strong>Importante:</strong> La fila 1 debe ser la fila de encabezados con los nombres
                                exactos de las columnas. La fecha debe estar en formato de fecha de Excel
                                (no como texto). Si un jugador ya está registrado o le falta un campo obligatorio,
                                será rechazado y se mostrará en el resumen de errores.
                            </div>
                        </div>

                        <div class="ayuda-section">
                            <h5>✏️ Editar un jugador</h5>
                            <p>
                                Haz clic en el botón <strong>Editar</strong> en la fila del jugador que deseas
                                modificar. Podrás cambiar nombre, apellidos, fecha de nacimiento y equipo.
                                Presiona <strong>Guardar</strong> para confirmar los cambios.
                            </p>
                        </div>

                        <div class="ayuda-section">
                            <h5>🗑️ Dar de baja a un jugador</h5>
                            <p>
                                Haz clic en el botón <strong>Eliminar</strong> en la fila correspondiente.
                                El sistema pedirá confirmación antes de proceder.
                            </p>
                            <table class="ayuda-table">
                                <thead>
                                    <tr><th>Resultado</th><th>Mensaje</th></tr>
                                </thead>
                                <tbody>
                                    <tr><td>✅ Dado de baja correctamente</td><td>OK, EL JUGADOR SALIÓ DEL EQUIPO</td></tr>
                                    <tr><td>❌ Error inesperado</td><td>ERROR, NO SE PUDO DAR DE BAJA</td></tr>
                                </tbody>
                            </table>
                        </div>

                        <div class="ayuda-section">
                            <h5>📤 Exportar el listado</h5>
                            <p>Si tienes permiso, puedes exportar el listado en: <strong>Excel</strong>, <strong>Word</strong> y <strong>PDF</strong>.</p>
                        </div>

                        <div class="ayuda-section ayuda-section-faq">
                            <h5>❓ Preguntas frecuentes</h5>
                            <p><strong>¿Por qué no veo los botones de Agregar / Editar / Eliminar?</strong><br />
                            Tu usuario no tiene ese permiso. Contacta al administrador del sistema.</p>
                            <p><strong>¿El encargado del equipo puede ver todos los jugadores del torneo?</strong><br />
                            No. Al iniciar sesión, el encargado solo puede ver y capturar los jugadores de su propio equipo.</p>
                            <p><strong>¿Qué pasa si la fecha de vigencia del encargado venció?</strong><br />
                            El acceso queda bloqueado. El administrador debe actualizar la vigencia desde el módulo de Equipos.</p>
                            <p><strong>¿Qué pasa si mi archivo Excel tiene errores?</strong><br />
                            El sistema importa los registros correctos e informa cuántos fueron rechazados y el motivo de cada uno.</p>
                        </div>

                    </div>

                    <div class="ayuda-modal-footer">
                        <button class="btn ayuda-btn-cerrar" @onclick="() => showHelp = false">Cerrar guía</button>
                    </div>

                </div>
            </div>
        }

    </Authorized>
</AuthorizeView>

