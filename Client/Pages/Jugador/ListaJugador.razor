@page "/ListaJugador/{Id}"
@using FUTBOLERO.Shared
@using Microsoft.AspNetCore.Components.Forms
@using System.IO
@using System.Linq
@inject HttpClient http
@inject IJSRuntime ijsruntime

@{
    string[] cabeceras = { "Nombre", "Equipo", "Fecha Nacimiento", "Años" };


    // ESTAS PROPIEDADES TIENEN QUE SER IGUAL A LAS QUE ESTAN EN EL CONTROLADOR
    string[] propiedades = { "nombrecompleto", "equipo", "fnacimientocadena", "años" };
  
}

<AuthorizeView>
    <Authorized>
        <section class="catalogo-page mt-3">
            <div class="catalogo-header-card">
                <div>
                    <p class="catalogo-kicker">Panel de administración</p>
                    <h3>Jugadores</h3>
                    <span>Administra el listado de jugadores registrados en el torneo.</span>
                </div>
                <div class="catalogo-badge">
                    <span>Catálogo</span>
                </div>
            </div>

            @if (listadoJugador == null)
            {
                <div class="catalogo-loading">
                    <div class="spinner-border text-primary" role="status"></div>
                    <span class="ml-2">Cargando jugadores...</span>
                </div>
            }
            else
            {
                @if (permitirAgregar)
                {
                    <div class="importar-card mb-3">
                        <h5>Carga masiva de jugadores por Excel</h5>
                        <span>Selecciona el equipo, carga la plantilla y registra jugadores en bloque.</span>

                        <div class="importar-grid mt-2">
                            <div>
                                <label class="importar-label">Equipo destino</label>
                                <select class="form-control" @bind="equipoSeleccionadoImportacion">
                                    <option value="">--- Seleccione ---</option>
                                    @if (oEquipoCLS != null)
                                    {
                                        @foreach (var equipo in oEquipoCLS)
                                        {
                                            <option value="@equipo.idequipo">@equipo.nombre</option>
                                        }
                                    }
                                </select>
                            </div>

                            <div>
                                <label class="importar-label">Archivo Excel (.xlsx o .xlsm)</label>
                                <InputFile OnChange="SeleccionarArchivoExcel" accept=".xlsx,.xlsm" />
                                @if (!string.IsNullOrWhiteSpace(nombreArchivoExcel))
                                {
                                    <small class="text-muted">Archivo seleccionado: @nombreArchivoExcel</small>
                                }
                            </div>

                            <div class="importar-actions">
                                <button class="btn btn-success" @onclick="ImportarJugadoresExcel">Importar jugadores</button>
                            </div>
                        </div>

                        <small class="text-muted d-block mt-2">
                            Columnas requeridas en la plantilla: Nombre, ApellidoPaterno, ApellidoMaterno, FechaNacimiento.
                        </small>
                    </div>
                }

                <div class="catalogo-list-card">
                    <Listados cabeceras=cabeceras
                              nombrePropiedadesMostrar=propiedades
                              lista=listadoJugador
                              type="combobox" button=false label="Seleccione un equipo"
                              combobox="oEquipoCLS" displayMember="nombre" valueMember="idequipo"
                              eventBusqueda="BuscarListaJugador"
                              permitirAgregar=@permitirAgregar rutaAgregar="AgregarJugador"
                              permitirEditar=@permitirEditar rutaEditar="EditarJugador"
                              permitirEliminar=@permitirEliminar eventEliminar="EliminarListaJugador"
                              permitirExportarExcel=@permitirExportarExcel
                              permitirExportarWord=@permitirExportarWord
                              permitirExportarPdf=@permitirExportarPDF
                              tituloReporte="Listado de Jugadores" />
                </div>
            }
        </section>
    </Authorized>
</AuthorizeView>

<style>
    .catalogo-page {
        padding: 0.25rem 0;
    }

    .catalogo-header-card {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        background: linear-gradient(135deg, #eff6ff 0%, #eef2ff 45%, #f8fafc 100%);
        border: 1px solid #dbeafe;
        border-radius: 16px;
        padding: 1.1rem 1.25rem;
        margin-bottom: 1rem;
        box-shadow: 0 14px 28px rgba(30, 64, 175, 0.08);
    }

    .catalogo-kicker {
        margin: 0;
        color: #2563eb;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .catalogo-header-card h3 {
        margin: 0.15rem 0 0.25rem;
        color: #1e3a8a;
        font-weight: 800;
    }

    .catalogo-header-card span {
        color: #475569;
        font-size: 0.93rem;
    }

    .catalogo-badge span {
        display: inline-block;
        background: linear-gradient(90deg, #2563eb 0%, #1d4ed8 100%);
        color: #fff;
        border-radius: 999px;
        padding: 0.3rem 0.8rem;
        font-size: 0.78rem;
        font-weight: 700;
        box-shadow: 0 8px 18px rgba(37, 99, 235, 0.24);
    }

    .catalogo-list-card {
        background-color: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 0.75rem;
        box-shadow: 0 16px 32px rgba(15, 23, 42, 0.08);
    }

    .catalogo-loading {
        margin: 1.5rem 0;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1e3a8a;
        font-weight: 600;
    }

    .importar-card {
        background: #ffffff;
        border: 1px solid #d1fae5;
        border-radius: 14px;
        padding: 0.9rem 1rem;
        box-shadow: 0 12px 22px rgba(5, 150, 105, 0.12);
    }

    .importar-card h5 {
        margin: 0;
        color: #065f46;
        font-weight: 700;
    }

    .importar-card span {
        color: #4b5563;
        font-size: 0.9rem;
    }

    .importar-grid {
        display: grid;
        grid-template-columns: repeat(3, minmax(0, 1fr));
        gap: 0.8rem;
        align-items: end;
    }

    .importar-label {
        font-weight: 600;
        color: #1f2937;
        margin-bottom: 0.25rem;
    }

    .importar-actions {
        display: flex;
        align-items: end;
    }

    @@media (max-width: 768px) {
        .catalogo-header-card {
            flex-direction: column;
            align-items: flex-start;
        }

        .importar-grid {
            grid-template-columns: 1fr;
        }
    }
</style>


@code {
    public string mensaje;

    public string idtorneoseleccionado;

    public string torneoMensaje { get; set; }

    public JugadorCLS[] listadoJugador;

    public JugadorCLS oJugadorCLSBorrar = new JugadorCLS();         // ESTE LO PONGO PARA SACAR EL NOMBRE DEL JUGADOR Y MANDARLO COMO PARAMETRO AL BORRAR

    public EquipoCLS[] oEquipoCLS;      // ESTO ES PORQUE SE VA HACER UNA BUSQUEDA POR COMBOBOX

    [CascadingParameter]
    private Task<AuthenticationState> auth { get; set; }

    [Parameter]
    public string Id { get; set; }

    public bool permitirAgregar = false;
    public bool permitirEditar = false;
    public bool permitirEliminar = false;
    public bool permitirExportarExcel = false;
    public bool permitirExportarWord = false;
    public bool permitirExportarPDF = false;

    List<int> listaBotones = new List<int>();

    public UsuarioEACLS listadousuario;

    public string equipoSeleccionadoImportacion;
    public IBrowserFile archivoExcelSeleccionado;
    public string nombreArchivoExcel;


    protected override async Task OnInitializedAsync()
    {
        var authuser = await auth;
        var user = authuser.User;

        if (user.Identity.IsAuthenticated)
        {
            var claims = user.Claims.ToList();
            var torneo = claims[1].Value;
            var idusuariologueado = claims[0].Value;

            // AQUI ESTOY RECIENDO EN CADENA EL ID DE TORNEO SELECCIONADO
            idtorneoseleccionado = claims[2].Value;

            torneoMensaje = torneo;

            // ESTA LINEA LA TUVE QUE CAMBIAR DE CONTROLADOR PORQUE EN EL DE USUARIO NO FUNCIONABA, NO SE PORQUE
            listadousuario = await http.GetFromJsonAsync<UsuarioEACLS>("api/Jugador/RecEA/" + idusuariologueado);

            int tipoUsuario = await http.GetFromJsonAsync<int>("api/Usuario/RegresaIdTipoUsuario/" + idusuariologueado);
            if (tipoUsuario == 6)
            {
                // DEBO SACAR DE LA TABLA EQUIPO EL IDEQUIPO, TENGO EL USUARIO LOGUEADO ENTONCES LO BIUSCO EN EL CONTROLADOR EQUIPO
                int idequipo = await http.GetFromJsonAsync<int>("api/Equipo/RegresaIdEquipo/" + listadousuario.usuequipo);

                listadoJugador = await http.GetFromJsonAsync<JugadorCLS[]>("api/Jugador/ListarJugadorEquipo/" + idequipo);  // AQUI OCUPO EL IDEQUIPO

                oEquipoCLS = await http.GetFromJsonAsync<EquipoCLS[]>("api/Equipo/ListarEquipoAdminEquipo/" + idequipo);    // ESTE LO LLENO PORQUE SE VA HA UTILIZAR EN EL COMBO BUSQUEDA DE EQUIPOS
                equipoSeleccionadoImportacion = idequipo.ToString();
            }
            else
            {
                listadoJugador = await http.GetFromJsonAsync<JugadorCLS[]>("api/Jugador/ListarJugador/" + idtorneoseleccionado);
                oEquipoCLS = await http.GetFromJsonAsync<EquipoCLS[]>("api/Equipo/ListarEquipoTodos/" + idtorneoseleccionado);    // ESTE LO LLENO PORQUE SE VA HA UTILIZAR EN EL COMBO BUSQUEDA DE EQUIPOS
            }

            if (user.Identity.IsAuthenticated)
            {
                //  ESTO LO HAGO PORQUE SI ES UN ADMINISTRADOR Y NO TIENE DERECHO A ADMINISTRAR EL TORNEO SELECCIONADO TENDRA QUE VERLO COMO INVITADO
                listaBotones = await http.GetFromJsonAsync<List<int>>("api/PaginaTipoUsuario/listarBotones2/" + user.Identity.Name + "/" + Id + "/" + idtorneoseleccionado);

                if (listaBotones.Count() > 0)
                {
                    if (listaBotones.Contains(1)) permitirAgregar = true;
                    if (listaBotones.Contains(2)) permitirEditar = true;
                    if (listaBotones.Contains(3)) permitirEliminar = true;
                    if (listaBotones.Contains(4)) permitirExportarExcel = true;
                    if (listaBotones.Contains(5)) permitirExportarWord = true;
                    if (listaBotones.Contains(6)) permitirExportarPDF = true;
                }
            }
        }
    }


    public void SeleccionarArchivoExcel(InputFileChangeEventArgs e)
    {
        archivoExcelSeleccionado = e.File;
        nombreArchivoExcel = archivoExcelSeleccionado?.Name;
    }


    public async Task ImportarJugadoresExcel()
    {
        if (string.IsNullOrWhiteSpace(equipoSeleccionadoImportacion))
        {
            await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "SELECCIONA EL EQUIPO DESTINO", "warning");
            return;
        }

        if (archivoExcelSeleccionado == null)
        {
            await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "SELECCIONA UN ARCHIVO EXCEL", "warning");
            return;
        }

        using MultipartFormDataContent data = new MultipartFormDataContent();
        using Stream archivoStream = archivoExcelSeleccionado.OpenReadStream(10 * 1024 * 1024);
        using StreamContent contenidoArchivo = new StreamContent(archivoStream);
        contenidoArchivo.Headers.ContentType = new System.Net.Http.Headers.MediaTypeHeaderValue(archivoExcelSeleccionado.ContentType);

        data.Add(contenidoArchivo, "archivo", archivoExcelSeleccionado.Name);
        data.Add(new StringContent(equipoSeleccionadoImportacion), "idequipo");
        data.Add(new StringContent(idtorneoseleccionado), "idtorneo");

        HttpResponseMessage respuesta = await http.PostAsync("api/Jugador/ImportarJugadoresExcel", data);
        if (!respuesta.IsSuccessStatusCode)
        {
            await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "OCURRIO UN ERROR AL IMPORTAR", "error");
            return;
        }

        ImportacionJugadoresExcelCLS resultado = await respuesta.Content.ReadFromJsonAsync<ImportacionJugadoresExcelCLS>();

        if (resultado != null)
        {
            string mensaje = "INSERTADOS: " + resultado.insertados + " | RECHAZADOS: " + resultado.rechazados;
            if (resultado.insertados > 0)
            {
                await ijsruntime.InvokeVoidAsync("MostrarMensajetime", "IMPORTACION COMPLETADA. " + mensaje, "success", 2500);
            }
            else
            {
                await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "NO SE IMPORTARON JUGADORES. " + mensaje, "warning");
            }

            if (resultado.errores != null && resultado.errores.Count > 0)
            {
                string errores = string.Join("\n", resultado.errores.Take(6));
                await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", errores, "warning");
            }
        }

        listadoJugador = await http.GetFromJsonAsync<JugadorCLS[]>("api/Jugador/FiltrarJugador/" + equipoSeleccionadoImportacion + "/" + idtorneoseleccionado);
    }


    public async Task BuscarListaJugador(string buscarNombreJugador)
    {
        if (buscarNombreJugador == null || buscarNombreJugador == "")
        {
            listadoJugador = await http.GetFromJsonAsync<JugadorCLS[]>("api/Jugador/ListarJugador/" + idtorneoseleccionado);
        }
        else
        {
            listadoJugador = await http.GetFromJsonAsync<JugadorCLS[]>("api/Jugador/FiltrarJugador/" + buscarNombreJugador + "/" + idtorneoseleccionado);
        }
    }


    public async Task EliminarListaJugador(string idJugador)       // LO PONEMOS COMO STRING PORQUE EN EL LISTADOSRAZOR2 ESTA COMO STRING
    {
        oJugadorCLSBorrar = await http.GetFromJsonAsync<JugadorCLS>("api/Jugador/RecuperarInformacionJugador/" + idJugador);


        if (await ijsruntime.InvokeAsync<bool>("ConfirmarBorrar", "Confirmar", "VAS A BORRAR A: " + oJugadorCLSBorrar.nombre + " " + oJugadorCLSBorrar.appaterno, "warning"))
        {
            int rpta = await http.GetFromJsonAsync<int>("api/Jugador/EliminarJugador/" + idJugador + "/" + idtorneoseleccionado);

            // 0 = OCURRIO UN ERROR     1 = SE BORRO ON     2 = HAY JUEGOS CON ESA JORNADA
            switch (rpta)
            {
                case 0:
                    await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "ERROR, NO SE PUDO DAR DE BAJA", "error");
                    break;
                case 1:
                    await ijsruntime.InvokeVoidAsync("MostrarMensajetime", "OK, EL JUGADOR SALIO DEL EQUIPO", "success", 2000);
                    listadoJugador = await http.GetFromJsonAsync<JugadorCLS[]>("api/Jugador/ListarJugador/" + idtorneoseleccionado);
                    break;
                default:
                    break;
            }
        }
    }
}



