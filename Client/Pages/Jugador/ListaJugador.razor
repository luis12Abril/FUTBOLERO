@page "/ListaJugador/{Id}"
@using FUTBOLERO.Shared
@inject HttpClient http
@inject IJSRuntime ijsruntime

@{
    string[] cabeceras = { "Nombre", "Equipo", "Fecha Nacimiento", "Años" };


    // ESTAS PROPIEDADES TIENEN QUE SER IGUAL A LAS QUE ESTAN EN EL CONTROLADOR
    string[] propiedades = { "nombrecompleto", "equipo", "fnacimientocadena", "años" };
  
}

<AuthorizeView>
    <Authorized>
        <Listados cabeceras=cabeceras
                  nombrePropiedadesMostrar=propiedades
                  lista=listadoJugador
                  type="combobox" button=false label="Seleccione un equipo"
                  combobox="oEquipoCLS" displayMember="nombre" valueMember="idequipo"
                  eventBusqueda="BuscarListaJugador"
                  permitirAgregar=@permitirAgregar rutaAgregar="AgregarJugador"
                  permitirEditar=@permitirEditar rutaEditar="EditarJugador"
                  permitirEliminar=@permitirEliminar eventEliminar="EliminarListaJugador"
                  permitirExportarExcel=@permitirExportarExcel
                  permitirExportarWord=@permitirExportarWord
                  permitirExportarPdf=@permitirExportarPDF
                  tituloReporte="Listado de Jugadores" />
    </Authorized>
</AuthorizeView>


@code {
    public string mensaje;

    public string idtorneoseleccionado;

    public string torneoMensaje { get; set; }

    public JugadorCLS[] listadoJugador;

    public JugadorCLS oJugadorCLSBorrar = new JugadorCLS();         // ESTE LO PONGO PARA SACAR EL NOMBRE DEL JUGADOR Y MANDARLO COMO PARAMETRO AL BORRAR

    public EquipoCLS[] oEquipoCLS;      // ESTO ES PORQUE SE VA HACER UNA BUSQUEDA POR COMBOBOX

    [CascadingParameter]
    private Task<AuthenticationState> auth { get; set; }

    [Parameter]
    public string Id { get; set; }

    public bool permitirAgregar = false;
    public bool permitirEditar = false;
    public bool permitirEliminar = false;
    public bool permitirExportarExcel = false;
    public bool permitirExportarWord = false;
    public bool permitirExportarPDF = false;

    List<int> listaBotones = new List<int>();

    public UsuarioEACLS listadousuario;


    protected override async Task OnInitializedAsync()
    {
        var authuser = await auth;
        var user = authuser.User;

        if (user.Identity.IsAuthenticated)
        {
            var claims = user.Claims.ToList();
            var torneo = claims[1].Value;
            var idusuariologueado = claims[0].Value;

            // AQUI ESTOY RECIENDO EN CADENA EL ID DE TORNEO SELECCIONADO
            idtorneoseleccionado = claims[2].Value;

            torneoMensaje = torneo;

            //listadoJugador = await http.GetFromJsonAsync<JugadorCLS[]>("api/Jugador/ListarTotalesPorAños/" + 9);


            // ESTA LINEA LA TUVE QUE CAMBIAR DE CONTROLADOR PORQUE EN EL DE USUARIO NO FUNCIONABA, NO SE PORQUE
            listadousuario = await http.GetFromJsonAsync<UsuarioEACLS>("api/Jugador/RecEA/" + idusuariologueado);

            int tipoUsuario = await http.GetFromJsonAsync<int>("api/Usuario/RegresaIdTipoUsuario/" + idusuariologueado);
            if (tipoUsuario == 6)
            {
                //string usuequipo1 = await http.GetFromJsonAsync<string>("api/Jugador/RegresaUsuarioEA/" + idusuariologueado);
                //int a = 0;

                // DEBO SACAR DE LA TABLA EQUIPO EL IDEQUIPO, TENGO EL USUARIO LOGUEADO ENTONCES LO BIUSCO EN EL CONTROLADOR EQUIPO
                int idequipo = await http.GetFromJsonAsync<int>("api/Equipo/RegresaIdEquipo/" + listadousuario.usuequipo);

                listadoJugador = await http.GetFromJsonAsync<JugadorCLS[]>("api/Jugador/ListarJugadorEquipo/" + idequipo);  // AQUI OCUPO EL IDEQUIPO

                oEquipoCLS = await http.GetFromJsonAsync<EquipoCLS[]>("api/Equipo/ListarEquipoAdminEquipo/" + idequipo);    // ESTE LO LLENO PORQUE SE VA HA UTILIZAR EN EL COMBO BUSQUEDA DE EQUIPOS

            }
            else
            {

                listadoJugador = await http.GetFromJsonAsync<JugadorCLS[]>("api/Jugador/ListarJugador/" + idtorneoseleccionado);
                oEquipoCLS = await http.GetFromJsonAsync<EquipoCLS[]>("api/Equipo/ListarEquipoTodos/" + idtorneoseleccionado);    // ESTE LO LLENO PORQUE SE VA HA UTILIZAR EN EL COMBO BUSQUEDA DE EQUIPOS

            }

            if (user.Identity.IsAuthenticated)
            {
                //listaBotones = await http.GetFromJsonAsync<List<int>>("api/PaginaTipoUsuario/listarBotones/" + user.Identity.Name + "/" + Id);

                //  ESTO LO HAGO PORQUE SI ES UN ADMINISTRADOR Y NO TIENE DERECHO A ADMINISTRAR EL TORNEO SELECCIONADO TENDRA QUE VERLO COMO INVITADO
                listaBotones = await http.GetFromJsonAsync<List<int>>("api/PaginaTipoUsuario/listarBotones2/" + user.Identity.Name + "/" + Id + "/" + idtorneoseleccionado);

                if (listaBotones.Count() > 0)
                {
                    if (listaBotones.Contains(1)) permitirAgregar = true;
                    if (listaBotones.Contains(2)) permitirEditar = true;
                    if (listaBotones.Contains(3)) permitirEliminar = true;
                    if (listaBotones.Contains(4)) permitirExportarExcel = true;
                    if (listaBotones.Contains(5)) permitirExportarWord = true;
                    if (listaBotones.Contains(6)) permitirExportarPDF = true;
                }
            }
        }
    }


    public async Task BuscarListaJugador(string buscarNombreJugador)
    {
        if (buscarNombreJugador == null || buscarNombreJugador == "")
        {
            listadoJugador = await http.GetFromJsonAsync<JugadorCLS[]>("api/Jugador/ListarJugador/" + idtorneoseleccionado);
        }
        else
        {
            listadoJugador = await http.GetFromJsonAsync<JugadorCLS[]>("api/Jugador/FiltrarJugador/" + buscarNombreJugador + "/" + idtorneoseleccionado);
        }
    }


    public async Task EliminarListaJugador(string idJugador)       // LO PONEMOS COMO STRING PORQUE EN EL LISTADOSRAZOR2 ESTA COMO STRING
    {
        oJugadorCLSBorrar = await http.GetFromJsonAsync<JugadorCLS>("api/Jugador/RecuperarInformacionJugador/" + idJugador);


        if (await ijsruntime.InvokeAsync<bool>("ConfirmarBorrar", "Confirmar", "VAS A BORRAR A: " + oJugadorCLSBorrar.nombre + " " + oJugadorCLSBorrar.appaterno, "warning"))
        {
            int rpta = await http.GetFromJsonAsync<int>("api/Jugador/EliminarJugador/" + idJugador + "/" + idtorneoseleccionado);

            // 0 = OCURRIO UN ERROR     1 = SE BORRO ON     2 = HAY JUEGOS CON ESA JORNADA
            switch (rpta)
            {
                case 0:
                    await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "ERROR, NO SE PUDO DAR DE BAJA", "error");
                    break;
                case 1:
                    await ijsruntime.InvokeVoidAsync("MostrarMensajetime", "OK, EL JUGADOR SALIO DEL EQUIPO", "success", 2000);
                    listadoJugador = await http.GetFromJsonAsync<JugadorCLS[]>("api/Jugador/ListarJugador/" + idtorneoseleccionado);
                    break;
                default:
                    break;
            }
        }
    }
}



