    /* ── MODAL DE AYUDA ── */
    .ayuda-overlay {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.45);
        backdrop-filter: blur(3px);
        z-index: 1050;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }

    .ayuda-modal {
        background: #fff;
        border-radius: 20px;
        width: 100%;
        max-width: 700px;
        max-height: 88vh;
        display: flex;
        flex-direction: column;
        box-shadow: 0 24px 60px rgba(30, 64, 175, 0.18);
        overflow: hidden;
    }

    .ayuda-modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.1rem 1.4rem 0.9rem;
        background: linear-gradient(135deg, #eff6ff 0%, #eef2ff 100%);
        border-bottom: 1px solid #dbeafe;
    }

    .ayuda-kicker {
        display: block;
