@page "/ListaJugadoresPorAño/{Id}"
@using FUTBOLERO.Shared
@inject HttpClient http
@inject IJSRuntime ijsruntime

@{ 
    string[] cabeceras = { "AÑO", "TOTAL" };

    // ESTAS PROPIEDADES TIENEN QUE SER IGUAL A LAS QUE ESTAN EN EL CONTROLADOR
    string[] propiedades = { "años", "contadoraños" };
}


<AuthorizeView>
    <Authorized>
        <section class="catalogo-page mt-3">
            <div class="catalogo-header-card">
                <div>
                    <p class="catalogo-kicker">Panel de administración</p>
                    <h3>Jugadores por Año</h3>
                    <span>Consulta el total de jugadores agrupados por edad y equipo.</span>
                </div>
                <div class="catalogo-header-right">
                    <div class="catalogo-badge">
                        <span>Catálogo</span>
                    </div>
                    <button class="catalogo-help-btn" @onclick="() => showHelp = true" title="Ayuda">
                        <span>?</span>
                    </button>
                </div>
            </div>

            @if (listadoJugadoresAños == null)
            {
                <div class="catalogo-loading">
                    <div class="spinner-border text-primary" role="status"></div>
                    <span class="ml-2">Cargando jugadores...</span>
                </div>
            }
            else
            {
                <div class="catalogo-list-card">
                    <Listados cabeceras=cabeceras
                              nombrePropiedadesMostrar=propiedades
                              lista=listadoJugadoresAños
                              type="combobox" button=false label="Seleccione un equipo"
                              combobox="oEquipoCLS" displayMember="nombre" valueMember="idequipo"
                              eventBusqueda="BuscarListaJugadoresPorAño"
                              tituloReporte="Total de Jugadores por edades" />
                </div>
            }
        </section>

        @* ── MODAL DE AYUDA ── *@
        @if (showHelp)
        {
            <div class="ayuda-overlay" @onclick="() => showHelp = false">
                <div class="ayuda-modal" @onclick:stopPropagation="true">

                    <div class="ayuda-modal-header">
                        <div>
                            <span class="ayuda-kicker">Guía de uso</span>
                            <h4>Jugadores por Año de Nacimiento</h4>
                        </div>
                        <button class="ayuda-close-btn" @onclick="() => showHelp = false">✕</button>
                    </div>

                    <div class="ayuda-modal-body">

                        <div class="ayuda-section">
                            <h5>📅 ¿Qué es esta pantalla?</h5>
                            <p>
                                La pantalla <strong>Jugadores por Año</strong> muestra el total de jugadores
                                registrados en el torneo agrupados por <strong>año de nacimiento</strong>.
                                Puedes filtrar por equipo para ver la distribución de edades de cada plantel.
                            </p>
                            <div class="ayuda-tip">
                                📌 Esta pantalla es de <strong>solo consulta</strong>. No permite agregar,
                                editar ni eliminar registros. Para administrar jugadores ve al módulo
                                <em>Jugadores</em>.
                            </div>
                        </div>

                        <div class="ayuda-section">
                            <h5>🎯 Importancia del reporte por edad</h5>
                            <p>
                                Conocer la distribución de edades de los jugadores es clave para
                                <strong>planear futuros torneos</strong> y tomar decisiones estratégicas:
                            </p>
                            <table class="ayuda-table">
                                <thead>
                                    <tr><th>Información</th><th>Para qué sirve</th></tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>Total de jugadores por año</td>
                                        <td>Identificar qué generaciones tienen más jugadores disponibles.</td>
                                    </tr>
                                    <tr>
                                        <td>Distribución por equipo</td>
                                        <td>Ver si un equipo está formado principalmente por jugadores jóvenes o veteranos.</td>
                                    </tr>
                                    <tr>
                                        <td>Proyección de equipos</td>
                                        <td>Estimar cuántos equipos se podrían armar en torneos por categoría de edad.</td>
                                    </tr>
                                    <tr>
                                        <td>Requisitos de edad</td>
                                        <td>Verificar si los jugadores cumplen el rango de edad exigido por el torneo.</td>
                                    </tr>
                                </tbody>
                            </table>
                            <div class="ayuda-tip">
                                💡 <strong>Ejemplo:</strong> Si hay 60 jugadores nacidos entre 2008 y 2010,
                                podrías planear un torneo <em>sub-17</em> con hasta 5 equipos de 11 jugadores.
                                Si la mayoría son veteranos, conviene organizar una categoría <em>máster</em>.
                            </div>
                        </div>

                        <div class="ayuda-section">
                            <h5>🔍 Filtrar por equipo</h5>
                            <p>
                                Usa el <strong>selector de equipo</strong> para ver únicamente los jugadores
                                de un plantel específico agrupados por año. Esto te permite comparar
                                la composición de cada equipo y detectar si alguno cuenta con jugadores
                                fuera del rango de edad permitido.
                            </p>
                            <p>
                                Para volver al resumen general del torneo, selecciona la opción
                                vacía del selector.
                            </p>
                        </div>

                        <div class="ayuda-section">
                            <h5>📊 Columnas del listado</h5>
                            <table class="ayuda-table">
                                <thead>
                                    <tr><th>Columna</th><th>Descripción</th></tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td><strong>AÑO</strong></td>
                                        <td>Año de nacimiento de los jugadores agrupados.</td>
                                    </tr>
                                    <tr>
                                        <td><strong>TOTAL</strong></td>
                                        <td>Cantidad de jugadores nacidos en ese año (en el torneo o equipo seleccionado).</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <div class="ayuda-section">
                            <h5>📈 Casos de uso frecuentes</h5>
                            <p><strong>Organizar un nuevo torneo por categoría:</strong><br />
                            Consulta el total sin filtro de equipo para ver cuántos jugadores hay por generación
                            en el torneo completo. Con eso defines cuantas categorías y cuántos equipos se
                            pueden conformar.</p>
                            <p><strong>Detectar inconsistencias de edad:</strong><br />
                            Filtra por equipo y verifica que todos sus jugadores estén dentro del año de
                            nacimiento permitido por las reglas del torneo.</p>
                            <p><strong>Renovación de planteles:</strong><br />
                            Identifica equipos con muchos jugadores de años avanzados para prever cuáles
                            necesitarán renovar plantel en la siguiente temporada.</p>
                        </div>

                        <div class="ayuda-section ayuda-section-faq">
                            <h5>❓ Preguntas frecuentes</h5>
                            <p><strong>¿Por qué no veo ningún dato?</strong><br />
                            Asegúrate de que haya jugadores registrados en el torneo activo con fecha de
                            nacimiento capturada. Si faltan fechas de nacimiento, esos jugadores no aparecerán.</p>
                            <p><strong>¿Puedo exportar este reporte?</strong><br />
                            El reporte de jugadores por año no cuenta con botón de exportación en esta
                            pantalla. Para exportar jugadores completos usa el módulo <em>Jugadores</em>.</p>
                            <p><strong>¿Este listado se actualiza automáticamente?</strong><br />
                            Sí. Cada vez que entras a la pantalla o cambias el filtro de equipo, los datos
                            se consultan en tiempo real desde la base de datos.</p>
                            <p><strong>¿Puedo ver jugadores de otros torneos?</strong><br />
                            No. El reporte siempre corresponde al torneo activo que seleccionaste al iniciar
                            sesión. Para cambiar de torneo regresa a la pantalla de selección.</p>
                        </div>

                    </div>

                    <div class="ayuda-modal-footer">
                        <button class="btn ayuda-btn-cerrar" @onclick="() => showHelp = false">Cerrar guía</button>
                    </div>

                </div>
            </div>
        }

    </Authorized>
</AuthorizeView>

<style>
