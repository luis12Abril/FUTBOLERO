    .ayuda-section:last-child {
        border-bottom: none;
        margin-bottom: 0;
    }

    .ayuda-section h5 {
        color: #1e3a8a;
        font-weight: 700;
        font-size: 0.97rem;
        margin-bottom: 0.5rem;
    }

    .ayuda-section p {
        color: #475569;
        font-size: 0.9rem;
