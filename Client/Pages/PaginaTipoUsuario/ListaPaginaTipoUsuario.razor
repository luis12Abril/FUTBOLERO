@page "/ListaPaginaTipoUsuarioBoton/{Id}"
@using FUTBOLERO.Shared
@inject HttpClient http

@{
    string[] cabeceras = { "Nombre de la página", "Nombre Tipo Usuario" };
    string[] propiedades = { "nombrepagina", "nombretipousuario" };
}

<AuthorizeView>
    <Authorized>
        <Listados cabeceras=cabeceras
                  nombrePropiedadesMostrar=propiedades
                  lista=listadoPaginaTipoUsuario
                  type="combobox" button=false label="Seleccione Tipo Usuario"
                  permitirEditar=@permitirEditar rutaEditar="EditarPaginaTipoUsuarioBoton"
                  combobox="oTipoUsuarioCLS" displayMember="nombre" valueMember="iidTipoUsuario"
                  eventBusqueda="BuscarListaPaginaTipoUsuario"
                  permitirExportarExcel=@permitirExportarExcel
                  permitirExportarWord=@permitirExportarWord
                  permitirExportarPdf=@permitirExportarPDF
                  tituloReporte="Paginas a las que puede acceder un Tipo Usuario" />
    </Authorized>
</AuthorizeView>



@code {
    public PaginaTipoUsuarioCLS[] listadoPaginaTipoUsuario;
    public TipoUsuarioCLS[] oTipoUsuarioCLS;

    [Parameter]
    public string Id { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState> auth { get; set; }

    // AQUI PODEMOS QUITAR LAS VARIABLES Agregar Y Eliminar
    public bool permitirAgregar = false;
    public bool permitirEditar = false;
    public bool permitirEliminar = false;
    public bool permitirExportarExcel = false;
    public bool permitirExportarWord = false;
    public bool permitirExportarPDF = false;

    List<int> listaBotones = new List<int>();


    protected override async Task OnInitializedAsync()
    {
        listadoPaginaTipoUsuario = await http.GetFromJsonAsync<PaginaTipoUsuarioCLS[]>("api/PaginaTipoUsuario/listarPaginaTipoUsuario");
        oTipoUsuarioCLS = await http.GetFromJsonAsync<TipoUsuarioCLS[]>("api/TipoUsuario/listarTipoUsuario");

        var authuser = await auth;
        var user = authuser.User;
        if (user.Identity.IsAuthenticated)
        {
            listaBotones = await http.GetFromJsonAsync<List<int>>("api/PaginaTipoUsuario/ListarBotones/" + user.Identity.Name + "/" + Id);
            //listaBotones = await http.GetFromJsonAsync<List<int>>("api/PaginaTipoUsuario/listarBotones/" + user.Identity.Name);
            //listaBotones = await http.GetFromJsonAsync<List<int>>("api/PaginaTipoUsuario/listarBotones/" + 4 + "/" + 1);

            if (listaBotones.Count() > 0)
            {
                if (listaBotones.Contains(1)) permitirAgregar = true;
                if (listaBotones.Contains(2)) permitirEditar = true;
                if (listaBotones.Contains(3)) permitirEliminar = true;
                if (listaBotones.Contains(4)) permitirExportarExcel = true;
                if (listaBotones.Contains(5)) permitirExportarWord = true;
                if (listaBotones.Contains(6)) permitirExportarPDF = true;
            }
        }
    }


    public async Task BuscarListaPaginaTipoUsuario(string buscarNombreTipoUsuario)
    {
        listadoPaginaTipoUsuario = await http.GetFromJsonAsync<PaginaTipoUsuarioCLS[]>("api/PaginaTipoUsuario/FiltrarPaginaTipoUsuario/" + buscarNombreTipoUsuario);
    }
}

