@page "/ListaEstatusJuego/{Id}"
@using FUTBOLERO.Shared
@inject HttpClient http
@inject IJSRuntime ijsruntime

@{
    string[] cabeceras = { "Nombre" };
    string[] propiedades = { "nombre" };
}

<AuthorizeView>
    <Authorized>
        <section class="catalogo-page mt-3">
            <div class="catalogo-header-card">
                <div>
                    <p class="catalogo-kicker">Panel de administración</p>
                    <h3>Estatus de Juego</h3>
                    <span>Administra los estatus disponibles para los juegos del torneo.</span>
                </div>
                <div class="catalogo-header-right">
                    <div class="catalogo-badge">
                        <span>Catálogo</span>
                    </div>
                    <button class="catalogo-help-btn" @onclick="() => showHelp = true" title="Ayuda">
                        <span>?</span>
                    </button>
                </div>
            </div>

            @if (listadoEstatusJuego == null)
            {
                <div class="catalogo-loading">
                    <div class="spinner-border text-primary" role="status"></div>
                    <span class="ml-2">Cargando estatus...</span>
                </div>
            }
            else
            {
                <div class="catalogo-list-card">
                    <Listados cabeceras=cabeceras
                              nombrePropiedadesMostrar=propiedades
                              lista=listadoEstatusJuego
                              type="text" button=false label="Estatus"
                              permitirAgregar=@permitirAgregar rutaAgregar="AgregarEstatusJuego"
                              permitirEditar=@permitirEditar rutaEditar="EditarEstatusJuego"
                              permitirEliminar=@permitirEliminar eventEliminar="EliminarListaEstatusJuego"
                              eventBusqueda="BuscarListaEstatusJuego"
                              permitirExportarExcel=@permitirExportarExcel
                              permitirExportarWord=@permitirExportarWord
                              permitirExportarPdf=@permitirExportarPDF
                              tituloReporte="Listados de Estatus del Juego" />
                </div>
            }
        </section>

        @* ── MODAL DE AYUDA ── *@
        @if (showHelp)
        {
            <div class="ayuda-overlay" @onclick="() => showHelp = false">
                <div class="ayuda-modal" @onclick:stopPropagation="true">

                    <div class="ayuda-modal-header">
                        <div>
                            <span class="ayuda-kicker">Guía de uso</span>
                            <h4>Módulo de Estatus de Juego</h4>
                        </div>
                        <button class="ayuda-close-btn" @onclick="() => showHelp = false">✕</button>
                    </div>

                    <div class="ayuda-modal-body">

                        <div class="ayuda-section">
                            <h5>🎮 ¿Qué es esta pantalla?</h5>
                            <p>
                                La pantalla <strong>Estatus de Juego</strong> administra los posibles estados
                                en que puede encontrarse un partido del torneo. El estatus de un juego
                                determina si ese partido <strong>aplica o no para la tabla de posiciones</strong>.
                            </p>
                        </div>

                        <div class="ayuda-section">
                            <h5>🔒 Estatus reservados del sistema</h5>
                            <p>
                                Al crearse el torneo el sistema genera automáticamente dos estatus
                                que <strong>no pueden eliminarse</strong> porque son esenciales para el funcionamiento:
                            </p>
                            <table class="ayuda-table">
                                <thead>
                                    <tr><th>Estatus</th><th>¿Aplica para posiciones?</th><th>Significado</th></tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td><strong>PENDIENTE</strong></td>
                                        <td>🚫 No aplica</td>
                                        <td>El juego aún no tiene toda la información confirmada (goles, resultado, etc.). Mientras esté en PENDIENTE, <strong>no se contabiliza en la tabla de posiciones</strong>.</td>
                                    </tr>
                                    <tr>
                                        <td><strong>JUGADO</strong></td>
                                        <td>✅ Sí aplica</td>
                                        <td>El juego ya tiene toda la información necesaria capturada. Al marcarlo como JUGADO, <strong>sí se contabiliza en la tabla de posiciones</strong>.</td>
                                    </tr>
                                </tbody>
                            </table>
                            <div class="ayuda-tip">
                                📌 Un juego recién programado siempre comienza en estado <strong>PENDIENTE</strong>.
                                El administrador lo cambia a <strong>JUGADO</strong> una vez que captura el resultado final.
                            </div>
                        </div>

                        <div class="ayuda-section">
                            <h5>➕ ¿Se pueden agregar más estatus?</h5>
                            <p>
                                Sí. Puedes agregar estatus adicionales como <em>SUSPENDIDO</em>,
                                <em>NO SE JUGÓ</em>, <em>APLAZADO</em>, etc. Para ello haz clic en
                                <strong>Agregar</strong> e ingresa el nombre del nuevo estatus.
                            </p>
                            <div class="ayuda-tip ayuda-tip-warning">
                                ⚠️ <strong>Recomendación:</strong> Se sugiere trabajar únicamente con los dos
                                estatus del sistema (<em>PENDIENTE</em> y <em>JUGADO</em>) para mantener
                                la consistencia de la tabla de posiciones. Los estatus adicionales
                                <strong>no cuentan para posiciones</strong> y pueden generar confusión
                                si no se gestionan con cuidado.
                            </div>
                        </div>

                        <div class="ayuda-section">
                            <h5>🔍 Buscar un estatus</h5>
                            <p>
                                Usa la <strong>barra de búsqueda</strong> para filtrar estatus por nombre.
                                Escribe parte del nombre y el listado se actualizará automáticamente.
                                Si borras el texto y buscas de nuevo, regresa al listado completo.
                            </p>
                        </div>

                        <div class="ayuda-section">
                            <h5>✏️ Editar un estatus</h5>
                            <p>
                                Haz clic en el botón <strong>Editar</strong> en la fila del estatus que
                                deseas modificar. Podrás cambiar su nombre. Presiona <strong>Guardar</strong>
                                para confirmar.
                            </p>
                            <div class="ayuda-tip ayuda-tip-warning">
                                ⚠️ Evita renombrar <em>PENDIENTE</em> o <em>JUGADO</em> ya que el sistema
                                los identifica por su nombre para calcular la tabla de posiciones.
                            </div>
                        </div>

                        <div class="ayuda-section">
                            <h5>🗑️ Eliminar un estatus</h5>
                            <p>
                                Haz clic en el botón <strong>Eliminar</strong> en la fila correspondiente.
                                El sistema pedirá confirmación antes de borrar.
                            </p>
                            <table class="ayuda-table">
                                <thead>
                                    <tr><th>Resultado</th><th>Mensaje</th></tr>
                                </thead>
                                <tbody>
                                    <tr><td>✅ Eliminado correctamente</td><td>OK, EL ESTATUS SE ELIMINÓ</td></tr>
                                    <tr><td>⚠️ Tiene juegos con ese estatus</td><td>NO SE PUEDE BORRAR, HAY JUEGOS CON ESE ESTATUS</td></tr>
                                    <tr><td>🔒 Estatus PENDIENTE</td><td>PENDIENTE NO SE DEBE BORRAR</td></tr>
                                    <tr><td>🔒 Estatus JUGADO</td><td>JUGADO NO SE DEBE BORRAR</td></tr>
                                    <tr><td>❌ Error inesperado</td><td>OCURRIÓ UN ERROR, NO SE PUDO BORRAR</td></tr>
                                </tbody>
                            </table>
                        </div>

                        <div class="ayuda-section">
                            <h5>📤 Exportar el listado</h5>
                            <p>Si tienes permiso, puedes exportar el listado de estatus en: <strong>Excel</strong>, <strong>Word</strong> y <strong>PDF</strong>.</p>
                        </div>

                        <div class="ayuda-section ayuda-section-faq">
                            <h5>❓ Preguntas frecuentes</h5>
                            <p><strong>¿Por qué no puedo borrar PENDIENTE o JUGADO?</strong><br />
                            Son estatus reservados del sistema. Sin ellos el flujo de captura de juegos y el cálculo de posiciones no funcionarían correctamente.</p>
                            <p><strong>¿Un juego en PENDIENTE afecta la tabla de posiciones?</strong><br />
                            No. Solo los juegos en estado <strong>JUGADO</strong> se contabilizan en la tabla de posiciones.</p>
                            <p><strong>¿Puedo crear un estatus SUSPENDIDO?</strong><br />
                            Sí, pero los juegos con ese estatus no aplicarán para la tabla de posiciones. Se recomienda usarlo solo si realmente lo necesitas y con criterio claro.</p>
                            <p><strong>¿Por qué no veo los botones de Agregar / Editar / Eliminar?</strong><br />
                            Tu usuario no tiene ese permiso asignado. Contacta al administrador del sistema.</p>
                        </div>

                    </div>

                    <div class="ayuda-modal-footer">
                        <button class="btn ayuda-btn-cerrar" @onclick="() => showHelp = false">Cerrar guía</button>
                    </div>

                </div>
            </div>
        }

    </Authorized>
</AuthorizeView>

