@page "/ListaMunicipio/{Id}"
@using FUTBOLERO.Shared
@inject HttpClient http
@inject IJSRuntime ijsruntime

@{
    string[] cabeceras = { "Municipio", "Estado",  };

    // ESTAS PROPIEDADES TIENEN QUE SER IGUAL A LAS QUE ESTAN EN EL CONTROLADOR
    string[] propiedades = { "nombre", "estado" };
}

<AuthorizeView>
    <Authorized>
        <Listados cabeceras=cabeceras
                  nombrePropiedadesMostrar=propiedades
                  lista=listadoMunicipio
                  type="combobox" button=false label="Seleccione un Estado"
                  combobox="oEstadoCLS" displayMember="nombre" valueMember="idestado"
                  eventBusqueda="BuscarListaMunicipio"
                  permitirAgregar=@permitirAgregar rutaAgregar="AgregarMunicipio"
                  permitirEditar=@permitirEditar rutaEditar="EditarMunicipio"
                  permitirEliminar=@permitirEliminar eventEliminar="EliminarListaMunicipio"
                  permitirExportarExcel=@permitirExportarExcel
                  permitirExportarWord=@permitirExportarWord
                  permitirExportarPdf=@permitirExportarPDF
                  tituloReporte="Listado de Municipios" />
    </Authorized>
</AuthorizeView>

@*LO SAQUE DE AUTHORIZEVIEW PORQUE SOLO ES UNA LISTA Y AL HACER REFRESH EN EL CELULAR SE PIEDE LA CONEXION, NO AFEACTA PORQUE NO DA ENTRADA A DATOS*@
@*<Listados cabeceras=cabeceras
    nombrePropiedadesMostrar=propiedades
    lista=listadoJugador
    type="combobox" button=false label="Seleccione un equipo"
    combobox="oEquipoCLS" displayMember="nombre" valueMember="idequipo"
    eventBusqueda="BuscarListaJugador"
    permitirAgregar=@permitirAgregar rutaAgregar="AgregarJugador"
    permitirEditar=@permitirEditar rutaEditar="EditarJugador"
    permitirEliminar=@permitirEliminar eventEliminar="EliminarListaJugador"
    permitirExportarExcel=@permitirExportarExcel
    permitirExportarWord=@permitirExportarWord
    permitirExportarPdf=@permitirExportarPDF
    tituloReporte="Listado de Jugadores" />*@


@code {
    public string mensaje;

    public string idtorneoseleccionado;

    public string torneoMensaje { get; set; }

    public MunicipioCLS[] listadoMunicipio;

    public MunicipioCLS oMunicipioCLSBorrar = new MunicipioCLS();         // ESTE LO PONGO PARA SACAR EL NOMBRE DEL MUNICIPIO Y MANDARLO COMO PARAMETRO AL BORRAR

    public EstadoCLS[] oEstadoCLS;      // ESTO ES PORQUE SE VA HACER UNA BUSQUEDA POR COMBOBOX

    [CascadingParameter]
    private Task<AuthenticationState> auth { get; set; }

    [Parameter]
    public string Id { get; set; }

    public bool permitirAgregar = false;
    public bool permitirEditar = false;
    public bool permitirEliminar = false;
    public bool permitirExportarExcel = false;
    public bool permitirExportarWord = false;
    public bool permitirExportarPDF = false;

    List<int> listaBotones = new List<int>();


    protected override async Task OnInitializedAsync()
    {
        var authuser = await auth;
        var user = authuser.User;

        if (user.Identity.IsAuthenticated)
        {
            var claims = user.Claims.ToList();
            var torneo = claims[1].Value;

            // AQUI ESTOY RECIENDO EN CADENA EL ID DE TORNEO SELECCIONADO
            idtorneoseleccionado = claims[2].Value;

            torneoMensaje = torneo;

            listadoMunicipio = await http.GetFromJsonAsync<MunicipioCLS[]>("api/Municipio/ListarMunicipio");
            oEstadoCLS = await http.GetFromJsonAsync<EstadoCLS[]>("api/Estado/ListarEstado");    // ESTE LO LLENO PORQUE SE VA HA UTILIZAR EN EL COMBO BUSQUEDA DE ESTADOS

            if (user.Identity.IsAuthenticated)
            {
                //listaBotones = await http.GetFromJsonAsync<List<int>>("api/PaginaTipoUsuario/listarBotones/" + user.Identity.Name + "/" + Id);

                //  ESTO LO HAGO PORQUE SI ES UN ADMINISTRADOR Y NO TIENE DERECHO A ADMINISTRAR EL TORNEO SELECCIONADO TENDRA QUE VERLO COMO INVITADO
                listaBotones = await http.GetFromJsonAsync<List<int>>("api/PaginaTipoUsuario/listarBotones2/" + user.Identity.Name + "/" + Id + "/" + idtorneoseleccionado);

                if (listaBotones.Count() > 0)
                {
                    if (listaBotones.Contains(1)) permitirAgregar = true;
                    if (listaBotones.Contains(2)) permitirEditar = true;
                    if (listaBotones.Contains(3)) permitirEliminar = true;
                    if (listaBotones.Contains(4)) permitirExportarExcel = true;
                    if (listaBotones.Contains(5)) permitirExportarWord = true;
                    if (listaBotones.Contains(6)) permitirExportarPDF = true;
                }
            }
        }
    }


    public async Task BuscarListaMunicipio(string buscarNombreMunicipio)
    {
        if (buscarNombreMunicipio == null || buscarNombreMunicipio == "")
        {
            listadoMunicipio = await http.GetFromJsonAsync<MunicipioCLS[]>("api/Municipio/ListarMunicipio");
        }
        else
        {
            //listadoMunicipio = await http.GetFromJsonAsync<MunicipioCLS[]>("api/Municipio/FiltrarMunicipio/" + "2");
            listadoMunicipio = await http.GetFromJsonAsync<MunicipioCLS[]>("api/Municipio/FiltrarMunicipio/" + buscarNombreMunicipio);
        }
    }


    public async Task EliminarListaMunicipio(string idMunicipio)       // LO PONEMOS COMO STRING PORQUE EN EL LISTADOSRAZOR2 ESTA COMO STRING
    {
        oMunicipioCLSBorrar = await http.GetFromJsonAsync<MunicipioCLS>("api/Municipio/RecuperarInformacionMunicipio/" + idMunicipio);


        if (await ijsruntime.InvokeAsync<bool>("ConfirmarBorrar", "Confirmar", "VAS A BORRAR A: " + oMunicipioCLSBorrar.nombre, "warning"))
        {
            int rpta = await http.GetFromJsonAsync<int>("api/Municipio/EliminarMunicipio/" + idMunicipio + "/" + idtorneoseleccionado);

            // 0 = OCURRIO UN ERROR     1 = SE BORRO ON     2 = HAY LIGAS EN ESE MUNICIPIO
            switch (rpta)
            {
                case 0:
                    await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "ERROR, NO SE PUDO DAR DE BAJA", "error");
                    break;
                case 1:
                    await ijsruntime.InvokeVoidAsync("MostrarMensajetime", "OK, EL MUNICIPIO SE ELIMINO", "success", 2000);
                    listadoMunicipio = await http.GetFromJsonAsync<MunicipioCLS[]>("api/Municipio/ListarMunicipio");
                    break;
                default:
                    break;
            }
        }
    }
}




