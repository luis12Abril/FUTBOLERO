@page "/ListaTorneoColegio/{Id}"
@using FUTBOLERO.Shared
@inject HttpClient http
@inject IJSRuntime ijsruntime

@{
    string[] cabeceras = { "Torneo", "Liga", };

    // ESTAS PROPIEDADES TIENEN QUE SER IGUAL A LAS QUE ESTAN EN EL CONTROLADOR
    string[] propiedades = { "nombre", "liga" };
}

<AuthorizeView>
    <Authorized>
        <Listados cabeceras=cabeceras
                  nombrePropiedadesMostrar=propiedades
                  lista=listadoTorneoColegio
                  permitirAgregar=@permitirAgregar rutaAgregar="AgregarTorneoColegio"
                  permitirEditar=@permitirEditar rutaEditar="EditarTorneoColegio"
                  permitirEliminar=@permitirEliminar eventEliminar="EliminarListaTorneoColegio"
                  permitirExportarExcel=@permitirExportarExcel
                  permitirExportarWord=@permitirExportarWord
                  permitirExportarPdf=@permitirExportarPDF
                  tituloReporte="Listado de Torneos" />
    </Authorized>
</AuthorizeView>
@*type="combobox" button=false label="Seleccione un Colegio"
    combobox="oColegioCLS" displayMember="nombre" valueMember="idcolegio"
    eventBusqueda="BuscarListaLigaColegio"*@

@code {

    public string idtorneoseleccionado;

    public TorneoColegioCLS[] listadoTorneoColegio;

    public TorneoColegioCLS oTorneoColegioCLSBorrar = new TorneoColegioCLS();         // ESTE LO PONGO PARA SACAR EL NOMBRE DEL TORNEO Y MANDARLO COMO PARAMETRO AL BORRAR

    public LigaColegioCLS[] oLigaColegioCLS;      // ESTO ES PORQUE SE VA HACER UNA BUSQUEDA POR COMBOBOX

    [CascadingParameter]
    private Task<AuthenticationState> auth { get; set; }

    [Parameter]
    public string Id { get; set; }

    public bool permitirAgregar = false;
    public bool permitirEditar = false;
    public bool permitirEliminar = false;
    public bool permitirExportarExcel = false;
    public bool permitirExportarWord = false;
    public bool permitirExportarPDF = false;

    List<int> listaBotones = new List<int>();


    protected override async Task OnInitializedAsync()
    {
        var authuser = await auth;
        var user = authuser.User;

        if (user.Identity.IsAuthenticated)
        {
            var claims = user.Claims.ToList();
            var torneo = claims[1].Value;

            // AQUI ESTOY RECIENDO EN CADENA EL ID DE TORNEO SELECCIONADO
            idtorneoseleccionado = claims[2].Value;

            listadoTorneoColegio = await http.GetFromJsonAsync<TorneoColegioCLS[]>("api/TorneoColegio/ListaTorneoColegio");
            //oColegioCLS = await http.GetFromJsonAsync<ColegioCLS[]>("api/Colegio/ListarColegio");    // ESTE LO LLENO PORQUE SE VA HA UTILIZAR EN EL COMBO BUSQUEDA DE ESTADOS

            if (user.Identity.IsAuthenticated)
            {
                //listaBotones = await http.GetFromJsonAsync<List<int>>("api/PaginaTipoUsuario/listarBotones/" + user.Identity.Name + "/" + Id);

                //  ESTO LO HAGO PORQUE SI ES UN ADMINISTRADOR Y NO TIENE DERECHO A ADMINISTRAR EL TORNEO SELECCIONADO TENDRA QUE VERLO COMO INVITADO
                listaBotones = await http.GetFromJsonAsync<List<int>>("api/PaginaTipoUsuario/listarBotones2/" + user.Identity.Name + "/" + Id + "/" + idtorneoseleccionado);

                if (listaBotones.Count() > 0)
                {
                    if (listaBotones.Contains(1)) permitirAgregar = true;
                    if (listaBotones.Contains(2)) permitirEditar = true;
                    if (listaBotones.Contains(3)) permitirEliminar = true;
                    if (listaBotones.Contains(4)) permitirExportarExcel = true;
                    if (listaBotones.Contains(5)) permitirExportarWord = true;
                    if (listaBotones.Contains(6)) permitirExportarPDF = true;
                }
            }
        }
    }


    //public async Task BuscarListaLigaColegio(string buscarNombreLigaColegio)
    //{
    //    if (buscarNombreLigaColegio == null || buscarNombreLigaColegio == "")
    //    {
    //        listadoLigaColegio = await http.GetFromJsonAsync<LigaColegioCLS[]>("api/LigaColegio/ListaLigaColegio");
    //    }
    //    else
    //    {
    //        //listadoMunicipio = await http.GetFromJsonAsync<MunicipioCLS[]>("api/Municipio/FiltrarMunicipio/" + "2");
    //        listadoLigaColegio = await http.GetFromJsonAsync<LigaColegioCLS[]>("api/LigaColegio/ListaLigaColegio" + buscarNombreLigaColegio);
    //    }
    //}


    public async Task EliminarListaTorneoColegio(string idTorneoColegio)       // LO PONEMOS COMO STRING PORQUE EN EL LISTADOSRAZOR2 ESTA COMO STRING
    {
        oTorneoColegioCLSBorrar = await http.GetFromJsonAsync<TorneoColegioCLS>("api/TorneoColegio/RecuperarInformacionTorneoColegio/" + idTorneoColegio);


        if (await ijsruntime.InvokeAsync<bool>("ConfirmarBorrar", "Confirmar", "VAS A BORRAR A: " + oTorneoColegioCLSBorrar.nombre, "warning"))
        {
            int rpta = await http.GetFromJsonAsync<int>("api/TorneoColegio/EliminarTorneoColegio/" + idTorneoColegio);

            // 0 = OCURRIO UN ERROR     1 = SE BORRO ON     2 = HAY LIGAS EN ESE MUNICIPIO
            switch (rpta)
            {
                case 0:
                    await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "ERROR, NO SE PUDO DAR DE BAJA", "error");
                    break;
                case 1:
                    await ijsruntime.InvokeVoidAsync("MostrarMensajetime", "OK, LA LIGA SE ELIMINO", "success", 2000);
                    listadoTorneoColegio = await http.GetFromJsonAsync<TorneoColegioCLS[]>("api/TorneoColegio/ListaTorneoColegio");
                    break;
                default:
                    break;
            }
        }
    }
}





