@page "/ListaJornada/{Id}"
@using FUTBOLERO.Shared
@inject HttpClient http
@inject IJSRuntime ijsruntime

@{
    string[] cabeceras = { "Nombre", "Fecha de la Jornada" };
    string[] propiedades = { "nombre", "fjornada" };
}

<AuthorizeView>
    <Authorized>
        <Listados cabeceras=cabeceras
                  nombrePropiedadesMostrar=propiedades
                  lista=listadoJornada
                  type="text" button=false label="Nombre de la Jornada"
                  permitirAgregar=@permitirAgregar rutaAgregar="AgregarJornada"
                  permitirEditar=@permitirEditar rutaEditar="EditarJornada"
                  permitirEliminar=@permitirEliminar eventEliminar="EliminarListaJornada"
                  eventBusqueda="BuscarListaJornada"
                  permitirExportarExcel=@permitirExportarExcel
                  permitirExportarWord=@permitirExportarWord
                  permitirExportarPdf=@permitirExportarPDF
                  tituloReporte="Listado de Jornadas" />
    </Authorized>
</AuthorizeView>

@code {
    public string idtorneoseleccionado;

    public string torneoMensaje { get; set; }

    public JornadaCLS[] listadoJornada;

    public JornadaCLS oJornadaCLSBorrar = new JornadaCLS();         // ESTE LO PONGO PARA SACAR EL NOMBRE DE LA JORNADA Y MANDARLA COMO PARAMETRO AL BORRAR

    [CascadingParameter]
    private Task<AuthenticationState> auth { get; set; }

    [Parameter]
    public string Id { get; set; }

    public bool permitirAgregar = false;
    public bool permitirEditar = false;
    public bool permitirEliminar = false;
    public bool permitirExportarExcel = false;
    public bool permitirExportarWord = false;
    public bool permitirExportarPDF = false;

    List<int> listaBotones = new List<int>();

    protected override async Task OnInitializedAsync()
    {
        var authuser = await auth;
        var user = authuser.User;

        if (user.Identity.IsAuthenticated)
        {
            var claims = user.Claims.ToList();
            var torneo = claims[1].Value;

            // AQUI ESTOY RECIENDO EN CADENA EL ID DE TORNEO SELECCIONADO
            idtorneoseleccionado = claims[2].Value;

            torneoMensaje = torneo;

            listadoJornada = await http.GetFromJsonAsync<JornadaCLS[]>("api/Jornada/ListarJornada/" + idtorneoseleccionado);

            if (user.Identity.IsAuthenticated)
            {
                listaBotones = await http.GetFromJsonAsync<List<int>>("api/PaginaTipoUsuario/listarBotones/" + user.Identity.Name + "/" + Id);

                if (listaBotones.Count() > 0)
                {
                    if (listaBotones.Contains(1)) permitirAgregar = true;
                    if (listaBotones.Contains(2)) permitirEditar = true;
                    if (listaBotones.Contains(3)) permitirEliminar = true;
                    if (listaBotones.Contains(4)) permitirExportarExcel = true;
                    if (listaBotones.Contains(5)) permitirExportarWord = true;
                    if (listaBotones.Contains(6)) permitirExportarPDF = true;
                }
            }
        }
    }


    public async Task BuscarListaJornada(string buscarNombreJornada)
    {
        if (buscarNombreJornada == null || buscarNombreJornada == "")
        {
            listadoJornada = await http.GetFromJsonAsync<JornadaCLS[]>("api/Jornada/ListarJornada/" + idtorneoseleccionado);
        }
        else
        {
            listadoJornada = await http.GetFromJsonAsync<JornadaCLS[]>("api/Jornada/FiltrarJornada/" + buscarNombreJornada + "/" + idtorneoseleccionado);
        }
    }


    public async Task EliminarListaJornada(string idJornada)       // LO PONEMOS COMO STRING PORQUE EN EL LISTADOSRAZOR2 ESTA COMO STRING
    {

        oJornadaCLSBorrar = await http.GetFromJsonAsync<JornadaCLS>("api/Jornada/RecuperarInformacionJornada/" + idJornada);

        if (await ijsruntime.InvokeAsync<bool>("ConfirmarBorrar", "Confirmar", "VAS A BORRAR A: " + oJornadaCLSBorrar.nombre, "warning"))
        {
            int rpta = await http.GetFromJsonAsync<int>("api/Jornada/EliminarJornada/" + idJornada);

            // 0 = OCURRIO UN ERROR     1 = SE BORRO CORRECTAMENTE   2 = HAY JUEGOS CON ESA JORNADA
            switch (rpta)
            {
                case 0:
                    await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "OCURRIO UN ERROR, NO SE PUDO BORRAR", "error");
                    break;
                case 1:
                    await ijsruntime.InvokeVoidAsync("MostrarMensajetime", "OK, LA JORNADA SE ELIMINO", "success", 2000);
                    listadoJornada = await http.GetFromJsonAsync<JornadaCLS[]>("api/Jornada/ListarJornada/" + idtorneoseleccionado);
                    break;
                case 2:
                    await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "NO SE PUEDE BORRAR, HAY JUEGOS CON ESA JORNADA", "warning");
                    break;
                default:
                    break;
            }
        }
    }
}

