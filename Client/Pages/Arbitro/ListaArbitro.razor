@page "/ListaArbitro/{Id}"
@using FUTBOLERO.Shared
@inject HttpClient http
@inject IJSRuntime ijsruntime

@{
    string[] cabeceras = { "Nombre" };
    string[] propiedades = { "nombrecompleto" };

}

<AuthorizeView>
    <Authorized>
        <section class="catalogo-page mt-3">
            <div class="catalogo-header-card">
                <div>
                    <p class="catalogo-kicker">Panel de administración</p>
                    <h3>Árbitros</h3>
                    <span>Administra los árbitros disponibles para el torneo.</span>
                </div>
                <div class="catalogo-header-right">
                    <div class="catalogo-badge">
                        <span>Catálogo</span>
                    </div>
                    <button class="catalogo-help-btn" @onclick="() => showHelp = true" title="Ayuda">
                        <span>?</span>
                    </button>
                </div>
            </div>

            @if (listadoArbitro == null)
            {
                <div class="catalogo-loading">
                    <div class="spinner-border text-primary" role="status"></div>
                    <span class="ml-2">Cargando árbitros...</span>
                </div>
            }
            else
            {
                <div class="catalogo-list-card">
                    <Listados cabeceras=cabeceras
                              nombrePropiedadesMostrar=propiedades
                              lista=listadoArbitro
                              type="text" button=false label="Nombre del Arbitro"
                              permitirAgregar=@permitirAgregar rutaAgregar="AgregarArbitro"
                              permitirEditar=@permitirEditar rutaEditar="EditarArbitro"
                              permitirEliminar=@permitirEliminar eventEliminar="EliminarListaArbitro"
                              eventBusqueda="BuscarListaArbitro"
                              permitirExportarExcel=@permitirExportarExcel
                              permitirExportarWord=@permitirExportarWord
                              permitirExportarPdf=@permitirExportarPDF
                              tituloReporte="Listado de Arbitros" />
                </div>
            }
        </section>

        @* ── MODAL DE AYUDA ── *@
        @if (showHelp)
        {
            <div class="ayuda-overlay" @onclick="() => showHelp = false">
                <div class="ayuda-modal" @onclick:stopPropagation="true">

                    <div class="ayuda-modal-header">
                        <div>
                            <span class="ayuda-kicker">Guía de uso</span>
                            <h4>Módulo de Árbitros</h4>
                        </div>
                        <button class="ayuda-close-btn" @onclick="() => showHelp = false">✕</button>
                    </div>

                    <div class="ayuda-modal-body">

                        <div class="ayuda-section">
                            <h5>🟥 ¿Qué es esta pantalla?</h5>
                            <p>
                                La pantalla <strong>Árbitros</strong> administra el padrón de árbitros
                                disponibles para el torneo. Cada partido debe tener un árbitro asignado;
                                si aún no se conoce quién será, se usa el árbitro reservado
                                <strong>PENDIENTE</strong>. Solo verás los botones de acción para
                                los que tengas permiso asignado.
                            </p>
                        </div>

                        <div class="ayuda-section">
                            <h5>🔒 Árbitro reservado del sistema</h5>
                            <p>
                                Al crearse el torneo el sistema genera automáticamente un árbitro
                                llamado <strong>PENDIENTE</strong> que <strong>no debe eliminarse</strong>.
                                Su función es servir como marcador provisional cuando se programa un
                                partido pero todavía no se ha definido quién lo va a arbitrar.
                            </p>
                            <div class="ayuda-tip">
                                📌 Cuando ya tengas al árbitro confirmado, edita el juego correspondiente
                                y cambia el árbitro de <em>PENDIENTE</em> al nombre real.
                            </div>
                        </div>

                        <div class="ayuda-section">
                            <h5>🔍 Buscar un árbitro</h5>
                            <p>
                                Usa la <strong>barra de búsqueda</strong> para filtrar árbitros por nombre.
                                Escribe parte del nombre y el listado se actualizará automáticamente.
                                Si borras el texto y buscas de nuevo, regresa al listado completo.
                            </p>
                        </div>

                        <div class="ayuda-section">
                            <h5>➕ Agregar un árbitro</h5>
                            <p>Haz clic en <strong>Agregar</strong> y llena el formulario:</p>
                            <table class="ayuda-table">
                                <thead>
                                    <tr><th>Campo</th><th>Obligatorio</th><th>Descripción</th></tr>
                                </thead>
                                <tbody>
                                    <tr><td>Nombre</td><td>✅ Sí</td><td>Nombre del árbitro. Máximo 30 caracteres.</td></tr>
                                    <tr><td>Apellido Paterno</td><td>✅ Sí</td><td>Apellido paterno. Máximo 30 caracteres.</td></tr>
                                    <tr><td>Apellido Materno</td><td>❌ No</td><td>Apellido materno. Máximo 30 caracteres.</td></tr>
                                </tbody>
                            </table>
                            <p>Presiona <strong>Guardar</strong> para confirmar. El sistema muestra el nombre completo en el listado y en los juegos.</p>
                        </div>

                        <div class="ayuda-section">
                            <h5>✏️ Editar un árbitro</h5>
                            <p>
                                Haz clic en <strong>Editar</strong> en la fila del árbitro que deseas
                                modificar. Podrás cambiar nombre y apellidos.
                                Presiona <strong>Guardar</strong> para confirmar los cambios.
                            </p>
                            <div class="ayuda-tip ayuda-tip-warning">
                                ⚠️ Evita modificar el nombre del árbitro <em>PENDIENTE</em> ya que
                                el sistema lo identifica por ese nombre para los juegos sin árbitro definido.
                            </div>
                        </div>

                        <div class="ayuda-section">
                            <h5>🗑️ Eliminar un árbitro</h5>
                            <p>
                                Haz clic en <strong>Eliminar</strong> en la fila correspondiente.
                                El sistema pedirá confirmación antes de borrar.
                            </p>
                            <table class="ayuda-table">
                                <thead>
                                    <tr><th>Resultado</th><th>Mensaje</th></tr>
                                </thead>
                                <tbody>
                                    <tr><td>✅ Eliminado correctamente</td><td>OK, EL ÁRBITRO SE ELIMINÓ</td></tr>
                                    <tr><td>⚠️ Tiene juegos asignados</td><td>NO SE PUEDE BORRAR, HAY JUEGOS CON ESE ÁRBITRO</td></tr>
                                    <tr><td>🔒 Árbitro PENDIENTE</td><td>EL ÁRBITRO CON NOMBRE PENDIENTE NO SE DEBE BORRAR</td></tr>
                                    <tr><td>❌ Error inesperado</td><td>OCURRIÓ UN ERROR, NO SE PUDO BORRAR</td></tr>
                                </tbody>
                            </table>
                            <div class="ayuda-tip ayuda-tip-warning">
                                ⚠️ No es posible eliminar un árbitro que tenga partidos asignados.
                                Primero deben reasignarse esos juegos a otro árbitro.
                            </div>
                        </div>

                        <div class="ayuda-section">
                            <h5>📤 Exportar el listado</h5>
                            <p>Si tienes permiso, puedes exportar el listado de árbitros en: <strong>Excel</strong>, <strong>Word</strong> y <strong>PDF</strong>.</p>
                        </div>

                        <div class="ayuda-section ayuda-section-faq">
                            <h5>❓ Preguntas frecuentes</h5>
                            <p><strong>¿Por qué no puedo borrar el árbitro PENDIENTE?</strong><br />
                            Es un árbitro reservado del sistema. Sin él no podrías programar juegos cuando aún no sabes quién va a arbitrar.</p>
                            <p><strong>¿Por qué no puedo eliminar un árbitro?</strong><br />
                            Ese árbitro tiene partidos asignados. Primero edita esos juegos y cámbialos a otro árbitro, luego podrás eliminarlo.</p>
                            <p><strong>¿Puedo tener dos árbitros con el mismo nombre?</strong><br />
                            El sistema no bloquea nombres duplicados, pero se recomienda distinguirlos para evitar confusiones al asignarlos a los partidos.</p>
                            <p><strong>¿Por qué no veo los botones de Agregar / Editar / Eliminar?</strong><br />
                            Tu usuario no tiene ese permiso asignado. Contacta al administrador del sistema.</p>
                        </div>

                    </div>

                    <div class="ayuda-modal-footer">
                        <button class="btn ayuda-btn-cerrar" @onclick="() => showHelp = false">Cerrar guía</button>
                    </div>

                </div>
            </div>
        }

    </Authorized>
</AuthorizeView>

<style>
