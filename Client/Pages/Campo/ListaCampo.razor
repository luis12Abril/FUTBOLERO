@page "/ListaCampo/{Id}"
@using FUTBOLERO.Shared
@inject HttpClient http
@inject IJSRuntime ijsruntime

@{
    string[] cabeceras = { "Nombre", "Ubicación" };
    string[] propiedades = { "nombre", "ubicacion" };
}

<AuthorizeView>
    <Authorized>
        <section class="catalogo-page mt-3">
            <div class="catalogo-header-card">
                <div>
                    <p class="catalogo-kicker">Panel de administración</p>
                    <h3>Campos</h3>
                    <span>Administra los campos disponibles para el torneo.</span>
                </div>
                <div class="catalogo-badge">
                    <span>Catálogo</span>
                </div>
            </div>

            @if (listadoCampo == null)
            {
                <div class="catalogo-loading">
                    <div class="spinner-border text-primary" role="status"></div>
                    <span class="ml-2">Cargando campos...</span>
                </div>
            }
            else
            {
                <div class="catalogo-list-card">
                    <Listados cabeceras=cabeceras
                              nombrePropiedadesMostrar=propiedades
                              lista=listadoCampo
                              type="text" button=false label="Nombre del Campo"
                              permitirAgregar=@permitirAgregar rutaAgregar="AgregarCampo"
                              permitirEditar=@permitirEditar rutaEditar="EditarCampo"
                              permitirEliminar=@permitirEliminar eventEliminar="EliminarListaCampo"
                              eventBusqueda="BuscarListaCampo"
                              permitirExportarExcel=@permitirExportarExcel
                              permitirExportarWord=@permitirExportarWord
                              permitirExportarPdf=@permitirExportarPDF
                              tituloReporte="Listado de Campos" />
                </div>
            }
        </section>
    </Authorized>
</AuthorizeView>

<style>
    .catalogo-page {
        padding: 0.25rem 0;
    }

    .catalogo-header-card {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        background: linear-gradient(135deg, #eff6ff 0%, #eef2ff 45%, #f8fafc 100%);
        border: 1px solid #dbeafe;
        border-radius: 16px;
        padding: 1.1rem 1.25rem;
        margin-bottom: 1rem;
        box-shadow: 0 14px 28px rgba(30, 64, 175, 0.08);
    }

    .catalogo-kicker {
        margin: 0;
        color: #2563eb;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .catalogo-header-card h3 {
        margin: 0.15rem 0 0.25rem;
        color: #1e3a8a;
        font-weight: 800;
    }

    .catalogo-header-card span {
        color: #475569;
        font-size: 0.93rem;
    }

    .catalogo-badge span {
        display: inline-block;
        background: linear-gradient(90deg, #2563eb 0%, #1d4ed8 100%);
        color: #fff;
        border-radius: 999px;
        padding: 0.3rem 0.8rem;
        font-size: 0.78rem;
        font-weight: 700;
        box-shadow: 0 8px 18px rgba(37, 99, 235, 0.24);
    }

    .catalogo-list-card {
        background-color: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 0.75rem;
        box-shadow: 0 16px 32px rgba(15, 23, 42, 0.08);
    }

    .catalogo-loading {
        margin: 1.5rem 0;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1e3a8a;
        font-weight: 600;
    }

    @@media (max-width: 768px) {
        .catalogo-header-card {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

@code {
    public string idtorneoseleccionado;

    public string torneoMensaje { get; set; }

    public CampoCLS[] listadoCampo;

    public CampoCLS oCampoCLSBorrar = new CampoCLS();         // ESTE LO PONGO PARA SACAR EL NOMBRE DEL CAMPO Y MANDARLO COMO PARAMETRO AL BORRAR

    [CascadingParameter]
    private Task<AuthenticationState> auth { get; set; }

    [Parameter]
    public string Id { get; set; }

    public bool permitirAgregar = false;
    public bool permitirEditar = false;
    public bool permitirEliminar = false;
    public bool permitirExportarExcel = false;
    public bool permitirExportarWord = false;
    public bool permitirExportarPDF = false;

    List<int> listaBotones = new List<int>();


    protected override async Task OnInitializedAsync()
    {
        var authuser = await auth;
        var user = authuser.User;

        if (user.Identity.IsAuthenticated)
        {
            var claims = user.Claims.ToList();
            var torneo = claims[1].Value;

            // AQUI ESTOY RECIENDO EN CADENA EL ID DE TORNEO SELECCIONADO
            idtorneoseleccionado = claims[2].Value;

            torneoMensaje = torneo;

            listadoCampo = await http.GetFromJsonAsync<CampoCLS[]>("api/Campo/ListarCampo/" + idtorneoseleccionado);

            if (user.Identity.IsAuthenticated)
            {
                listaBotones = await http.GetFromJsonAsync<List<int>>("api/PaginaTipoUsuario/listarBotones/" + user.Identity.Name + "/" + Id);

                if (listaBotones.Count() > 0)
                {
                    if (listaBotones.Contains(1)) permitirAgregar = true;
                    if (listaBotones.Contains(2)) permitirEditar = true;
                    if (listaBotones.Contains(3)) permitirEliminar = true;
                    if (listaBotones.Contains(4)) permitirExportarExcel = true;
                    if (listaBotones.Contains(5)) permitirExportarWord = true;
                    if (listaBotones.Contains(6)) permitirExportarPDF = true;
                }
            }
        }
    }


    public async Task BuscarListaCampo(string buscarNombreCampo)
    {
        if (buscarNombreCampo == null || buscarNombreCampo == "")
        {
            listadoCampo = await http.GetFromJsonAsync<CampoCLS[]>("api/Campo/ListarCampo/" + idtorneoseleccionado);
        }
        else
        {
            listadoCampo = await http.GetFromJsonAsync<CampoCLS[]>("api/Campo/FiltrarCampo/" + buscarNombreCampo + "/" + idtorneoseleccionado);
        }
    }


    public async Task EliminarListaCampo(string idCampo)       // LO PONEMOS COMO STRING PORQUE EN EL LISTADOS ESTA COMO STRING
    {
        oCampoCLSBorrar = await http.GetFromJsonAsync<CampoCLS>("api/Campo/RecuperarInformacionCampo/" + idCampo);

        if (await ijsruntime.InvokeAsync<bool>("ConfirmarBorrar", "Confirmar", "VAS A BORRAR A: " + oCampoCLSBorrar.nombre, "warning"))
        {
            int rpta = await http.GetFromJsonAsync<int>("api/Campo/EliminarCampo/" + idCampo);

            // 0 = OCURRIO UN ERROR     1 = SE BORRO CORRECTAMENTE     2 = HAY JUEGOS CON ESE CAMPO     3 = ES UN CAMPO CON NOMBRE PENDIENTE(NO SE PUEDE BORAR)
            switch (rpta)
            {
                case 0:
                    await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "OCURRIO UN ERROR, NO SE PUDO BORRAR", "error");
                    break;
                case 1:
                    await ijsruntime.InvokeVoidAsync("MostrarMensajetime", "OK, EL CAMPO SE ELIMINO", "success", 2000);
                    listadoCampo = await http.GetFromJsonAsync<CampoCLS[]>("api/Campo/ListarCampo/" + idtorneoseleccionado);
                    break;
                case 2:
                    await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "NO SE PUEDE BORRAR, HAY JUEGOS EN ESE CAMPO", "warning");
                    break;
                case 3:
                    await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "EL CAMPO CON NOMBRE PENDIENTE NO SE DEBE BORRAR", "warning");
                    break;
                default:
                    break;
            }
        }
    }

}

