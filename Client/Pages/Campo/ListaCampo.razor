@page "/ListaCampo/{Id}"
@using FUTBOLERO.Shared
@inject HttpClient http
@inject IJSRuntime ijsruntime

@{
    string[] cabeceras = { "Nombre", "Ubicación" };
    string[] propiedades = { "nombre", "ubicacion" };
}

<AuthorizeView>
    <Authorized>
        <section class="catalogo-page mt-3">
            <div class="catalogo-header-card">
                <div>
                    <p class="catalogo-kicker">Panel de administración</p>
                    <h3>Campos</h3>
                    <span>Administra los campos disponibles para el torneo.</span>
                </div>
                <div class="catalogo-header-right">
                    <div class="catalogo-badge">
                        <span>Catálogo</span>
                    </div>
                    <button class="catalogo-help-btn" @onclick="() => showHelp = true" title="Ayuda">
                        <span>?</span>
                    </button>
                </div>
            </div>

            @if (listadoCampo == null)
            {
                <div class="catalogo-loading">
                    <div class="spinner-border text-primary" role="status"></div>
                    <span class="ml-2">Cargando campos...</span>
                </div>
            }
            else
            {
                <div class="catalogo-list-card">
                    <Listados cabeceras=cabeceras
                              nombrePropiedadesMostrar=propiedades
                              lista=listadoCampo
                              type="text" button=false label="Nombre del Campo"
                              permitirAgregar=@permitirAgregar rutaAgregar="AgregarCampo"
                              permitirEditar=@permitirEditar rutaEditar="EditarCampo"
                              permitirEliminar=@permitirEliminar eventEliminar="EliminarListaCampo"
                              eventBusqueda="BuscarListaCampo"
                              permitirExportarExcel=@permitirExportarExcel
                              permitirExportarWord=@permitirExportarWord
                              permitirExportarPdf=@permitirExportarPDF
                              tituloReporte="Listado de Campos" />
                </div>
            }
        </section>

        @* ── MODAL DE AYUDA ── *@
        @if (showHelp)
        {
            <div class="ayuda-overlay" @onclick="() => showHelp = false">
                <div class="ayuda-modal" @onclick:stopPropagation="true">

                    <div class="ayuda-modal-header">
                        <div>
                            <span class="ayuda-kicker">Guía de uso</span>
                            <h4>Módulo de Campos</h4>
                        </div>
                        <button class="ayuda-close-btn" @onclick="() => showHelp = false">✕</button>
                    </div>

                    <div class="ayuda-modal-body">

                        <div class="ayuda-section">
                            <h5>🏁 ¿Qué es esta pantalla?</h5>
                            <p>
                                La pantalla <strong>Campos</strong> te permite administrar los campos deportivos
                                o estadios en los que se disputarán los partidos del torneo. Cada juego
                                debe tener asignado un campo donde se celebrará.
                                Solo verás los botones de acción para los que tengas permiso asignado.
                            </p>
                        </div>

                        <div class="ayuda-section">
                            <h5>🔍 Buscar un campo</h5>
                            <p>
                                Usa la <strong>barra de búsqueda</strong> para filtrar campos por nombre.
                                Escribe parte del nombre y el listado se actualizará automáticamente.
                                Si borras el texto y buscas de nuevo, regresa al listado completo.
                            </p>
                        </div>

                        <div class="ayuda-section">
                            <h5>➕ Agregar un campo</h5>
                            <p>Haz clic en el botón <strong>Agregar</strong> y llena el formulario:</p>
                            <table class="ayuda-table">
                                <thead>
                                    <tr><th>Campo</th><th>Obligatorio</th><th>Descripción</th></tr>
                                </thead>
                                <tbody>
                                    <tr><td>Nombre</td><td>✅ Sí</td><td>Nombre del campo o estadio donde se jugarán los partidos. Máximo 50 caracteres.</td></tr>
                                    <tr><td>Ubicación</td><td>❌ No</td><td>Dirección o referencia del campo. Máximo 50 caracteres.</td></tr>
                                </tbody>
                            </table>
                            <p>Presiona <strong>Guardar</strong> para confirmar. Solo el nombre es obligatorio.</p>
                        </div>

                        <div class="ayuda-section">
                            <h5>✏️ Editar un campo</h5>
                            <p>
                                Haz clic en el botón <strong>Editar</strong> en la fila del campo que deseas
                                modificar. Podrás cambiar el nombre y la ubicación.
                                Presiona <strong>Guardar</strong> para confirmar los cambios.
                            </p>
                        </div>

                        <div class="ayuda-section">
                            <h5>🗑️ Eliminar un campo</h5>
                            <p>
                                Haz clic en el botón <strong>Eliminar</strong> en la fila correspondiente.
                                El sistema pedirá confirmación antes de borrar.
                            </p>
                            <table class="ayuda-table">
                                <thead>
                                    <tr><th>Resultado</th><th>Mensaje</th></tr>
                                </thead>
                                <tbody>
                                    <tr><td>✅ Eliminado correctamente</td><td>OK, EL CAMPO SE ELIMINÓ</td></tr>
                                    <tr><td>⚠️ Tiene juegos registrados</td><td>NO SE PUEDE BORRAR, HAY JUEGOS EN ESE CAMPO</td></tr>
                                    <tr><td>🔒 Campo PENDIENTE</td><td>EL CAMPO CON NOMBRE PENDIENTE NO SE DEBE BORRAR</td></tr>
                                    <tr><td>❌ Error inesperado</td><td>OCURRIÓ UN ERROR, NO SE PUDO BORRAR</td></tr>
                                </tbody>
                            </table>
                            <div class="ayuda-tip ayuda-tip-warning">
                                ⚠️ <strong>Campo PENDIENTE:</strong> El sistema reserva automáticamente un
                                campo llamado <em>PENDIENTE</em> para asignarlo provisionalmente a juegos
                                cuya sede aún no se ha definido. Este campo <strong>no debe eliminarse</strong>.
                            </div>
                            <div class="ayuda-tip">
                                📌 Tampoco es posible eliminar un campo que ya tenga partidos asignados.
                                Primero deben reasignarse o eliminarse esos juegos.
                            </div>
                        </div>

                        <div class="ayuda-section">
                            <h5>📤 Exportar el listado</h5>
                            <p>Si tienes permiso, puedes exportar el listado de campos en: <strong>Excel</strong>, <strong>Word</strong> y <strong>PDF</strong>.</p>
                        </div>

                        <div class="ayuda-section ayuda-section-faq">
                            <h5>❓ Preguntas frecuentes</h5>
                            <p><strong>¿Por qué no veo los botones de Agregar / Editar / Eliminar?</strong><br />
                            Tu usuario no tiene ese permiso asignado. Contacta al administrador del sistema.</p>
                            <p><strong>¿Por qué no puedo borrar el campo PENDIENTE?</strong><br />
                            Es un campo reservado del sistema para juegos sin sede definida. No debe eliminarse para que el sistema funcione correctamente.</p>
                            <p><strong>¿Por qué no puedo eliminar un campo?</strong><br />
                            Ese campo tiene partidos asignados. Para eliminarlo, primero deben reasignarse o eliminarse los juegos que lo usan.</p>
                            <p><strong>¿Puedo registrar varios campos con la misma ubicación?</strong><br />
                            Sí. El sistema permite campos distintos en la misma ubicación, siempre que tengan nombres diferentes.</p>
                        </div>

                    </div>

                    <div class="ayuda-modal-footer">
                        <button class="btn ayuda-btn-cerrar" @onclick="() => showHelp = false">Cerrar guía</button>
                    </div>

                </div>
            </div>
        }

    </Authorized>
</AuthorizeView>

<style>
    .catalogo-page {
        padding: 0.25rem 0;
    }

    .catalogo-header-card {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        background: linear-gradient(135deg, #eff6ff 0%, #eef2ff 45%, #f8fafc 100%);
        border: 1px solid #dbeafe;
        border-radius: 16px;
        padding: 1.1rem 1.25rem;
        margin-bottom: 1rem;
        box-shadow: 0 14px 28px rgba(30, 64, 175, 0.08);
    }

    .catalogo-kicker {
        margin: 0;
        color: #2563eb;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .catalogo-header-card h3 {
        margin: 0.15rem 0 0.25rem;
        color: #1e3a8a;
        font-weight: 800;
    }

    .catalogo-header-card span {
        color: #475569;
        font-size: 0.93rem;
    }

    .catalogo-header-right {
        display: flex;
        align-items: center;
        gap: 0.6rem;
    }

    .catalogo-badge span {
        display: inline-block;
        background: linear-gradient(90deg, #2563eb 0%, #1d4ed8 100%);
        color: #fff;
        border-radius: 999px;
        padding: 0.3rem 0.8rem;
        font-size: 0.78rem;
        font-weight: 700;
        box-shadow: 0 8px 18px rgba(37, 99, 235, 0.24);
    }

    .catalogo-help-btn {
        width: 34px;
        height: 34px;
        border-radius: 50%;
        border: 2px solid #2563eb;
        background: #fff;
        color: #2563eb;
        font-weight: 800;
        font-size: 1rem;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        box-shadow: 0 4px 12px rgba(37, 99, 235, 0.18);
        transition: background 0.2s, color 0.2s, transform 0.15s;
        line-height: 1;
        padding: 0;
    }

    .catalogo-help-btn:hover {
        background: #2563eb;
        color: #fff;
        transform: scale(1.1);
    }

    .catalogo-list-card {
        background-color: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 0.75rem;
        box-shadow: 0 16px 32px rgba(15, 23, 42, 0.08);
    }

    .catalogo-loading {
        margin: 1.5rem 0;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1e3a8a;
        font-weight: 600;
    }

    @@media (max-width: 768px) {
        .catalogo-header-card {
            flex-direction: column;
            align-items: flex-start;
        }

        .catalogo-header-right {
            align-self: flex-end;
        }

        .ayuda-modal {
            max-height: 92vh;
        }
    }

    /* ── MODAL DE AYUDA ── */
    .ayuda-overlay {
        position: fixed;
        inset: 0;
        background: rgba(15, 23, 42, 0.45);
        backdrop-filter: blur(3px);
        z-index: 1050;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 1rem;
    }

    .ayuda-modal {
        background: #fff;
        border-radius: 20px;
        width: 100%;
        max-width: 680px;
        max-height: 88vh;
        display: flex;
        flex-direction: column;
        box-shadow: 0 24px 60px rgba(30, 64, 175, 0.18);
        overflow: hidden;
    }

    .ayuda-modal-header {
        display: flex;
        justify-content: space-between;
        align-items: center;
        padding: 1.1rem 1.4rem 0.9rem;
        background: linear-gradient(135deg, #eff6ff 0%, #eef2ff 100%);
        border-bottom: 1px solid #dbeafe;
    }

    .ayuda-kicker {
        display: block;
        color: #2563eb;
        font-size: 0.75rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .08em;
        margin-bottom: 0.15rem;
    }

    .ayuda-modal-header h4 {
        margin: 0;
        color: #1e3a8a;
        font-weight: 800;
        font-size: 1.15rem;
    }

    .ayuda-close-btn {
        background: none;
        border: none;
        font-size: 1.1rem;
        color: #64748b;
        cursor: pointer;
        border-radius: 50%;
        width: 32px;
        height: 32px;
        display: flex;
        align-items: center;
        justify-content: center;
        transition: background 0.2s, color 0.2s;
    }

    .ayuda-close-btn:hover {
        background: #fee2e2;
        color: #dc2626;
    }

    .ayuda-modal-body {
        overflow-y: auto;
        padding: 1.2rem 1.4rem;
        flex: 1;
    }

    .ayuda-section {
        margin-bottom: 1.4rem;
        padding-bottom: 1.2rem;
        border-bottom: 1px solid #f1f5f9;
    }

    .ayuda-section:last-child {
        border-bottom: none;
        margin-bottom: 0;
    }

    .ayuda-section h5 {
        color: #1e3a8a;
        font-weight: 700;
        font-size: 0.97rem;
        margin-bottom: 0.5rem;
    }

    .ayuda-section p {
        color: #475569;
        font-size: 0.9rem;
        margin-bottom: 0.5rem;
        line-height: 1.6;
    }

    .ayuda-table {
        width: 100%;
        border-collapse: collapse;
        font-size: 0.85rem;
        margin: 0.5rem 0;
    }

    .ayuda-table th {
        background: linear-gradient(90deg, #eff6ff, #eef2ff);
        color: #1e3a8a;
        font-weight: 700;
        padding: 0.45rem 0.7rem;
        text-align: left;
        border-bottom: 2px solid #dbeafe;
    }

    .ayuda-table td {
        padding: 0.4rem 0.7rem;
        color: #475569;
        border-bottom: 1px solid #f1f5f9;
        vertical-align: top;
    }

    .ayuda-table tr:last-child td {
        border-bottom: none;
    }

    .ayuda-tip {
        background: #eff6ff;
        border-left: 3px solid #2563eb;
        border-radius: 0 8px 8px 0;
        padding: 0.55rem 0.8rem;
        font-size: 0.85rem;
        color: #1e40af;
        margin-top: 0.6rem;
    }

    .ayuda-tip-warning {
        background: #fffbeb;
        border-left-color: #f59e0b;
        color: #92400e;
    }

    .ayuda-section-faq p {
        margin-bottom: 0.75rem;
    }

    .ayuda-modal-footer {
        padding: 0.85rem 1.4rem;
        border-top: 1px solid #e2e8f0;
        display: flex;
        justify-content: flex-end;
        background: #f8fafc;
    }

    .ayuda-btn-cerrar {
        background: linear-gradient(90deg, #2563eb 0%, #1d4ed8 100%);
        color: #fff;
        border: none;
        border-radius: 999px;
        padding: 0.4rem 1.3rem;
        font-size: 0.88rem;
        font-weight: 700;
        cursor: pointer;
        box-shadow: 0 4px 14px rgba(37, 99, 235, 0.25);
        transition: opacity 0.2s;
    }

    .ayuda-btn-cerrar:hover {
        opacity: 0.88;
    }
</style>

@code {
    public string idtorneoseleccionado;

    public string torneoMensaje { get; set; }

    public CampoCLS[] listadoCampo;

    public CampoCLS oCampoCLSBorrar = new CampoCLS();         // ESTE LO PONGO PARA SACAR EL NOMBRE DEL CAMPO Y MANDARLO COMO PARAMETRO AL BORRAR

    [CascadingParameter]
    private Task<AuthenticationState> auth { get; set; }

    [Parameter]
    public string Id { get; set; }

    public bool permitirAgregar = false;
    public bool permitirEditar = false;
    public bool permitirEliminar = false;
    public bool permitirExportarExcel = false;
    public bool permitirExportarWord = false;
    public bool permitirExportarPDF = false;

    public bool showHelp = false;

    List<int> listaBotones = new List<int>();


    protected override async Task OnInitializedAsync()
    {
        var authuser = await auth;
        var user = authuser.User;

        if (user.Identity.IsAuthenticated)
        {
            var claims = user.Claims.ToList();
            var torneo = claims[1].Value;

            // AQUI ESTOY RECIENDO EN CADENA EL ID DE TORNEO SELECCIONADO
            idtorneoseleccionado = claims[2].Value;

            torneoMensaje = torneo;

            listadoCampo = await http.GetFromJsonAsync<CampoCLS[]>("api/Campo/ListarCampo/" + idtorneoseleccionado);

            if (user.Identity.IsAuthenticated)
            {
                listaBotones = await http.GetFromJsonAsync<List<int>>("api/PaginaTipoUsuario/listarBotones/" + user.Identity.Name + "/" + Id);

                if (listaBotones.Count() > 0)
                {
                    if (listaBotones.Contains(1)) permitirAgregar = true;
                    if (listaBotones.Contains(2)) permitirEditar = true;
                    if (listaBotones.Contains(3)) permitirEliminar = true;
                    if (listaBotones.Contains(4)) permitirExportarExcel = true;
                    if (listaBotones.Contains(5)) permitirExportarWord = true;
                    if (listaBotones.Contains(6)) permitirExportarPDF = true;
                }
            }
        }
    }


    public async Task BuscarListaCampo(string buscarNombreCampo)
    {
        if (buscarNombreCampo == null || buscarNombreCampo == "")
        {
            listadoCampo = await http.GetFromJsonAsync<CampoCLS[]>("api/Campo/ListarCampo/" + idtorneoseleccionado);
        }
        else
        {
            listadoCampo = await http.GetFromJsonAsync<CampoCLS[]>("api/Campo/FiltrarCampo/" + buscarNombreCampo + "/" + idtorneoseleccionado);
        }
    }


    public async Task EliminarListaCampo(string idCampo)       // LO PONEMOS COMO STRING PORQUE EN EL LISTADOS ESTA COMO STRING
    {
        oCampoCLSBorrar = await http.GetFromJsonAsync<CampoCLS>("api/Campo/RecuperarInformacionCampo/" + idCampo);

        if (await ijsruntime.InvokeAsync<bool>("ConfirmarBorrar", "Confirmar", "VAS A BORRAR A: " + oCampoCLSBorrar.nombre, "warning"))
        {
            int rpta = await http.GetFromJsonAsync<int>("api/Campo/EliminarCampo/" + idCampo);

            // 0 = OCURRIO UN ERROR     1 = SE BORRO CORRECTAMENTE     2 = HAY JUEGOS CON ESE CAMPO     3 = ES UN CAMPO CON NOMBRE PENDIENTE(NO SE PUEDE BORAR)
            switch (rpta)
            {
                case 0:
                    await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "OCURRIO UN ERROR, NO SE PUDO BORRAR", "error");
                    break;
                case 1:
                    await ijsruntime.InvokeVoidAsync("MostrarMensajetime", "OK, EL CAMPO SE ELIMINO", "success", 2000);
                    listadoCampo = await http.GetFromJsonAsync<CampoCLS[]>("api/Campo/ListarCampo/" + idtorneoseleccionado);
                    break;
                case 2:
                    await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "NO SE PUEDE BORRAR, HAY JUEGOS EN ESE CAMPO", "warning");
                    break;
                case 3:
                    await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "EL CAMPO CON NOMBRE PENDIENTE NO SE DEBE BORRAR", "warning");
                    break;
                default:
                    break;
            }
        }
    }

}

