 @page "/ListaPagina/{Id}"
@using FUTBOLERO.Shared
@inject HttpClient http
@inject IJSRuntime ijsruntime

@{
    string[] cabeceras = { "Orden", "Mensaje", "Acción", "Visible?" };
    string[] propiedades = { "ordenmenu", "mensaje", "accion", "nombrevisible" };
}

<AuthorizeView>
    <Authorized>
        <section class="catalogo-page mt-3">
            <div class="catalogo-header-card">
                <div>
                    <p class="catalogo-kicker">Panel de administración</p>
                    <h3>Páginas del Sistema</h3>
                    <span>Administra páginas, rutas y visibilidad del menú.</span>
                </div>
                <div class="catalogo-badge">
                    <span>Catálogo</span>
                </div>
            </div>

            @if (listadoPagina == null)
            {
                <div class="catalogo-loading">
                    <div class="spinner-border text-primary" role="status"></div>
                    <span class="ml-2">Cargando páginas...</span>
                </div>
            }
            else
            {
                <div class="catalogo-list-card">
                    <Listados cabeceras=cabeceras
                              nombrePropiedadesMostrar=propiedades
                              lista=listadoPagina
                              type="text" button=false label="Nombre Página"
                              permitirAgregar=@permitirAgregar rutaAgregar="agregarPagina"
                              permitirEditar=@permitirEditar rutaEditar="editarPagina"
                              permitirEliminar=@permitirEliminar eventEliminar="eliminarListaPagina"
                              eventBusqueda="buscarListaPagina"
                              permitirExportarExcel=@permitirExportarExcel
                              permitirExportarWord=@permitirExportarWord
                              permitirExportarPdf=@permitirExportarPDF
                              tituloReporte="Listado de Personas" />
                </div>
            }
        </section>
    </Authorized>
</AuthorizeView>

<style>
    .catalogo-page {
        padding: 0.25rem 0;
    }

    .catalogo-header-card {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        background: linear-gradient(135deg, #eff6ff 0%, #eef2ff 45%, #f8fafc 100%);
        border: 1px solid #dbeafe;
        border-radius: 16px;
        padding: 1.1rem 1.25rem;
        margin-bottom: 1rem;
        box-shadow: 0 14px 28px rgba(30, 64, 175, 0.08);
    }

    .catalogo-kicker {
        margin: 0;
        color: #2563eb;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .catalogo-header-card h3 {
        margin: 0.15rem 0 0.25rem;
        color: #1e3a8a;
        font-weight: 800;
    }

    .catalogo-header-card span {
        color: #475569;
        font-size: 0.93rem;
    }

    .catalogo-badge span {
        display: inline-block;
        background: linear-gradient(90deg, #2563eb 0%, #1d4ed8 100%);
        color: #fff;
        border-radius: 999px;
        padding: 0.3rem 0.8rem;
        font-size: 0.78rem;
        font-weight: 700;
        box-shadow: 0 8px 18px rgba(37, 99, 235, 0.24);
    }

    .catalogo-list-card {
        background-color: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 0.75rem;
        box-shadow: 0 16px 32px rgba(15, 23, 42, 0.08);
    }

    .catalogo-loading {
        margin: 1.5rem 0;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1e3a8a;
        font-weight: 600;
    }

    @@media (max-width: 768px) {
        .catalogo-header-card {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

@code {
    [Parameter]
    public string Id { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState> auth { get; set; }

    public bool permitirAgregar = false;
    public bool permitirEditar = false;
    public bool permitirEliminar = false;
    public bool permitirExportarExcel = false;
    public bool permitirExportarWord = false;
    public bool permitirExportarPDF = false;

    public PaginaCLS oPaginaCLSBorrar = new PaginaCLS();         // ESTE LO PONGO PARA SACAR EL NOMBRE DE LA PAGINA Y MANDARLO COMO PARAMETRO AL BORRAR

    List<int> listaBotones = new List<int>();

    public PaginaCLS[] listadoPagina;

    protected override async Task OnInitializedAsync()
    {
        listadoPagina = await http.GetFromJsonAsync<PaginaCLS[]>("api/pagina/listarPagina");

        var authuser = await auth;
        var user = authuser.User;

        if (user.Identity.IsAuthenticated)
        {
            listaBotones = await http.GetFromJsonAsync<List<int>>("api/PaginaTipoUsuario/listarBotones/" + user.Identity.Name + "/" + Id);

            if (listaBotones.Count() > 0)
            {
                if (listaBotones.Contains(1)) permitirAgregar = true;
                if (listaBotones.Contains(2)) permitirEditar = true;
                if (listaBotones.Contains(3)) permitirEliminar = true;
                if (listaBotones.Contains(4)) permitirExportarExcel = true;
                if (listaBotones.Contains(5)) permitirExportarWord = true;
                if (listaBotones.Contains(6)) permitirExportarPDF = true;
            }
        }
    }


    public async Task eliminarListaPagina(string idPagina)
    {
        oPaginaCLSBorrar = await http.GetFromJsonAsync<PaginaCLS>("api/Pagina/RecuperarInformacionPagina/" + idPagina);

        if (await ijsruntime.InvokeAsync<bool>("ConfirmarBorrar", "Confirmar", "Vas a borrar a: " + oPaginaCLSBorrar.mensaje, "warning"))
        {
            int rpta = await http.GetFromJsonAsync<int>("api/pagina/eliminarPagina/" + idPagina);

            // 0 = OCURRIO UN ERROR     1 = SE BORRO ON
            switch (rpta)
            {
                case 0:
                    await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "Ocurrio un error, no se pudo borrar", "error");
                    break;
                case 1:
                    await ijsruntime.InvokeVoidAsync("MostrarMensajetime", "Ok, la página se elimino", "success", 2000);
                    listadoPagina = await http.GetFromJsonAsync<PaginaCLS[]>("api/pagina/listarPagina");
                    break;
                default:
                    break;
            }
        }
    }


    public async Task buscarListaPagina(string mensaje)
    {
        listadoPagina = await http.GetFromJsonAsync<PaginaCLS[]>("api/pagina/filtrarPagina/" + mensaje);
    }
}
