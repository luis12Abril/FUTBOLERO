@page "/ListaCumpleañeros/{Id}"
@using FUTBOLERO.Shared
@inject HttpClient http
@inject IJSRuntime ijsruntime

@{
    string[] cabeceras = { "JUGADOR", "EQUIPO", "F. NACIMIENTO", "SU CUMPLEAÑOS", "CUMPLE" };
    string[] propiedades = { "nombrejugador", "nombreequipo", "fnacimientocadena", "fcumpleañoscadenacorta", "años" };
}

<AuthorizeView>
    <Authorized>
        <section class="catalogo-page mt-3">
            <div class="catalogo-header-card">
                <div>
                    <p class="catalogo-kicker">Panel de administración</p>
                    <h3>Próximos Cumpleañeros</h3>
                    <span>Consulta los próximos cumpleaños de los jugadores registrados.</span>
                </div>
                <div class="catalogo-header-right">
                    <div class="catalogo-badge">
                        <span>Catálogo</span>
                    </div>
                    <button class="catalogo-help-btn" @onclick="() => showHelp = true" title="Ayuda">
                        <span>?</span>
                    </button>
                </div>
            </div>

            @if (listadoCumpleañeros == null)
            {
                <div class="catalogo-loading">
                    <div class="spinner-border text-primary" role="status"></div>
                    <span class="ml-2">Cargando cumpleañeros...</span>
                </div>
            }
            else
            {
                <div class="catalogo-list-card">
                    <Listados cabeceras=cabeceras
                              nombrePropiedadesMostrar=propiedades
                              lista=listadoCumpleañeros
                              type="combobox" button=false label="Seleccione un equipo"
                              combobox="oEquipoCLS" displayMember="nombre" valueMember="idequipo"
                              eventBusqueda="BuscarListaJugadorCumpleañero"
                              permitirExportarExcel=@permitirExportarExcel
                              permitirExportarWord=@permitirExportarWord
                              permitirExportarPdf=@permitirExportarPDF
                              tituloReporte="Listado de cumpleañeros" />
                </div>
            }
        </section>

        @* ── MODAL DE AYUDA ── *@
        @if (showHelp)
        {
            <div class="ayuda-overlay" @onclick="() => showHelp = false">
                <div class="ayuda-modal" @onclick:stopPropagation="true">

                    <div class="ayuda-modal-header">
                        <div>
                            <span class="ayuda-kicker">Guía de uso</span>
                            <h4>🎂 Próximos Cumpleañeros</h4>
                        </div>
                        <button class="ayuda-close-btn" @onclick="() => showHelp = false">✕</button>
                    </div>

                    <div class="ayuda-modal-body">

                        <div class="ayuda-section">
                            <h5>🎉 ¿Qué es esta pantalla?</h5>
                            <p>
                                La pantalla <strong>Próximos Cumpleañeros</strong> muestra los jugadores
                                del torneo cuyo cumpleaños se aproxima, ordenados por fecha. Es una
                                herramienta de <strong>seguimiento y atención personalizada</strong>
                                hacia los participantes del torneo.
                            </p>
                            <div class="ayuda-tip">
                                🎈 Esta pantalla es de <strong>solo consulta</strong>. Los datos se
                                calculan automáticamente a partir de las fechas de nacimiento capturadas
                                en el módulo de <em>Jugadores</em>.
                            </div>
                        </div>

                        <div class="ayuda-section">
                            <h5>🌟 ¿Por qué es importante esta información?</h5>
                            <p>
                                Conocer los próximos cumpleaños de los jugadores va más allá de un
                                simple dato — es una oportunidad para <strong>fortalecer el vínculo
                                entre la liga y sus participantes</strong>:
                            </p>
                            <table class="ayuda-table">
                                <thead>
                                    <tr><th>Acción</th><th>Impacto</th></tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>🎊 Felicitar al jugador el día de su cumpleaños</td>
                                        <td>Genera sentido de pertenencia y lealtad hacia el torneo.</td>
                                    </tr>
                                    <tr>
                                        <td>📱 Compartir en redes sociales del torneo</td>
                                        <td>Aumenta la visibilidad e interacción en las redes de la liga.</td>
                                    </tr>
                                    <tr>
                                        <td>🏅 Reconocimiento especial en la jornada</td>
                                        <td>El jugador se siente valorado y el equipo lo celebra en cancha.</td>
                                    </tr>
                                    <tr>
                                        <td>📊 Verificar edad para categoría</td>
                                        <td>Detectar si un jugador cumple años antes del inicio del torneo y cambia de categoría.</td>
                                    </tr>
                                </tbody>
                            </table>
                            <div class="ayuda-tip ayuda-tip-success">
                                💡 <strong>Consejo:</strong> Revisa esta pantalla antes de cada jornada
                                y aprovecha para mencionar los cumpleañeros de la semana durante
                                los partidos o en los grupos de WhatsApp de los equipos.
                            </div>
                        </div>

                        <div class="ayuda-section">
                            <h5>📋 Columnas del listado</h5>
                            <table class="ayuda-table">
                                <thead>
                                    <tr><th>Columna</th><th>Descripción</th></tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td><strong>JUGADOR</strong></td>
                                        <td>Nombre completo del jugador que está próximo a cumplir años.</td>
                                    </tr>
                                    <tr>
                                        <td><strong>EQUIPO</strong></td>
                                        <td>Equipo al que pertenece el jugador dentro del torneo.</td>
                                    </tr>
                                    <tr>
                                        <td><strong>F. NACIMIENTO</strong></td>
                                        <td>Fecha de nacimiento registrada en el sistema.</td>
                                    </tr>
                                    <tr>
                                        <td><strong>SU CUMPLEAÑOS</strong></td>
                                        <td>Fecha en que el jugador cumplirá años este ciclo (día y mes).</td>
                                    </tr>
                                    <tr>
                                        <td><strong>CUMPLE</strong></td>
                                        <td>Edad que cumplirá el jugador en su próximo cumpleaños.</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <div class="ayuda-section">
                            <h5>🔍 Filtrar por equipo</h5>
                            <p>
                                Usa el <strong>selector de equipo</strong> para ver únicamente los
                                jugadores de un plantel específico que estén próximos a cumplir años.
                                Ideal para que el capitán del equipo pueda identificar rápidamente
                                a sus jugadores cumpleañeros.
                            </p>
                            <p>
                                Selecciona la opción vacía del selector para regresar al listado
                                completo de todos los equipos del torneo.
                            </p>
                        </div>

                        <div class="ayuda-section">
                            <h5>📤 Exportar el listado</h5>
                            <p>
                                Si tienes permiso, puedes exportar la lista de próximos cumpleañeros
                                en <strong>Excel</strong>, <strong>Word</strong> y <strong>PDF</strong>.
                                Úsalo para compartirlo con los coordinadores de cada equipo o
                                publicarlo en los canales oficiales de la liga.
                            </p>
                        </div>

                        <div class="ayuda-section ayuda-section-faq">
                            <h5>❓ Preguntas frecuentes</h5>
                            <p><strong>¿Por qué no aparece ningún jugador?</strong><br />
                            Puede deberse a que los jugadores no tienen fecha de nacimiento capturada,
                            o a que no hay cumpleaños próximos en el período que muestra el sistema.
                            Verifica que las fechas estén registradas en el módulo de <em>Jugadores</em>.</p>
                            <p><strong>¿Cuántos días de anticipación muestra el sistema?</strong><br />
                            El sistema muestra los jugadores cuyos cumpleaños están próximos según
                            la configuración del torneo. Consulta con el administrador si necesitas
                            ampliar o reducir el rango de días.</p>
                            <p><strong>¿Puedo ver cumpleañeros de otros torneos?</strong><br />
                            No. El listado corresponde únicamente al torneo activo seleccionado
                            al iniciar sesión. Para cambiar de torneo regresa a la pantalla de selección.</p>
                            <p><strong>¿Qué pasa si un jugador no tiene fecha de nacimiento?</strong><br />
                            No aparecerá en este listado. Para corregirlo, edita el jugador desde
                            el módulo <em>Jugadores</em> y agrega su fecha de nacimiento.</p>
                        </div>

                    </div>

                    <div class="ayuda-modal-footer">
                        <button class="btn ayuda-btn-cerrar" @onclick="() => showHelp = false">Cerrar guía</button>
                    </div>

                </div>
            </div>
        }

    </Authorized>
</AuthorizeView>

<style>
