</style>

@code {

    // --- Modelos internos ---
    public class Jornada
    {
        public int Numero { get; set; }
        public List<Partido> Partidos { get; set; } = new List<Partido>();
        public string EquipoDescansa { get; set; } = "";
    }

    public class Partido
    {
        public string Local { get; set; }
        public string Visitante { get; set; }
    }

    // --- Variables ---
    private List<EquipoCLS> listaEquipos = new List<EquipoCLS>();
    private List<Jornada> jornadas = new List<Jornada>();
    private bool cargando = true;
    private string torneoNombre = "";
    private int totalPartidos = 0;
    private bool showHelp = false;

    [CascadingParameter]
    private Task<AuthenticationState> auth { get; set; }

    // --- Inicializar ---
    protected override async Task OnInitializedAsync()
    {
        var authuser = await auth;
        var user = authuser.User;

        if (user.Identity.IsAuthenticated)
        {
            var claims = user.Claims.ToList();
            torneoNombre = claims[1].Value;
            var idtorneo = claims[2].Value;

            listaEquipos = await http.GetFromJsonAsync<List<EquipoCLS>>(
                "api/Equipo/ListarEquiposParticipantes/" + idtorneo);

            if (listaEquipos != null && listaEquipos.Count >= 2)
                GenerarProgramacion();
        }

        cargando = false;
    }

    // --- Algoritmo Round-Robin ---
    private void GenerarProgramacion()
    {
        var lista = listaEquipos.Select(e => e.nombre).ToList();

        // Si numero impar agrega equipo fantasma (DESCANSA)
        if (lista.Count % 2 != 0)
            lista.Add("DESCANSA");

        int n = lista.Count;
        jornadas = new List<Jornada>();

        for (int ronda = 0; ronda < n - 1; ronda++)
        {
            var jornada = new Jornada { Numero = ronda + 1 };

            for (int i = 0; i < n / 2; i++)
            {
                string local = lista[i];
                string visitante = lista[n - 1 - i];

                if (local == "DESCANSA")
                    jornada.EquipoDescansa = visitante;
                else if (visitante == "DESCANSA")
                    jornada.EquipoDescansa = local;
                else
                    jornada.Partidos.Add(new Partido { Local = local, Visitante = visitante });
            }

            jornadas.Add(jornada);

            // Rotar lista manteniendo fijo el primer elemento
            var ultimo = lista[n - 1];
            lista.RemoveAt(n - 1);
            lista.Insert(1, ultimo);
        }

        totalPartidos = jornadas.Sum(j => j.Partidos.Count);
    }

    // --- Exportar Word ---
    private async Task ExportarWord()
    {
        var sb = new System.Text.StringBuilder();

        sb.AppendLine("<html xmlns:o='urn:schemas-microsoft-com:office:office' xmlns:w='urn:schemas-microsoft-com:office:word'>");
        sb.AppendLine("<head><meta charset='utf-8'><title>Programacion del Torneo</title>");
        sb.AppendLine("<style>");
        sb.AppendLine("body { font-family: Calibri, Arial, sans-serif; font-size: 11pt; }");
        sb.AppendLine("h1 { color: #2f6a5e; font-size: 16pt; }");
        sb.AppendLine("h3 { background-color: #42a890; color: white; padding: 4px 8px; font-size: 11pt; }");
        sb.AppendLine("table { width: 100%; border-collapse: collapse; margin-bottom: 12pt; }");
        sb.AppendLine("td { padding: 4px 10px; border-bottom: 1px solid #ccc; font-size: 10pt; }");
        sb.AppendLine(".local { text-align: right; font-weight: bold; width: 45%; }");
        sb.AppendLine(".vs { text-align: center; color: #42a890; font-weight: bold; width: 10%; }");
        sb.AppendLine(".visit { text-align: left; font-weight: bold; width: 45%; }");
        sb.AppendLine(".descansa { background-color: #fff8e1; border: 1px dashed #c8a200; padding: 3px 10px; font-size: 9pt; color: #7a5800; font-weight: bold; margin-top: 4pt; display: inline-block; }");
        sb.AppendLine("</style></head><body>");

        sb.AppendLine($"<h1>&#9917; Programaci&oacute;n del Torneo: {torneoNombre}</h1>");
        sb.AppendLine($"<p>{listaEquipos.Count} equipos &nbsp;&middot;&nbsp; {jornadas.Count} jornadas &nbsp;&middot;&nbsp; {totalPartidos} partidos en total</p>");
        sb.AppendLine("<hr/>");

        foreach (var jornada in jornadas)
        {
            sb.AppendLine($"<h3>JORNADA {jornada.Numero}</h3>");
            sb.AppendLine("<table>");
            foreach (var partido in jornada.Partidos)
            {
                sb.AppendLine($"<tr><td class='local'>{partido.Local}</td><td class='vs'>VS</td><td class='visit'>{partido.Visitante}</td></tr>");
            }
            sb.AppendLine("</table>");
            if (!string.IsNullOrEmpty(jornada.EquipoDescansa))
                sb.AppendLine($"<p class='descansa'>&#128564; DESCANSA: {jornada.EquipoDescansa}</p>");
        }

        sb.AppendLine("<p><em>Nota: Esta es solo una propuesta. El administrador registrar&aacute; los juegos semana a semana seg&uacute;n las fechas reales.</em></p>");
        sb.AppendLine("</body></html>");

        var htmlBytes = System.Text.Encoding.UTF8.GetBytes(sb.ToString());
        var base64 = Convert.ToBase64String(htmlBytes);

        await ijsruntime.InvokeVoidAsync("descargarArchivo",
            base64,
            $"Programacion_{torneoNombre.Replace(" ", "_")}.doc",
            "application/msword");
    }
}
