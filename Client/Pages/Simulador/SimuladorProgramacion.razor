@page "/SimuladorProgramacion"
@using FUTBOLERO.Shared
@inject HttpClient http
@inject IJSRuntime ijsruntime

<AuthorizeView>
    <Authorized>

        @if (cargando)
        {
            <div class="sim-wrapper">
                <div class="sim-card text-center py-5">
                    <button class="btn btn-cargando" disabled>
                        <span class="spinner-border spinner-border-sm me-2"></span>
                        Cargando equipos...
                    </button>
                </div>
            </div>
        }
        else
        {
            <div class="sim-wrapper">
                <div class="sim-card">

                    <!-- HEADER -->
                    <div class="sim-header">
                        <div>
                            <h4 class="mb-1">⚽ Simulador de Programación</h4>
                            <p class="mb-0">Propuesta generada con los equipos del torneo: <strong>@torneoNombre</strong></p>
                        </div>
                        <div class="sim-header-right">
                            @if (jornadas.Count > 0)
                            {
                                <span class="sim-badge">@listaEquipos.Count equipos &nbsp;·&nbsp; @jornadas.Count jornadas &nbsp;·&nbsp; @totalPartidos partidos</span>
                            }
                            <button class="sim-help-btn" @onclick="() => showHelp = true" title="Ayuda">
                                <span>?</span>
                            </button>
                        </div>
                    </div>

                    <!-- BODY -->
                    <div class="sim-body">

                        @if (listaEquipos.Count < 2)
                        {
                            <div class="alert alert-warning rounded-3">
                                ⚠️ Se necesitan al menos <strong>2 equipos</strong> registrados en el torneo para generar la simulación.
                            </div>
                        }
                        else
                        {
                            <!-- JORNADAS -->
                            <div class="jornadas-grid">
                                @foreach (var jornada in jornadas)
                                {
                                    <div class="jornada-card">
                                        <div class="jornada-titulo">
                                            🗓️ JORNADA @jornada.Numero
                                        </div>
                                        <div class="jornada-partidos">
                                            @foreach (var partido in jornada.Partidos)
                                            {
                                                <div class="partido-fila">
                                                    <span class="equipo-local">@partido.Local</span>
                                                    <span class="vs-badge">VS</span>
                                                    <span class="equipo-visitante">@partido.Visitante</span>
                                                </div>
                                            }
                                            @if (!string.IsNullOrEmpty(jornada.EquipoDescansa))
                                            {
                                                <div class="descansa-fila">
                                                    😴 DESCANSA: <strong>@jornada.EquipoDescansa</strong>
                                                </div>
                                            }
                                        </div>
                                    </div>
                                }
                            </div>

                            <!-- NOTA Y BOTON -->
                            <div class="sim-footer">
                                <p class="sim-nota">
                                    📌 <strong>Nota:</strong> Esta es solo una <em>propuesta de programación</em>.
                                    El administrador puede usarla como referencia y registrar los juegos semana a semana según las fechas reales del torneo.
                                </p>
                                <div class="sim-actions">
                                    <button class="btn btn-exportar" @onclick="ExportarWord">
                                        📄 Descargar como Word
                                    </button>
                                </div>
                            </div>
                        }

                    </div>
                </div>
            </div>
        }

            @* ── MODAL DE AYUDA ── *@
            @if (showHelp)
            {
                <div class="ayuda-overlay" @onclick="() => showHelp = false">
                    <div class="ayuda-modal" @onclick:stopPropagation="true">

                        <div class="ayuda-modal-header">
                            <div>
                                <span class="ayuda-kicker">Guía de uso</span>
                                <h4>Simulador de Programación</h4>
                            </div>
                            <button class="ayuda-close-btn" @onclick="() => showHelp = false">✕</button>
                        </div>

                        <div class="ayuda-modal-body">

                            <div class="ayuda-section">
                                <h5>📋 ¿Qué es esta pantalla?</h5>
                                <p>
                                    El <strong>Simulador de Programación</strong> genera automáticamente una propuesta de
                                    calendario de partidos para el torneo activo, usando el algoritmo <strong>Round-Robin</strong>
                                    (todos contra todos). Es solo una simulación de referencia para apoyar al administrador
                                    a la hora de planificar y registrar los juegos semana a semana según las fechas reales del torneo.
                                </p>
                                <div class="ayuda-tip">
                                    ℹ️ <strong>Importante:</strong> Esta programación <em>no se guarda</em> en el sistema ni crea
                                    juegos automáticamente. Es solo una propuesta visual de apoyo.
                                </div>
                            </div>

                            <div class="ayuda-section">
                                <h5>⚽ ¿Cómo funciona el algoritmo?</h5>
                                <p>
                                    El sistema toma todos los equipos del torneo y genera jornadas donde cada equipo juega
                                    exactamente una vez por fecha, rotando los rivales hasta que todos se hayan enfrentado entre sí.
                                </p>
                                <table class="ayuda-table">
                                    <thead>
                                        <tr><th>Dato</th><th>Descripción</th></tr>
                                    </thead>
                                    <tbody>
                                        <tr><td>Equipos</td><td>Total de equipos participantes en el torneo.</td></tr>
                                        <tr><td>Jornadas</td><td>Número de fechas necesarias para que todos se enfrenten.</td></tr>
                                        <tr><td>Partidos</td><td>Total de encuentros en toda la programación.</td></tr>
                                    </tbody>
                                </table>
                            </div>

                            <div class="ayuda-section">
                                <h5>😴 ¿Qué significa “DESCANSA”?</h5>
                                <p>
                                    Cuando el número total de equipos es <strong>impar</strong>, en cada jornada un equipo
                                    diferente queda sin rival. Ese equipo aparece al final de la tarjeta con la etiqueta:
                                </p>
                                <div class="ayuda-tip ayuda-tip-warning">
                                    😴 <strong>DESCANSA: NOMBRE DEL EQUIPO</strong> — este equipo no juega en esa jornada.
                                    El equipo que descansa rota automáticamente en cada fecha para ser justo con todos.
                                </div>
                            </div>

                            <div class="ayuda-section">
                                <h5>📄 Exportar a Word</h5>
                                <p>
                                    El botón <strong>Descargar como Word</strong> genera un documento <em>.doc</em> con
                                    toda la programación: nombre del torneo, total de equipos, jornadas, partidos y
                                    — si aplica — el equipo que descansa en cada jornada.
                                    Útil para imprimir o compartir la propuesta con los participantes.
                                </p>
                            </div>

                            <div class="ayuda-section ayuda-section-faq">
                                <h5>❓ Preguntas frecuentes</h5>
                                <p><strong>¿Por qué no aparece ninguna jornada?</strong><br />
                                Se necesitan al menos <strong>2 equipos</strong> registrados en el torneo para generar la simulación.</p>
                                <p><strong>¿Puedo modificar la programación generada?</strong><br />
                                No desde aquí. Esta pantalla solo muestra la propuesta. Los juegos reales se registran en el módulo de <strong>Juegos</strong>.</p>
                                <p><strong>¿La programación cambia si agrego más equipos?</strong><br />
                                Sí. Al recargar la página se recalcula automáticamente con todos los equipos actuales del torneo.</p>
                            </div>

                        </div>

                        <div class="ayuda-modal-footer">
                            <button class="btn ayuda-btn-cerrar" @onclick="() => showHelp = false">Cerrar guía</button>
                        </div>

                    </div>
                </div>
            }

        </Authorized>
    </AuthorizeView>

    <style>
