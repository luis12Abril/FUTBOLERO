@page "/ListaGoleadores/{Id}"
@using FUTBOLERO.Shared
@inject HttpClient http
@inject IJSRuntime ijsruntime

@{
    string[] cabeceras = { "NOMBRE", "EQUIPO", "GOLES" };
    string[] propiedades = { "nombre", "equipo", "goles" };
}

<AuthorizeView>
    <Authorized>
        <section class="catalogo-page mt-3">
            <div class="catalogo-header-card">
                <div>
                    <p class="catalogo-kicker">Panel de administración</p>
                    <h3>Goleadores</h3>
                    <span>Consulta y filtra la tabla de goleadores del torneo.</span>
                </div>
                <div class="catalogo-header-right">
                    <div class="catalogo-badge">
                        <span>Catálogo</span>
                    </div>
                    <button class="catalogo-help-btn" @onclick="() => showHelp = true" title="Ayuda">
                        <span>?</span>
                    </button>
                </div>
            </div>

            @if (listadoGoleadores == null)
            {
                <div class="catalogo-loading">
                    <div class="spinner-border text-primary" role="status"></div>
                    <span class="ml-2">Cargando goleadores...</span>
                </div>
            }
            else
            {
                <div class="catalogo-list-card">
                    <Listados cabeceras=cabeceras
                              nombrePropiedadesMostrar=propiedades
                              lista=listadoGoleadores
                              type="combobox" button=false label="Seleccione un equipo"
                              combobox="oEquipoCLS" displayMember="nombre" valueMember="idequipo"
                              eventBusqueda="BuscarListaJugador"
                              permitirExportarExcel=@permitirExportarExcel
                              permitirExportarWord=@permitirExportarWord
                              permitirExportarPdf=@permitirExportarPDF
                              tituloReporte="Listado de Campos" />
                </div>
            }
        </section>

        @* ── MODAL DE AYUDA ── *@
        @if (showHelp)
        {
            <div class="ayuda-overlay" @onclick="() => showHelp = false">
                <div class="ayuda-modal" @onclick:stopPropagation="true">

                    <div class="ayuda-modal-header">
                        <div>
                            <span class="ayuda-kicker">Guía de uso</span>
                            <h4>⚽ Tabla de Goleadores</h4>
                        </div>
                        <button class="ayuda-close-btn" @onclick="() => showHelp = false">✕</button>
                    </div>

                    <div class="ayuda-modal-body">

                        <div class="ayuda-section">
                            <h5>⚽ ¿Qué es esta pantalla?</h5>
                            <p>
                                La <strong>Tabla de Goleadores</strong> muestra el ranking de jugadores
                                ordenados de mayor a menor según la cantidad de goles anotados en el
                                torneo activo. Es una de las estadísticas más consultadas por equipos,
                                jugadores y aficionados, ya que refleja el desempeño ofensivo individual
                                a lo largo de la competencia.
                            </p>
                            <div class="ayuda-tip">
                                📌 Esta pantalla es de <strong>solo consulta</strong>. Los goles se
                                registran automáticamente al capturar el resultado de cada juego en el
                                módulo <em>Juegos</em>.
                            </div>
                        </div>

                        <div class="ayuda-section">
                            <h5>✅ ¿Cuándo cuenta un gol para la tabla de goleadores?</h5>
                            <p>
                                <strong>No todos los goles de todos los partidos se suman a la tabla.</strong>
                                Para que los goles de un partido sean contabilizados, el administrador
                                debe activar la opción <strong>"Cuenta para los GOLES"</strong> al
                                registrar o editar ese juego en el módulo <em>Juegos</em>.
                            </p>
                            <table class="ayuda-table">
                                <thead>
                                    <tr><th>Opción en el juego</th><th>Efecto en la tabla de goleadores</th></tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>✅ <strong>"Cuenta para los GOLES"</strong> activada</td>
                                        <td>Los goles de ese partido <strong>sí suman</strong> al marcador individual de cada goleador.</td>
                                    </tr>
                                    <tr>
                                        <td>❌ <strong>"Cuenta para los GOLES"</strong> desactivada</td>
                                        <td>Los goles de ese partido <strong>no se toman en cuenta</strong> para la tabla de goleadores, aunque sí puedan contar para puntos.</td>
                                    </tr>
                                </tbody>
                            </table>
                            <div class="ayuda-tip ayuda-tip-warning">
                                ⚠️ Si un jugador anotó goles en un partido pero no aparece en el listado
                                o su conteo es menor al esperado, verifica que el juego tenga activada
                                la opción <em>"Cuenta para los GOLES"</em> en el módulo <em>Juegos</em>.
                            </div>
                        </div>

                        <div class="ayuda-section">
                            <h5>🏆 ¿Qué juegos se incluyen en el conteo?</h5>
                            <p>
                                El alcance de la tabla de goleadores depende de cómo el administrador
                                configure cada juego. Existen dos enfoques comunes según el torneo:
                            </p>
                            <table class="ayuda-table">
                                <thead>
                                    <tr><th>Modalidad</th><th>¿Qué juegos cuentan?</th></tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td>📅 <strong>Solo fase regular</strong></td>
                                        <td>Únicamente los juegos de la fase regular (jornadas normales). Los partidos de liguilla o finales <strong>no se activan</strong> con "Cuenta para los GOLES".</td>
                                    </tr>
                                    <tr>
                                        <td>🥇 <strong>Todos los juegos</strong></td>
                                        <td>Se activa la opción en todos los partidos, incluyendo semifinales, finales y liguilla. El goleador refleja el torneo completo.</td>
                                    </tr>
                                </tbody>
                            </table>
                            <div class="ayuda-tip">
                                💡 El administrador decide qué partidos cuentan para la tabla. Consulta
                                con él si tienes dudas sobre qué fase está incluida en el conteo actual.
                            </div>
                        </div>

                        <div class="ayuda-section">
                            <h5>📋 Columnas del listado</h5>
                            <table class="ayuda-table">
                                <thead>
                                    <tr><th>Columna</th><th>Descripción</th></tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td><strong>NOMBRE</strong></td>
                                        <td>Nombre completo del jugador goleador.</td>
                                    </tr>
                                    <tr>
                                        <td><strong>EQUIPO</strong></td>
                                        <td>Equipo al que pertenece el jugador en el torneo.</td>
                                    </tr>
                                    <tr>
                                        <td><strong>GOLES</strong></td>
                                        <td>Total de goles anotados en los partidos donde la opción <em>"Cuenta para los GOLES"</em> está activa.</td>
                                    </tr>
                                </tbody>
                            </table>
                        </div>

                        <div class="ayuda-section">
                            <h5>🔍 Filtrar por equipo</h5>
                            <p>
                                Usa el <strong>selector de equipo</strong> para ver únicamente los
                                goleadores de un plantel específico. Ideal para conocer el desempeño
                                ofensivo de un equipo en particular o para que el capitán consulte
                                a sus propios jugadores.
                            </p>
                            <p>
                                Selecciona la opción vacía del selector para regresar al listado
                                completo de todos los equipos.
                            </p>
                        </div>

                        <div class="ayuda-section">
                            <h5>📤 Exportar el listado</h5>
                            <p>
                                Si tienes permiso, puedes exportar la tabla de goleadores en
                                <strong>Excel</strong>, <strong>Word</strong> y <strong>PDF</strong>.
                                Útil para publicarla en redes sociales de la liga, grupos de WhatsApp
                                o imprimirla para colocarla en las instalaciones del torneo.
                            </p>
                        </div>

                        <div class="ayuda-section ayuda-section-faq">
                            <h5>❓ Preguntas frecuentes</h5>
                            <p><strong>¿Por qué no aparece ningún goleador?</strong><br />
                            Puede que ningún juego tenga activada la opción <em>"Cuenta para los GOLES"</em>,
                            o que aún no se hayan registrado goles individuales en los partidos del
                            módulo <em>Juegos</em>.</p>
                            <p><strong>¿Por qué un jugador tiene menos goles de los esperados?</strong><br />
                            Alguno de sus partidos puede tener desactivada la opción <em>"Cuenta para los GOLES"</em>.
                            Verifica cada juego en el módulo <em>Juegos</em>.</p>
                            <p><strong>¿Los goles de liguilla o finales cuentan?</strong><br />
                            Depende de la configuración del torneo. Si el administrador activó
                            <em>"Cuenta para los GOLES"</em> en esos partidos, sí cuentan.
                            De lo contrario, no se incluyen en el total.</p>
                            <p><strong>¿Puedo ver goleadores de torneos anteriores?</strong><br />
                            No. El listado corresponde únicamente al torneo activo. Para consultar
                            torneos anteriores debes seleccionarlos desde la pantalla de selección.</p>
                            <p><strong>¿Cuándo se actualiza la tabla?</strong><br />
                            Cada vez que entras a esta pantalla o cambias el filtro de equipo,
                            los datos se consultan en tiempo real desde la base de datos.</p>
                        </div>

                    </div>

                    <div class="ayuda-modal-footer">
                        <button class="btn ayuda-btn-cerrar" @onclick="() => showHelp = false">Cerrar guía</button>
                    </div>

                </div>
            </div>
        }

    </Authorized>
</AuthorizeView>

