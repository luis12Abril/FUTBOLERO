@page "/editarEstado/{idEstado}"
@using FUTBOLERO.Shared
@inject HttpClient http

<FormularioEstado oEstadoCLS="oEstadoCLS" />

@code {
    [Parameter]
    public string idEstado { get; set; }

    public EstadoCLS oEstadoCLS = new EstadoCLS();

    protected async override Task OnParametersSetAsync()
    {
        oEstadoCLS = await http.GetFromJsonAsync<EstadoCLS>("api/Estado/RecuperarInformacionEstado/" + idEstado);
    }
}


