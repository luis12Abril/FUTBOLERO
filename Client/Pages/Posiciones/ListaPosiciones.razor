@page "/ListaPosiciones/{Id}"
@using FUTBOLERO.Shared
@inject HttpClient http
@inject IJSRuntime ijsruntime

@{
    string[] cabeceras = { "EQUIPO", "JJ", "JG", "JE", "JEGP", "JP", "GF", "GC", "DG", "PE", "PTOS" };
    string[] propiedades = { "nombre", "jugados", "ganados", "empatados", "empatadosganados", "perdidos",
    "golesafavor", "golesencontra", "diferenciagoles", "puntosextras", "puntos"};
}

<AuthorizeView>
    <Authorized>
        <section class="catalogo-page mt-3">
            <div class="catalogo-header-card">
                <div>
                    <p class="catalogo-kicker">Panel de administración</p>
                    <h3>Tabla de Posiciones</h3>
                    <span>Consulta el rendimiento de los equipos del torneo seleccionado.</span>
                </div>
                <div class="catalogo-badge">
                    <span>Catálogo</span>
                </div>
            </div>

            @if (listadoPosiciones == null)
            {
                <div class="catalogo-loading">
                    <div class="spinner-border text-primary" role="status"></div>
                    <span class="ml-2">Cargando posiciones...</span>
                </div>
            }
            else
            {
                <div class="catalogo-list-card">
                    <div class="mb-2 d-flex" style="gap: 0.5rem;">
                        @if (permitirExportarExcel)
                        {
                            <button class="btn btn-success" @onclick="ExportarExcelPosiciones">Exportar a Excel</button>
                        }
                        @if (permitirExportarPDF)
                        {
                            <button class="btn btn-warning" @onclick="ExportarPdfPosiciones">Exportar a PDF</button>
                        }
                    </div>

                    <Listados cabeceras=cabeceras
                              nombrePropiedadesMostrar=propiedades
                              lista=listadoPosiciones
                              permitirExportarExcel=false
                              permitirExportarWord=@permitirExportarWord
                              permitirExportarPdf=false
                              tituloReporte="Tabla de Posiciones" />
                </div>
            }
        </section>
    </Authorized>
</AuthorizeView>

<style>
    .catalogo-page {
        padding: 0.25rem 0;
    }

    .catalogo-header-card {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        background: linear-gradient(135deg, #eff6ff 0%, #eef2ff 45%, #f8fafc 100%);
        border: 1px solid #dbeafe;
        border-radius: 16px;
        padding: 1.1rem 1.25rem;
        margin-bottom: 1rem;
        box-shadow: 0 14px 28px rgba(30, 64, 175, 0.08);
    }

    .catalogo-kicker {
        margin: 0;
        color: #2563eb;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .catalogo-header-card h3 {
        margin: 0.15rem 0 0.25rem;
        color: #1e3a8a;
        font-weight: 800;
    }

    .catalogo-header-card span {
        color: #475569;
        font-size: 0.93rem;
    }

    .catalogo-badge span {
        display: inline-block;
        background: linear-gradient(90deg, #2563eb 0%, #1d4ed8 100%);
        color: #fff;
        border-radius: 999px;
        padding: 0.3rem 0.8rem;
        font-size: 0.78rem;
        font-weight: 700;
        box-shadow: 0 8px 18px rgba(37, 99, 235, 0.24);
    }

    .catalogo-list-card {
        background-color: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 0.75rem;
        box-shadow: 0 16px 32px rgba(15, 23, 42, 0.08);
    }

    .catalogo-loading {
        margin: 1.5rem 0;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1e3a8a;
        font-weight: 600;
    }

    @@media (max-width: 768px) {
        .catalogo-header-card {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

@code {
    public string mensaje = "NADA";

    public string idtorneoseleccionado;

    public PosicionesCLS[] listadoPosiciones;

    public PosicionesCLS oPosicionesCLSBorrar = new PosicionesCLS();         // ESTA LINEA AL PARECER NO LA OCUPO, PERO LA VOY A DEJAR MIENTRAS LO REVISO

    [CascadingParameter]
    private Task<AuthenticationState> auth { get; set; }

    [CascadingParameter]
    public MisValoresCascada misvalorescascada { get; set; }

    [Parameter]
    public string Id { get; set; }

    public bool permitirAgregar = false;
    public bool permitirEditar = false;
    public bool permitirEliminar = false;
    public bool permitirExportarExcel = false;
    public bool permitirExportarWord = false;
    public bool permitirExportarPDF = false;

    List<int> listaBotones = new List<int>();

    protected override async Task OnInitializedAsync()
    {
        // TODAS ESTAS LINEAS SI VAN
        var authuser = await auth;
        var user = authuser.User;

        if (user.Identity.IsAuthenticated)
        {
            var claims = user.Claims.ToList();
            var torneoseleccionadocadena = claims[1].Value;

            // AQUI ESTOY RECIENDO EN CADENA EL ID DE TORNEO SELECCIONADO
            idtorneoseleccionado = claims[2].Value;

            listadoPosiciones = await http.GetFromJsonAsync<PosicionesCLS[]>("api/Posiciones/ListarPosiciones/" + idtorneoseleccionado);
            //listadoPosiciones = await http.GetFromJsonAsync<PosicionesCLS[]>("api/Posiciones/ListarPosiciones/" + "1");

            listaBotones = await http.GetFromJsonAsync<List<int>>("api/PaginaTipoUsuario/listarBotones/" + user.Identity.Name + "/" + Id);
            //listaBotones = await http.GetFromJsonAsync<List<int>>("api/PaginaTipoUsuario/listarBotones/" + "admin" + "/" + Id);

            if (listaBotones.Count() > 0)
            {
                if (listaBotones.Contains(1)) permitirAgregar = true;
                if (listaBotones.Contains(2)) permitirEditar = true;
                if (listaBotones.Contains(3)) permitirEliminar = true;
                if (listaBotones.Contains(4)) permitirExportarExcel = true;
                if (listaBotones.Contains(5)) permitirExportarWord = true;
                if (listaBotones.Contains(6)) permitirExportarPDF = true;
            }

            misvalorescascada.torneocascada = torneoseleccionadocadena;
        }
    }


    public async Task ExportarExcelPosiciones()
    {
        try
        {
            byte[] archivo = await http.GetByteArrayAsync("api/Posiciones/ExportarPosicionesExcel/" + idtorneoseleccionado);
            string base64 = Convert.ToBase64String(archivo);
            string data = "data:application/vnd.openxmlformats-officedocument.spreadsheetml.sheet;base64," + base64;
            await ijsruntime.InvokeVoidAsync("descargarExcel", data, "TablaPosiciones.xlsx");
        }
        catch (Exception ex)
        {
            await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "ERROR AL EXPORTAR EXCEL: " + ex.Message, "error");
        }
    }


    public async Task ExportarPdfPosiciones()
    {
        try
        {
            byte[] archivo = await http.GetByteArrayAsync("api/Posiciones/ExportarPosicionesPdf/" + idtorneoseleccionado);
            string base64 = Convert.ToBase64String(archivo);
            string data = "data:application/pdf;base64," + base64;
            await ijsruntime.InvokeVoidAsync("descargarPdf", data);
        }
        catch (Exception ex)
        {
            await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "ERROR AL EXPORTAR PDF: " + ex.Message, "error");
        }
    }



}

