@code {
    [CascadingParameter]
    private Task<AuthenticationState> auth { get; set; }

    private string idtorneoseleccionado = "";
    private string torneoNombre = "";
    private string ligaNombre = "";

    private int equipoSeleccionado = 0;
    private string nombreEquipoSeleccionado = "";
    private EquipoCLS equipoActual = null;

    private int tipoLista = 1;
    private bool cargando = false;

    private List<EquipoCLS> listaEquipos = new();
    private JugadorCLS[] listaJugadores = null;

    private string ClaseTipo1 => tipoLista == 1 ? "cred-tipo-btn activo" : "cred-tipo-btn";
    private string ClaseTipo2 => tipoLista == 2 ? "cred-tipo-btn activo" : "cred-tipo-btn";

    protected override async Task OnInitializedAsync()
    {
        var authuser = await auth;
        var user = authuser.User;

        if (user.Identity.IsAuthenticated)
        {
            var claims = user.Claims.ToList();
            torneoNombre = claims[1].Value;
            idtorneoseleccionado = claims[2].Value;

            listaEquipos = await http.GetFromJsonAsync<List<EquipoCLS>>(
                "api/Equipo/ListarEquipo/" + idtorneoseleccionado);

            try
            {
                var torneoCLS = await http.GetFromJsonAsync<TorneoCLS>(
                    "api/Torneo/RecuperarInformacionTorneo/" + idtorneoseleccionado);

                if (torneoCLS?.idliga != null)
                {
                    var ligaCLS = await http.GetFromJsonAsync<LigaCLS>(
                        "api/Liga/RecuperarInformacionLiga/" + torneoCLS.idliga);
                    ligaNombre = ligaCLS?.nombre ?? torneoNombre;
                }
            }
            catch
            {
                ligaNombre = torneoNombre;
            }
        }
    }

    private async Task CambiarEquipo(ChangeEventArgs e)
    {
        if (!int.TryParse(e.Value?.ToString(), out int idEquipo) || idEquipo == 0)
        {
            equipoSeleccionado = 0;
            nombreEquipoSeleccionado = "";
            equipoActual = null;
            listaJugadores = null;
            return;
        }

        equipoSeleccionado = idEquipo;
        nombreEquipoSeleccionado = listaEquipos.FirstOrDefault(eq => eq.idequipo == idEquipo)?.nombre ?? "";
        cargando = true;
        listaJugadores = null;
        equipoActual = null;

        // Cargar jugadores y datos del equipo (foto) en paralelo
        var taskJugadores = http.GetFromJsonAsync<JugadorCLS[]>("api/Jugador/ListarJugadorEquipo/" + idEquipo);
        var taskEquipo    = http.GetFromJsonAsync<EquipoCLS>("api/Equipo/RecuperarInformacionEquipo/" + idEquipo);

        await System.Threading.Tasks.Task.WhenAll(taskJugadores, taskEquipo);

        listaJugadores = taskJugadores.Result;
        equipoActual   = taskEquipo.Result;

        cargando = false;
    }

    // ────────────────────────────────────────────────────────────────
    //  EXPORTAR A WORD
    // ────────────────────────────────────────────────────────────────
    private async Task ExportarWord()
    {
        try
        {
            var sb = new System.Text.StringBuilder();

            sb.AppendLine("<!DOCTYPE html>");
            sb.AppendLine("<html xmlns:o='urn:schemas-microsoft-com:office:office'");
            sb.AppendLine("      xmlns:w='urn:schemas-microsoft-com:office:word'");
            sb.AppendLine("      xmlns='http://www.w3.org/TR/REC-html40'>");
            sb.AppendLine("<head><meta charset='utf-8'><title>Lista de Jugadores</title>");
            sb.AppendLine("<style>");
            sb.AppendLine("@page Section1 { size:21.0cm 29.7cm; margin:1.5cm 2cm; mso-header-margin:.5cm; mso-footer-margin:.5cm; mso-paper-source:0; }");
            sb.AppendLine("div.Section1 { page:Section1; }");
            sb.AppendLine("body { font-family:Arial,sans-serif; font-size:9pt; }");
            sb.AppendLine("table.lista { page-break-inside:avoid; width:100%; border-collapse:collapse; }");
            sb.AppendLine("</style>");
            sb.AppendLine("</head>");
            sb.AppendLine("<body><div class='Section1'>");

            if (tipoLista == 1)
                GenerarHtmlTipo1(sb);
            else
                GenerarHtmlTipo2(sb);

            sb.AppendLine("</div></body></html>");

            var bytes = System.Text.Encoding.UTF8.GetBytes(sb.ToString());
            var base64 = Convert.ToBase64String(bytes);

            await ijsruntime.InvokeVoidAsync("descargarArchivo",
                base64,
                $"ListaJugadores_{nombreEquipoSeleccionado.Replace(" ", "_")}_{DateTime.Now:ddMMyyyy}.doc",
                "application/msword");
        }
        catch (Exception ex)
        {
            await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta",
                "ERROR AL EXPORTAR: " + ex.Message, "error");
        }
    }

    // ────────────────────────────────────────────────────────────────
    //  HTML WORD — TIPO 1
    // ────────────────────────────────────────────────────────────────
