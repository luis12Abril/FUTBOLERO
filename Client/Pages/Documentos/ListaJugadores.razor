@page "/documentos/lista-jugadores"
@using FUTBOLERO.Shared
@inject HttpClient http
@inject IJSRuntime ijsruntime

<AuthorizeView>
    <Authorized>
        <section class="catalogo-page mt-3">

            <div class="catalogo-header-card">
                <div>
                    <p class="catalogo-kicker">Panel de administración</p>
                    <h3>Lista de Jugadores</h3>
                    <span>Genera e imprime la lista oficial de jugadores del equipo seleccionado.</span>
                </div>
            </div>

            @* ─── FILTROS ─── *@
            <div class="cred-filtros-card">
                <div class="cred-filtro-row">
                    <div class="cred-filtro-item">
                        <label class="cred-label">Seleccionar Equipo</label>
                        <select class="cred-select" @onchange="CambiarEquipo">
                            <option value="">-- Seleccione un equipo --</option>
                            @if (listaEquipos != null)
                            {
                                @foreach (var eq in listaEquipos)
                                {
                                    <option value="@eq.idequipo">@eq.nombre</option>
                                }
                            }
                        </select>
                    </div>

                    <div class="cred-filtro-item">
                        <label class="cred-label">Tipo de Lista</label>
                        <div class="cred-tipo-toggle">
                            <button class="@ClaseTipo1" @onclick="() => tipoLista = 1">Tipo 1</button>
                            <button class="@ClaseTipo2" @onclick="() => tipoLista = 2">Tipo 2</button>
                        </div>
                    </div>

                    @if (listaJugadores != null && listaJugadores.Length > 0)
                    {
                        <div class="cred-filtro-item cred-filtro-btn">
                            <button class="btn-exportar-word" @onclick="ExportarWord">
                                📄 Exportar a Word
                            </button>
                        </div>
                    }
                </div>
            </div>

            @* ─── CONTENIDO ─── *@
            @if (cargando)
            {
                <div class="catalogo-loading">
                    <div class="spinner-border text-primary" role="status"></div>
                    <span class="ml-2">Cargando jugadores...</span>
                </div>
            }
            else if (equipoSeleccionado == 0)
            {
                <div class="cred-empty-msg">
                    <span>⬆️ Seleccione un equipo para ver su lista de jugadores.</span>
                </div>
            }
            else if (listaJugadores == null || listaJugadores.Length == 0)
            {
                <div class="cred-empty-msg cred-empty-warn">
                    <span>⚠️ Este equipo no tiene jugadores dados de alta.</span>
                </div>
            }
            else
            {
                @if (tipoLista == 1)
                {
                    @* ══════ TIPO 1: Lista oficial clásica azul ══════ *@
                    <div class="lista-preview-wrap">
                        <div class="lista-tipo1">

                            @* Encabezado *@
                            <div class="lt1-header">
                                <div class="lt1-logo">
                                    @if (!string.IsNullOrEmpty(equipoActual?.fotoequipo))
                                    {
                                        <img src="@equipoActual.fotoequipo" alt="Logo" class="lt1-logo-img" />
                                    }
                                    else
                                    {
                                        <div class="lt1-logo-placeholder">⚽</div>
                                    }
                                </div>
                                <div class="lt1-header-info">
                                    <div class="lt1-liga">@ligaNombre</div>
                                    <div class="lt1-torneo">@torneoNombre</div>
                                    <div class="lt1-equipo">@nombreEquipoSeleccionado</div>
                                </div>
                            </div>

                            @* Tabla de jugadores *@
                            <table class="lt1-tabla">
                                <thead>
                                    <tr>
                                        <th class="lt1-th lt1-th-num">#</th>
                                        <th class="lt1-th lt1-th-nombre">Jugador</th>
                                        <th class="lt1-th lt1-th-check">Titular</th>
                                        <th class="lt1-th lt1-th-check">Suplente</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @for (int i = 0; i < 25; i++)
                                    {
                                        var jugador = i < listaJugadores.Length ? listaJugadores[i] : null;
                                        var num = i + 1;
                                        <tr class="lt1-tr @(i % 2 == 0 ? "lt1-par" : "lt1-impar")">
                                            <td class="lt1-td lt1-td-num">@num</td>
                                            <td class="lt1-td lt1-td-nombre">@(jugador?.nombrecompleto ?? "")</td>
                                            <td class="lt1-td lt1-td-check"></td>
                                            <td class="lt1-td lt1-td-check"></td>
                                        </tr>
                                    }
                                </tbody>
                            </table>

                            @* Firmas *@
                            <div class="lt1-footer">
                                <div class="lt1-firma-bloque">
                                    <div class="lt1-firma-linea"></div>
                                    <span>Firma del Representante</span>
                                </div>
                                <div class="lt1-firma-bloque">
                                    <div class="lt1-firma-linea"></div>
                                    <span>Firma del Árbitro</span>
                                </div>
                            </div>

                        </div>
                    </div>
                }
                else
                {
                    @* ══════ TIPO 2: Lista compacta verde ══════ *@
                    <div class="lista-preview-wrap">
                        <div class="lista-tipo2">

                            @* Encabezado verde *@
                            <div class="lt2-header">
                                <div class="lt2-logo">
                                    @if (!string.IsNullOrEmpty(equipoActual?.fotoequipo))
                                    {
                                        <img src="@equipoActual.fotoequipo" alt="Logo" class="lt2-logo-img" />
                                    }
                                    else
                                    {
                                        <div class="lt2-logo-placeholder">⚽</div>
                                    }
                                </div>
                                <div class="lt2-header-info">
                                    <div class="lt2-titulo">LISTA OFICIAL DE JUGADORES</div>
                                    <div class="lt2-liga">@ligaNombre</div>
                                    <div class="lt2-torneo">@torneoNombre</div>
                                    <div class="lt2-equipo">@nombreEquipoSeleccionado</div>
                                </div>
                            </div>

                            @* Dos columnas de jugadores *@
                            <div class="lt2-body">
                                @{
                                    int mitad = (int)Math.Ceiling(25.0 / 2);
                                }
                                @* Columna izquierda (1-13) *@
                                <table class="lt2-tabla">
                                    <thead>
                                        <tr>
                                            <th class="lt2-th lt2-th-num">#</th>
                                            <th class="lt2-th lt2-th-nombre">Jugador</th>
                                            <th class="lt2-th lt2-th-check">T</th>
                                            <th class="lt2-th lt2-th-check">S</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @for (int i = 0; i < mitad; i++)
                                        {
                                            var jugador = i < listaJugadores.Length ? listaJugadores[i] : null;
                                            <tr class="lt2-tr @(i % 2 == 0 ? "lt2-par" : "lt2-impar")">
                                                <td class="lt2-td lt2-td-num">@(i + 1)</td>
                                                <td class="lt2-td lt2-td-nombre">@(jugador?.nombrecompleto ?? "")</td>
                                                <td class="lt2-td lt2-td-check"></td>
                                                <td class="lt2-td lt2-td-check"></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                                @* Columna derecha (14-25) *@
                                <table class="lt2-tabla">
                                    <thead>
                                        <tr>
                                            <th class="lt2-th lt2-th-num">#</th>
                                            <th class="lt2-th lt2-th-nombre">Jugador</th>
                                            <th class="lt2-th lt2-th-check">T</th>
                                            <th class="lt2-th lt2-th-check">S</th>
                                        </tr>
                                    </thead>
                                    <tbody>
                                        @for (int i = mitad; i < 25; i++)
                                        {
                                            var jugador = i < listaJugadores.Length ? listaJugadores[i] : null;
                                            <tr class="lt2-tr @(i % 2 == 0 ? "lt2-par" : "lt2-impar")">
                                                <td class="lt2-td lt2-td-num">@(i + 1)</td>
                                                <td class="lt2-td lt2-td-nombre">@(jugador?.nombrecompleto ?? "")</td>
                                                <td class="lt2-td lt2-td-check"></td>
                                                <td class="lt2-td lt2-td-check"></td>
                                            </tr>
                                        }
                                    </tbody>
                                </table>
                            </div>

                            @* Firmas *@
                            <div class="lt2-footer">
                                <div class="lt2-firma-bloque">
                                    <div class="lt2-firma-linea"></div>
                                    <span>Firma del Representante</span>
                                </div>
                                <div class="lt2-firma-bloque">
                                    <div class="lt2-firma-linea"></div>
                                    <span>Firma del Árbitro</span>
                                </div>
                            </div>

                        </div>
                    </div>
                }
            }

        </section>
    </Authorized>
</AuthorizeView>

<style>
