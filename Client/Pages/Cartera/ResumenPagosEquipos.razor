        sb.AppendLine("  <Style ss:ID=\"sDatoNum\"><Alignment ss:Horizontal=\"Right\" ss:Vertical=\"Center\"/><Font ss:Size=\"10\"/><NumberFormat ss:Format=\"&quot;$&quot;#,##0.00\"/><Borders><Border ss:Position=\"Bottom\" ss:LineStyle=\"Continuous\" ss:Weight=\"1\" ss:Color=\"#DDDDDD\"/></Borders></Style>");
        sb.AppendLine("  <Style ss:ID=\"sDatoNumAlt\"><Alignment ss:Horizontal=\"Right\" ss:Vertical=\"Center\"/><Font ss:Size=\"10\"/><Interior ss:Color=\"#EFF6FF\" ss:Pattern=\"Solid\"/><NumberFormat ss:Format=\"&quot;$&quot;#,##0.00\"/><Borders><Border ss:Position=\"Bottom\" ss:LineStyle=\"Continuous\" ss:Weight=\"1\" ss:Color=\"#DDDDDD\"/></Borders></Style>");
        sb.AppendLine("  <Style ss:ID=\"sDatoCenter\"><Alignment ss:Horizontal=\"Center\" ss:Vertical=\"Center\"/><Font ss:Size=\"10\"/><Borders><Border ss:Position=\"Bottom\" ss:LineStyle=\"Continuous\" ss:Weight=\"1\" ss:Color=\"#DDDDDD\"/></Borders></Style>");
        sb.AppendLine("  <Style ss:ID=\"sDatoCenterAlt\"><Alignment ss:Horizontal=\"Center\" ss:Vertical=\"Center\"/><Font ss:Size=\"10\"/><Interior ss:Color=\"#EFF6FF\" ss:Pattern=\"Solid\"/><Borders><Border ss:Position=\"Bottom\" ss:LineStyle=\"Continuous\" ss:Weight=\"1\" ss:Color=\"#DDDDDD\"/></Borders></Style>");
        sb.AppendLine("  <Style ss:ID=\"sTotalesLabel\"><Font ss:Bold=\"1\" ss:Size=\"10\"/><Interior ss:Color=\"#DBEAFE\" ss:Pattern=\"Solid\"/><Borders><Border ss:Position=\"Top\" ss:LineStyle=\"Continuous\" ss:Weight=\"2\" ss:Color=\"#1E40AF\"/></Borders></Style>");
        sb.AppendLine("  <Style ss:ID=\"sTotalesNum\"><Alignment ss:Horizontal=\"Right\"/><Font ss:Bold=\"1\" ss:Size=\"10\"/><Interior ss:Color=\"#DBEAFE\" ss:Pattern=\"Solid\"/><NumberFormat ss:Format=\"&quot;$&quot;#,##0.00\"/><Borders><Border ss:Position=\"Top\" ss:LineStyle=\"Continuous\" ss:Weight=\"2\" ss:Color=\"#1E40AF\"/></Borders></Style>");
        sb.AppendLine("  <Style ss:ID=\"sTotalesVacio\"><Interior ss:Color=\"#DBEAFE\" ss:Pattern=\"Solid\"/><Borders><Border ss:Position=\"Top\" ss:LineStyle=\"Continuous\" ss:Weight=\"2\" ss:Color=\"#1E40AF\"/></Borders></Style>");
        sb.AppendLine("</Styles>");

        sb.AppendLine("<Worksheet ss:Name=\"Resumen de Pagos\">");
        sb.AppendLine("<Table>");

        // Anchos de columna: Equipo=175, Representante=200, CuotaTotal=100, Pagado=100, Pendiente=100, Estatus=90
        sb.AppendLine("  <Column ss:Width=\"175\"/>");
        sb.AppendLine("  <Column ss:Width=\"200\"/>");
        sb.AppendLine("  <Column ss:Width=\"100\"/>");
        sb.AppendLine("  <Column ss:Width=\"100\"/>");
        sb.AppendLine("  <Column ss:Width=\"100\"/>");
        sb.AppendLine("  <Column ss:Width=\"90\"/>");

        // Fila 1: Título
        sb.AppendLine("  <Row ss:Height=\"22\">");
        sb.AppendLine($"    <Cell ss:StyleID=\"sTitulo\" ss:MergeAcross=\"5\"><Data ss:Type=\"String\">Resumen de Pagos</Data></Cell>");
        sb.AppendLine("  </Row>");

        // Fila 2: Subtítulo
        sb.AppendLine("  <Row>");
        sb.AppendLine("    <Cell ss:MergeAcross=\"5\"><Data ss:Type=\"String\">Estado de cuenta de todos los equipos en el torneo.</Data></Cell>");
        sb.AppendLine("  </Row>");

        // Fila 3: vacía
        sb.AppendLine("  <Row ss:Height=\"8\"><Cell><Data ss:Type=\"String\"></Data></Cell></Row>");

        // Fila 4: Resumen general
        sb.AppendLine("  <Row>");
        sb.AppendLine($"    <Cell ss:StyleID=\"sResumen\" ss:MergeAcross=\"5\"><Data ss:Type=\"String\">Total equipos: {listaEquipos.Count}   |   Liquidados: {liquidados}   |   Pago parcial: {parciales}   |   Sin pago: {sinPago}</Data></Cell>");
        sb.AppendLine("  </Row>");

        // Fila 5: vacía
        sb.AppendLine("  <Row ss:Height=\"8\"><Cell><Data ss:Type=\"String\"></Data></Cell></Row>");

        // Fila 6: Encabezados de tabla
        sb.AppendLine("  <Row ss:Height=\"18\">");
        sb.AppendLine("    <Cell ss:StyleID=\"sEncabezado\"><Data ss:Type=\"String\">EQUIPO</Data></Cell>");
        sb.AppendLine("    <Cell ss:StyleID=\"sEncabezado\"><Data ss:Type=\"String\">REPRESENTANTE</Data></Cell>");
        sb.AppendLine("    <Cell ss:StyleID=\"sEncabezado\"><Data ss:Type=\"String\">CUOTA TOTAL</Data></Cell>");
        sb.AppendLine("    <Cell ss:StyleID=\"sEncabezado\"><Data ss:Type=\"String\">PAGADO</Data></Cell>");
        sb.AppendLine("    <Cell ss:StyleID=\"sEncabezado\"><Data ss:Type=\"String\">PENDIENTE</Data></Cell>");
        sb.AppendLine("    <Cell ss:StyleID=\"sEncabezado\"><Data ss:Type=\"String\">ESTATUS</Data></Cell>");
        sb.AppendLine("  </Row>");

        // Filas de datos
        int rowIndex = 0;
        foreach (var eq in listaEquipos)
        {
            bool alt = (rowIndex % 2 == 1);
            string sDato       = alt ? "sDatoAlt"       : "sDato";
            string sDatoNum    = alt ? "sDatoNumAlt"    : "sDatoNum";
            string sDatoCenter = alt ? "sDatoCenterAlt" : "sDatoCenter";

            sb.AppendLine("  <Row ss:Height=\"16\">");
            sb.AppendLine($"    <Cell ss:StyleID=\"{sDato}\"><Data ss:Type=\"String\">{eq.nombreEquipo}</Data></Cell>");
            sb.AppendLine($"    <Cell ss:StyleID=\"{sDato}\"><Data ss:Type=\"String\">{eq.representante}</Data></Cell>");
            sb.AppendLine($"    <Cell ss:StyleID=\"{sDatoNum}\"><Data ss:Type=\"Number\">{eq.montoasignado.ToString(System.Globalization.CultureInfo.InvariantCulture)}</Data></Cell>");
            sb.AppendLine($"    <Cell ss:StyleID=\"{sDatoNum}\"><Data ss:Type=\"Number\">{eq.totalPagado.ToString(System.Globalization.CultureInfo.InvariantCulture)}</Data></Cell>");
            sb.AppendLine($"    <Cell ss:StyleID=\"{sDatoNum}\"><Data ss:Type=\"Number\">{eq.saldoPendiente.ToString(System.Globalization.CultureInfo.InvariantCulture)}</Data></Cell>");
            sb.AppendLine($"    <Cell ss:StyleID=\"{sDatoCenter}\"><Data ss:Type=\"String\">{eq.estatusPago}</Data></Cell>");
            sb.AppendLine("  </Row>");
            rowIndex++;
        }

        // Fila de totales
        sb.AppendLine("  <Row ss:Height=\"18\">");
        sb.AppendLine("    <Cell ss:StyleID=\"sTotalesLabel\"><Data ss:Type=\"String\">TOTALES</Data></Cell>");
        sb.AppendLine("    <Cell ss:StyleID=\"sTotalesVacio\"><Data ss:Type=\"String\"></Data></Cell>");
        sb.AppendLine($"    <Cell ss:StyleID=\"sTotalesNum\"><Data ss:Type=\"Number\">{listaEquipos.Sum(e => e.montoasignado).ToString(System.Globalization.CultureInfo.InvariantCulture)}</Data></Cell>");
        sb.AppendLine($"    <Cell ss:StyleID=\"sTotalesNum\"><Data ss:Type=\"Number\">{listaEquipos.Sum(e => e.totalPagado).ToString(System.Globalization.CultureInfo.InvariantCulture)}</Data></Cell>");
        sb.AppendLine($"    <Cell ss:StyleID=\"sTotalesNum\"><Data ss:Type=\"Number\">{listaEquipos.Sum(e => e.saldoPendiente).ToString(System.Globalization.CultureInfo.InvariantCulture)}</Data></Cell>");
        sb.AppendLine("    <Cell ss:StyleID=\"sTotalesVacio\"><Data ss:Type=\"String\"></Data></Cell>");
        sb.AppendLine("  </Row>");

        sb.AppendLine("</Table>");
        sb.AppendLine("</Worksheet>");
        sb.AppendLine("</Workbook>");

        var xmlBytes = System.Text.Encoding.UTF8.GetBytes(sb.ToString());
        var base64 = Convert.ToBase64String(xmlBytes);

        await ijsruntime.InvokeVoidAsync("descargarArchivo",
            base64,
            "ResumenPagos.xls",
            "application/vnd.ms-excel");
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            var respCuota = await http.GetAsync($"api/CuotaTorneo/ObtenerCuota/{IdTorneo}");
            if (respCuota.IsSuccessStatusCode)
            {
                var content = await respCuota.Content.ReadAsStringAsync();
                if (!string.IsNullOrWhiteSpace(content) && content != "null")
                {
                    oCuota = System.Text.Json.JsonSerializer.Deserialize<CuotaTorneoCLS>(
                        content,
                        new System.Text.Json.JsonSerializerOptions { PropertyNameCaseInsensitive = true });
                }
            }
        }
        catch { }

        if (oCuota != null && oCuota.idcuotatorneo > 0)
        {
            try
            {
                listaEquipos = await http.GetFromJsonAsync<List<CuotaEquipoCLS>>(
                    $"api/CuotaEquipo/ListarResumen/{oCuota.idcuotatorneo}");
            }
            catch { listaEquipos = new List<CuotaEquipoCLS>(); }
        }
        else
        {
            listaEquipos = new List<CuotaEquipoCLS>();
        }
    }
}
