@page "/ResumenPagosEquipos/{IdTorneo}"
@using FUTBOLERO.Shared
@inject HttpClient http
@inject NavigationManager navigation
@inject IJSRuntime ijsruntime

<AuthorizeView Context="authCtx">
    <Authorized>
        <section class="resumen-page mt-3">
            <div class="resumen-header-card">
                <div>
                    <p class="resumen-kicker">Panel de administración</p>
                    <h3>💰 Resumen de Pagos</h3>
                    <span>Estado de cuenta de todos los equipos en el torneo.</span>
                </div>
                <div class="resumen-acciones" style="display:flex; gap:0.5rem; align-items:center; flex-wrap:wrap;">
                    @if (listaEquipos != null && listaEquipos.Any())
                    {
                        <button class="btn btn-exportar-word" @onclick="ExportarWord">
                            📄 Exportar a Word
                        </button>
                        <button class="btn btn-exportar-excel" @onclick="ExportarExcel">
                            📊 Exportar a Excel
                        </button>
                    }
                    <NavLink href="@($"ConfigurarCuotaTorneo/{IdTorneo}")" class="btn btn-configurar">
                        ⚙️ Configurar Cuota
                    </NavLink>
                    <button class="catalogo-help-btn" @onclick="() => showHelp = true" title="Ayuda">?</button>
                </div>
            </div>

            @if (listaEquipos == null)
            {
                <div class="text-center py-5">
                    <div class="spinner-border text-primary" role="status"></div>
                    <span class="ms-2">Cargando...</span>
                </div>
            }
            else if (!listaEquipos.Any())
            {
                <div class="alert alert-info mt-3">
                    No hay equipos con cuota asignada. 
                    <NavLink href="@($"ConfigurarCuotaTorneo/{IdTorneo}")">Configura la cuota primero.</NavLink>
                </div>
            }
            else
            {
                <!-- Tarjetas de resumen general -->
                <div class="resumen-stats row g-3 mb-3">
                    <div class="col-md-3">
                        <div class="stat-card stat-total">
                            <div class="stat-valor">@listaEquipos.Count</div>
                            <div class="stat-label">Total Equipos</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="stat-card stat-liquidado">
                            <div class="stat-valor">@listaEquipos.Count(e => e.estatusPago == "Liquidado")</div>
                            <div class="stat-label">✅ Liquidados</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="stat-card stat-parcial">
                            <div class="stat-valor">@listaEquipos.Count(e => e.estatusPago == "Parcial")</div>
                            <div class="stat-label">⚠️ Pago Parcial</div>
                        </div>
                    </div>
                    <div class="col-md-3">
                        <div class="stat-card stat-sinpago">
                            <div class="stat-valor">@listaEquipos.Count(e => e.estatusPago == "Sin pago")</div>
                            <div class="stat-label">🔴 Sin Pago</div>
                        </div>
                    </div>
                </div>

                <!-- Tabla de equipos -->
                <div class="resumen-list-card">
                    <div class="table-responsive">
                        <table class="table table-hover resumen-tabla mb-0">
                            <thead>
                                <tr>
                                    <th>Equipo</th>
                                    <th>Representante</th>
                                    <th class="text-end">Cuota Total</th>
                                    <th class="text-end">Pagado</th>
                                    <th class="text-end">Pendiente</th>
                                    <th class="text-center">Estatus</th>
                                    <th class="text-center">Acciones</th>
                                </tr>
                            </thead>
                            <tbody>
                                @foreach (var eq in listaEquipos)
                                {
                                    <tr>
                                        <td class="fw-semibold">@eq.nombreEquipo</td>
                                        <td>@eq.representante</td>
                                        <td class="text-end">
                                            @if (equipoEditandoId == eq.idcuotaequipo)
                                            {
                                                <div class="d-flex align-items-center gap-1 justify-content-end">
                                                    <input type="number" class="form-control form-control-sm text-end" style="width:110px"
                                                           @bind="montoEditando" />
                                                    <button class="btn btn-sm btn-success" @onclick="() => GuardarMonto(eq)" title="Guardar">✔</button>
                                                    <button class="btn btn-sm btn-secondary" @onclick="CancelarEdicion" title="Cancelar">✖</button>
                                                </div>
                                            }
                                            else
                                            {
                                                <span>@eq.montoasignado.ToString("C2")</span>
                                                <button class="btn btn-sm btn-outline-primary ms-1 py-0 px-1" style="font-size:0.7rem"
                                                        @onclick="() => IniciarEdicion(eq)" title="Editar monto">✏️</button>
                                            }
                                        </td>
                                        <td class="text-end text-success fw-semibold">@eq.totalPagado.ToString("C2")</td>
                                        <td class="text-end @(eq.saldoPendiente > 0 ? "text-danger fw-semibold" : "text-success")">
                                            @eq.saldoPendiente.ToString("C2")
                                        </td>
                                        <td class="text-center">
                                            @if (eq.estatusPago == "Liquidado")
                                            {
                                                <span class="badge badge-liquidado">✅ Liquidado</span>
                                            }
                                            else if (eq.estatusPago == "Parcial")
                                            {
                                                <span class="badge badge-parcial">⚠️ Parcial</span>
                                            }
                                            else
                                            {
                                                <span class="badge badge-sinpago">🔴 Sin pago</span>
                                            }
                                        </td>
                                        <td class="text-center">
                                            <NavLink href="@($"RegistrarPago/{eq.idcuotaequipo}/{IdTorneo}")"
                                                     class="btn btn-sm btn-pagar">
                                                💵 Pagos
                                            </NavLink>
                                        </td>
                                    </tr>
                                }
                            </tbody>
                            <tfoot>
                                <tr class="resumen-totales">
                                    <td colspan="2" class="fw-bold">TOTALES</td>
                                    <td class="text-end fw-bold">@listaEquipos.Sum(e => e.montoasignado).ToString("C2")</td>
                                    <td class="text-end fw-bold text-success">@listaEquipos.Sum(e => e.totalPagado).ToString("C2")</td>
                                    <td class="text-end fw-bold text-danger">@listaEquipos.Sum(e => e.saldoPendiente).ToString("C2")</td>
                                    <td colspan="2"></td>
                                </tr>
                            </tfoot>
                        </table>
                    </div>
                </div>
            }
        </section>

        @* ── MODAL DE AYUDA ── *@
        @if (showHelp)
        {
            <div class="ayuda-overlay" @onclick="() => showHelp = false">
                <div class="ayuda-modal" @onclick:stopPropagation="true">

                    <div class="ayuda-modal-header">
                        <div>
                            <span class="ayuda-kicker">Guía de uso</span>
                            <h4>Resumen de Pagos</h4>
                        </div>
                        <button class="ayuda-close-btn" @onclick="() => showHelp = false">✕</button>
                    </div>

                    <div class="ayuda-modal-body">

                        <div class="ayuda-section">
                            <h5>📊 ¿Qué es esta pantalla?</h5>
                            <p>
                                Muestra el <strong>estado de cuenta de todos los equipos</strong> del torneo:
                                cuánto deben, cuánto han pagado y cuánto les falta. Desde aquí puedes
                                navegar a los pagos individuales de cada equipo.
                            </p>
                        </div>

                        <div class="ayuda-section">
                            <h5>🗒️ Tarjetas de resumen general</h5>
                            <p>En la parte superior verás cuatro tarjetas con el conteo de equipos según su estatus:</p>
                            <table class="ayuda-table">
                                <thead><tr><th>Tarjeta</th><th>Significado</th></tr></thead>
                                <tbody>
                                    <tr><td>🔵 Total Equipos</td><td>Todos los equipos con cuota asignada en este torneo.</td></tr>
                                    <tr><td>✅ Liquidados</td><td>Equipos que ya pagaron el 100% de su cuota.</td></tr>
                                    <tr><td>⚠️ Pago Parcial</td><td>Equipos que han abonado pero les falta saldo.</td></tr>
                                    <tr><td>🔴 Sin Pago</td><td>Equipos que no han realizado ningún abono.</td></tr>
                                </tbody>
                            </table>
                        </div>

                        <div class="ayuda-section">
                            <h5>📝 Tabla de equipos</h5>
                            <p>En la tabla principal verás las columnas:</p>
                            <table class="ayuda-table">
                                <thead><tr><th>Columna</th><th>Descripción</th></tr></thead>
                                <tbody>
                                    <tr><td>Equipo</td><td>Nombre del equipo participante.</td></tr>
                                    <tr><td>Representante</td><td>Nombre de la persona responsable del equipo.</td></tr>
                                    <tr><td>Cuota Total</td><td>Monto que debe cubrir el equipo. Se puede editar directamente con el ícono ✏️.</td></tr>
                                    <tr><td>Pagado</td><td>Suma de todos los abonos registrados.</td></tr>
                                    <tr><td>Pendiente</td><td>Diferencia entre la cuota total y lo pagado. Rojo = debe dinero, verde = liquidado.</td></tr>
                                    <tr><td>Estatus</td><td>Badge de color: Liquidado, Parcial o Sin pago.</td></tr>
                                    <tr><td>Acciones</td><td>Botón <strong>Pagos</strong> para ver y registrar abonos del equipo.</td></tr>
                                </tbody>
                            </table>
                        </div>

                        <div class="ayuda-section">
                            <h5>✏️ Editar monto individual de un equipo</h5>
                            <p>
                                Si un equipo necesita pagar un monto diferente al general, haz clic en el
                                ícono ✏️ que aparece junto a su cuota total. Escribe el nuevo monto y
                                presiona <strong>✔</strong> para guardar o <strong>✖</strong> para cancelar.
                            </p>
                            <div class="ayuda-tip">
                                📌 El monto individual no afecta la cuota base del torneo, solo a ese equipo en particular.
                            </div>
                        </div>

                        <div class="ayuda-section">
                            <h5>💵 Registrar pagos de un equipo</h5>
                            <p>
                                Haz clic en el botón <strong>Pagos</strong> de la fila del equipo.
                                Se abrirá la pantalla de <em>Registrar Pago</em> donde podrás ver el historial
                                de abonos y registrar nuevos pagos.
                            </p>
                        </div>

                        <div class="ayuda-section">
                            <h5>📤 Exportar el resumen</h5>
                            <p>Puedes exportar el listado completo de todos los equipos con sus montos y estatus en:</p>
                            <table class="ayuda-table">
                                <tbody>
                                    <tr><td>📄 <strong>Word</strong></td><td>Documento formateado con tarjetas de resumen y tabla detallada.</td></tr>
                                    <tr><td>📊 <strong>Excel</strong></td><td>Hoja de cálculo con totales calculados, listo para imprimir o analizar.</td></tr>
                                </tbody>
                            </table>
                        </div>

                        <div class="ayuda-section">
                            <h5>⚙️ Configurar Cuota</h5>
                            <p>
                                El botón <strong>Configurar Cuota</strong> te lleva a la pantalla donde puedes
                                cambiar el monto base del torneo, la fecha límite y el concepto del cobro.
                            </p>
                        </div>

                        <div class="ayuda-section ayuda-section-faq">
                            <h5>❓ Preguntas frecuentes</h5>
                            <p><strong>¿Por qué un equipo aparece como “Sin pago” si ya paguó?</strong><br />
                            Verifica que el pago haya sido registrado desde el botón <strong>Pagos</strong> del equipo. Si no aparece, aún no se ha capturado.</p>
                            <p><strong>¿Puedo cambiar el monto de un solo equipo sin afectar a los demás?</strong><br />
                            Sí. Usa el ícono ✏️ en la columna <em>Cuota Total</em> de ese equipo.</p>
                            <p><strong>¿Qué pasa si el saldo pendiente es negativo?</strong><br />
                            Significa que el equipo pagó más de lo requerido. Puedes ajustar el monto o considerar ese excedente como adelanto.</p>
                        </div>

                    </div>

                    <div class="ayuda-modal-footer">
                        <button class="btn ayuda-btn-cerrar" @onclick="() => showHelp = false">Cerrar guía</button>
                    </div>

                </div>
            </div>
        }

    </Authorized>
</AuthorizeView>

<style>
