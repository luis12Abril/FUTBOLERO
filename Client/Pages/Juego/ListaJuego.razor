@page "/ListaJuego/{Id}"
@using FUTBOLERO.Shared
@inject HttpClient http
@inject IJSRuntime ijsruntime

@{
    string[] cabeceras = { "Jornada", "Equipo 01", "Goles", "Equipo 02", "Goles", "Horario", "Estatus" };

    // ESTAS PROPIEDADES TIENEN QUE SER IGUAL A LAS QUE ESTAN EN EL CONTROLADOR
    string[] propiedades = { "jornadacadena", "equipo01cadena", "golesequipo01", "equipo02cadena", "golesequipo02", "fhorariocadena", "estatusjuegocadena" };
}

<AuthorizeView>
    <Authorized>
        <section class="catalogo-page mt-3">
            <div class="catalogo-header-card">
                <div>
                    <p class="catalogo-kicker">Panel de administración</p>
                    <h3>Juegos</h3>
                    <span>Administra los partidos programados y su estatus en el torneo.</span>
                </div>
                <div class="catalogo-header-right">
                    <div class="catalogo-badge">
                        <span>Catálogo</span>
                    </div>
                    <button class="catalogo-help-btn" @onclick="() => showHelp = true" title="Ayuda">
                        <span>?</span>
                    </button>
                </div>
            </div>

            @if (listadoJuego == null)
            {
                <div class="catalogo-loading">
                    <div class="spinner-border text-primary" role="status"></div>
                    <span class="ml-2">Cargando juegos...</span>
                </div>
            }
            else
            {
                <div class="catalogo-list-card">
                    <Listados cabeceras=cabeceras
                              nombrePropiedadesMostrar=propiedades
                              lista=listadoJuego
                              type="combobox" button=false label="Seleccione una jornada"
                              combobox="oJornadaCLS" displayMember="nombre" valueMember="idjornada"
                              permitirAgregar=@permitirAgregar rutaAgregar="AgregarJuego"
                              permitirEditar=@permitirEditar rutaEditar="EditarJuego"
                              permitirEliminar=@permitirEliminar eventEliminar="EliminarListaJuego"
                              eventBusqueda="BuscarListaJuego"
                              permitirExportarExcel=@permitirExportarExcel
                              permitirExportarWord=@permitirExportarWord
                              permitirExportarPdf=@permitirExportarPDF
                              tituloReporte="Listado de Juegos" />
                </div>
            }
        </section>

        @* ── MODAL DE AYUDA ── *@
        @if (showHelp)
        {
            <div class="ayuda-overlay" @onclick="() => showHelp = false">
                <div class="ayuda-modal" @onclick:stopPropagation="true">

                    <div class="ayuda-modal-header">
                        <div>
                            <span class="ayuda-kicker">Guía de uso</span>
                            <h4>Módulo de Juegos</h4>
                        </div>
                        <button class="ayuda-close-btn" @onclick="() => showHelp = false">✕</button>
                    </div>

                    <div class="ayuda-modal-body">

                        <div class="ayuda-section">
                            <h5>⚽ ¿Qué es esta pantalla?</h5>
                            <p>
                                La pantalla <strong>Juegos</strong> es donde se administran los partidos del torneo.
                                Desde aquí puedes <strong>programar nuevos juegos</strong> y también
                                <strong>capturar el resultado</strong> una vez que el partido ha concluido.
                                La búsqueda se hace por jornada usando el selector desplegable.
                            </p>
                        </div>

                        <div class="ayuda-section">
                            <h5>🔍 Buscar juegos por jornada</h5>
                            <p>
                                Selecciona una <strong>jornada</strong> en el selector desplegable para ver
                                únicamente los partidos de esa fecha. Si dejas el selector vacío
                                se muestran todos los juegos del torneo.
                            </p>
                        </div>

                        <div class="ayuda-section">
                            <h5>➕ Programar un juego nuevo</h5>
                            <p>Haz clic en <strong>Agregar</strong> y completa el formulario con los siguientes datos:</p>
                            <table class="ayuda-table">
                                <thead>
                                    <tr><th>Campo</th><th>Obligatorio</th><th>Descripción</th></tr>
                                </thead>
                                <tbody>
                                    <tr><td>Jornada</td><td>✅ Sí</td><td>Fecha o etapa del torneo a la que pertenece el partido.</td></tr>
                                    <tr><td>Equipo 01</td><td>✅ Sí</td><td>Primer equipo que participará en el partido.</td></tr>
                                    <tr><td>Equipo 02</td><td>✅ Sí</td><td>Segundo equipo contrincante.</td></tr>
                                    <tr><td>Campo</td><td>✅ Sí</td><td>Lugar donde se jugará el partido. Si aún no se define, selecciona <em>PENDIENTE</em>.</td></tr>
                                    <tr><td>Arbitro</td><td>✅ Sí</td><td>Arbitro asignado al partido.</td></tr>
                                    <tr><td>Horario</td><td>✅ Sí</td><td>Fecha y hora en que se jugará el partido.</td></tr>
                                </tbody>
                            </table>
                            <div class="ayuda-tip">
                                📌 Al crear un juego, el estatus queda automáticamente en <strong>PENDIENTE</strong>
                                y los checks de puntos y goles vienen activados por defecto.
                            </div>
                        </div>

                        <div class="ayuda-section">
                            <h5>✏️ Editar un juego — capturar el resultado</h5>
                            <p>
                                Haz clic en <strong>Editar</strong> en la fila del partido. En modo edición
                                encontrarás todos los campos del alta más las siguientes secciones adicionales:
                            </p>

                            <p><strong>Resultado por equipo:</strong></p>
                            <table class="ayuda-table">
                                <thead>
                                    <tr><th>Elemento</th><th>Descripción</th></tr>
                                </thead>
                                <tbody>
                                    <tr><td>Goles</td><td>Número de goles anotados por el equipo en el partido.</td></tr>
                                    <tr><td>PE (Puntos Extra)</td><td>Puntos adicionales por penales u otro criterio definido por el torneo.</td></tr>
                                    <tr><td>Radios G / E / P / GP / GA</td><td>Resultado individual del equipo: <strong>G</strong> = Ganó, <strong>E</strong> = Empató, <strong>P</strong> = Perdió, <strong>GP</strong> = Ganó por Penales, <strong>GA</strong> = Ganó por Admin (administrativa).</td></tr>
                                </tbody>
                            </table>

                            <p style="margin-top:0.7rem"><strong>Estatus del juego:</strong> cambia el estatus de <em>PENDIENTE</em> a <em>JUGADO</em> cuando el partido ya concluyó y toda la información está capturada.</p>

                            <p><strong>Goles por jugador:</strong> después del resultado aparece la lista de jugadores de ambos equipos para registrar quién anotó y cuántos goles.
                            Esto alimenta la tabla de goleadores del torneo.</p>

                            <p><strong>Comentarios:</strong> puedes agregar notas o incidencias del partido (tarjetas, lesiones, etc.). Los comentarios quedan visibles en el historial del juego.</p>
                        </div>

                        <div class="ayuda-section">
                            <h5>📊 Cuenta para PUNTOS y Cuenta para GOLES</h5>
                            <p>
                                En la parte inferior del formulario hay dos opciones clave que controlan
                                si el partido impacta o no las tablas del torneo:
                            </p>
                            <table class="ayuda-table">
                                <thead>
                                    <tr><th>Opción</th><th>Check activado ✅</th><th>Check desactivado ❌</th></tr>
                                </thead>
                                <tbody>
                                    <tr>
                                        <td><strong>Cuenta para PUNTOS</strong></td>
                                        <td>El resultado del partido <strong>sí modifica</strong> la tabla de posiciones (puntos, ganados, perdidos, etc.).</td>
                                        <td>El partido <strong>no afecta</strong> la tabla de posiciones. Útil en fases de Liguilla o finales.</td>
                                    </tr>
                                    <tr>
                                        <td><strong>Cuenta para GOLES</strong></td>
                                        <td>Los goles de este partido <strong>sí cuentan</strong> para la tabla de goleadores del torneo.</td>
                                        <td>Los goles <strong>no se acumulan</strong> en la tabla de goleadores. Útil si el torneo decide que solo cuentan los goles del rol regular.</td>
                                    </tr>
                                </tbody>
                            </table>
                            <div class="ayuda-tip ayuda-tip-warning">
                                ⚠️ <strong>¿Cuándo desactivarlos?</strong> Cuando el torneo entra en fase de
                                <strong>Liguilla o eliminación directa</strong>, los partidos de esa fase
                                generalmente <strong>no deben contar para posiciones</strong>, por lo que
                                debes quitar el check de <em>Cuenta para PUNTOS</em>. Para el check de
                                <em>Cuenta para GOLES</em> depende de cada organización: algunas solo
                                cuentan los goles del rol regular, otras cuentan hasta el último partido.
                            </div>
                        </div>

                        <div class="ayuda-section">
                            <h5>🗑️ Eliminar un juego</h5>
                            <p>
                                Haz clic en <strong>Eliminar</strong> en la fila del partido.
                                El sistema mostrará un mensaje de confirmación con los nombres de los equipos
                                antes de proceder. Solo puedes eliminar un juego que no tenga restricciones activas.
                            </p>
                            <div class="ayuda-tip ayuda-tip-warning">
                                ⚠️ Al eliminar un juego con estatus <strong>JUGADO</strong> y checks activos,
                                el sistema revierte automáticamente los puntos y goles que ese partido
                                había acumulado en las tablas.
                            </div>
                        </div>

                        <div class="ayuda-section">
                            <h5>📤 Exportar el listado</h5>
                            <p>Si tienes permiso, puedes exportar el listado de juegos en: <strong>Excel</strong>, <strong>Word</strong> y <strong>PDF</strong>.</p>
                        </div>

                        <div class="ayuda-section ayuda-section-faq">
                            <h5>❓ Preguntas frecuentes</h5>
                            <p><strong>¿Por qué un juego JUGADO no aparece en la tabla de posiciones?</strong><br />
                            Verifica que el check <em>Cuenta para PUNTOS</em> esté activado. Si está desactivado, el resultado no se contabiliza en posiciones aunque el estatus sea JUGADO.</p>
                            <p><strong>¿Puedo cambiar el resultado después de guardarlo?</strong><br />
                            Sí. Edita el juego, corrige los goles y el resultado, y vuelve a guardar. Las tablas se recalcularán automáticamente.</p>
                            <p><strong>¿Qué significa GP (Ganó por Penales)?</strong><br />
                            Indica que el equipo ganó el partido mediante tanda de penales. Suele usarse en fases eliminatorias donde el marcador quedó empatado al final del tiempo reglamentario.</p>
                            <p><strong>¿Qué son los Puntos Extra (PE)?</strong><br />
                            Son puntos adicionales que algunos torneos asignan por criterios especiales. Solo úsalos si el reglamento de tu torneo los contempla.</p>
                            <p><strong>¿Por qué no veo los botones de Agregar / Editar / Eliminar?</strong><br />
                            Tu usuario no tiene ese permiso asignado. Contacta al administrador del sistema.</p>
                        </div>

                    </div>

                    <div class="ayuda-modal-footer">
                        <button class="btn ayuda-btn-cerrar" @onclick="() => showHelp = false">Cerrar guía</button>
                    </div>

                </div>
            </div>
        }

    </Authorized>
</AuthorizeView>

<style>
