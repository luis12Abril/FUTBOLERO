@page "/ListaComunicado/{Id}"
@using FUTBOLERO.Shared
@inject HttpClient http
@inject IJSRuntime ijsruntime

@{
    string[] cabeceras = { "Fecha", "Comunicado" };
    string[] propiedades = { "fechacomunicadocadena", "comunicadocorto" };
}

<AuthorizeView>
    <Authorized>
        <section class="catalogo-page mt-3">
            <div class="catalogo-header-card">
                <div>
                    <p class="catalogo-kicker">Panel de administración</p>
                    <h3>Comunicados</h3>
                    <span>Administra y consulta los comunicados publicados para el torneo.</span>
                </div>
                <div class="catalogo-badge">
                    <span>Catálogo</span>
                </div>
            </div>

            @if (listadoComunicado == null)
            {
                <div class="catalogo-loading">
                    <div class="spinner-border text-primary" role="status"></div>
                    <span class="ml-2">Cargando comunicados...</span>
                </div>
            }
            else
            {
                <div class="catalogo-list-card">
                    <Listados cabeceras=cabeceras
                              nombrePropiedadesMostrar=propiedades
                              lista=listadoComunicado
                              type="text" button=false label="Encabezado"
                              eventBusqueda="BuscarListaComunicado"
                              permitirAgregar=@permitirAgregar rutaAgregar="AgregarComunicado"
                              permitirEditar=@permitirEditar rutaEditar="EditarComunicado"
                              permitirEliminar=@permitirEliminar eventEliminar="EliminarListaComunicado"
                              permitirExportarExcel=@permitirExportarExcel
                              permitirExportarWord=@permitirExportarWord
                              permitirExportarPdf=@permitirExportarPDF
                              tituloReporte="Listado de Jornadas"
                              botoneditinvitado=@esinvitado />
                </div>
            }
        </section>
    </Authorized>
</AuthorizeView>

<style>
    .catalogo-page {
        padding: 0.25rem 0;
    }

    .catalogo-header-card {
        display: flex;
        justify-content: space-between;
        align-items: center;
        gap: 1rem;
        background: linear-gradient(135deg, #eff6ff 0%, #eef2ff 45%, #f8fafc 100%);
        border: 1px solid #dbeafe;
        border-radius: 16px;
        padding: 1.1rem 1.25rem;
        margin-bottom: 1rem;
        box-shadow: 0 14px 28px rgba(30, 64, 175, 0.08);
    }

    .catalogo-kicker {
        margin: 0;
        color: #2563eb;
        font-size: 0.8rem;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .08em;
    }

    .catalogo-header-card h3 {
        margin: 0.15rem 0 0.25rem;
        color: #1e3a8a;
        font-weight: 800;
    }

    .catalogo-header-card span {
        color: #475569;
        font-size: 0.93rem;
    }

    .catalogo-badge span {
        display: inline-block;
        background: linear-gradient(90deg, #2563eb 0%, #1d4ed8 100%);
        color: #fff;
        border-radius: 999px;
        padding: 0.3rem 0.8rem;
        font-size: 0.78rem;
        font-weight: 700;
        box-shadow: 0 8px 18px rgba(37, 99, 235, 0.24);
    }

    .catalogo-list-card {
        background-color: #ffffff;
        border: 1px solid #e2e8f0;
        border-radius: 16px;
        padding: 0.75rem;
        box-shadow: 0 16px 32px rgba(15, 23, 42, 0.08);
    }

    .catalogo-loading {
        margin: 1.5rem 0;
        display: flex;
        align-items: center;
        justify-content: center;
        color: #1e3a8a;
        font-weight: 600;
    }

    @@media (max-width: 768px) {
        .catalogo-header-card {
            flex-direction: column;
            align-items: flex-start;
        }
    }
</style>

@code {
    public bool esinvitado = false;

    public string idtorneoseleccionado;

    public int idtipousuario { get; set; } = 2;

    public string torneoMensaje { get; set; }

    public ComunicadoCLS[] listadoComunicado;

    public ComunicadoCLS oComunicadoCLSBorrar = new ComunicadoCLS();         // ESTE LO PONGO PARA SACAR EL NOMBRE DEL COMUNICADO Y MANDARLA COMO PARAMETRO AL BORRAR

    [CascadingParameter]
    private Task<AuthenticationState> auth { get; set; }

    [CascadingParameter]
    public MisValoresCascada misvalorescascada { get; set; }

    [Parameter]
    public string Id { get; set; }

    public bool permitirAgregar = false;
    public bool permitirEditar = false;
    public bool permitirEliminar = false;
    public bool permitirExportarExcel = false;
    public bool permitirExportarWord = false;
    public bool permitirExportarPDF = false;

    List<int> listaBotones = new List<int>();


    protected override async Task OnInitializedAsync()
    {
        var authuser = await auth;
        var user = authuser.User;

        if (user.Identity.IsAuthenticated)
        {
            var claims = user.Claims.ToList();

            // AQUI ESTOY RECIBIENDO EN CADENA EL ID DEL TORNEO SELECCIONADO
            idtorneoseleccionado = claims[2].Value;

            listadoComunicado = await http.GetFromJsonAsync<ComunicadoCLS[]>("api/Comunicado/ListarComunicado/" + idtorneoseleccionado);

            if (user.Identity.IsAuthenticated)
            {
                int tipousu = misvalorescascada.idtipousuariocascada;

                idtipousuario = await http.GetFromJsonAsync<int>("api/PaginaTipoUsuario/puedeadministrar/" + user.Identity.Name + "/" + idtorneoseleccionado);

                misvalorescascada.idtipousuariocascada = idtipousuario;

                // 2 ES UN TIPOUSUARIO INVITADO, ES PARA CAMBIAR EL ENCABEZADO DE LA LISTA
                if (idtipousuario == 2)
                {
                    esinvitado = true;
                }

                listaBotones = await http.GetFromJsonAsync<List<int>>("api/PaginaTipoUsuario/listarBotones3/" + idtipousuario + "/" + Id);

                //listaBotones = await http.GetFromJsonAsync<List<int>>("api/PaginaTipoUsuario/listarBotones/" + user.Identity.Name + "/" + Id);

                if (listaBotones.Count() > 0)
                {
                    if (listaBotones.Contains(1)) permitirAgregar = true;
                    if (listaBotones.Contains(2)) permitirEditar = true;
                    if (listaBotones.Contains(3)) permitirEliminar = true;
                    if (listaBotones.Contains(4)) permitirExportarExcel = true;
                    if (listaBotones.Contains(5)) permitirExportarWord = true;
                    if (listaBotones.Contains(6)) permitirExportarPDF = true;
                }
            }
        }
    }


    public async Task BuscarListaComunicado(string buscarNombreComunicado)
    {
        if (buscarNombreComunicado == null || buscarNombreComunicado == "")
        {
            listadoComunicado = await http.GetFromJsonAsync<ComunicadoCLS[]>("api/Comunicado/ListarComunicado/" + idtorneoseleccionado);
        }
        else
        {
            listadoComunicado = await http.GetFromJsonAsync<ComunicadoCLS[]>("api/Comunicado/FiltrarComunicado/" + buscarNombreComunicado + "/" + idtorneoseleccionado);
        }
    }


    public async Task EliminarListaComunicado(string idComunicado)       // LO PONEMOS COMO STRING PORQUE EN EL LISTADOSRAZOR2 ESTA COMO STRING
    {

        oComunicadoCLSBorrar = await http.GetFromJsonAsync<ComunicadoCLS>("api/Comunicado/RecuperarInformacionComunicado/" + idComunicado);

        if (await ijsruntime.InvokeAsync<bool>("ConfirmarBorrar", "Confirmar", "VAS A BORRAR A: " + oComunicadoCLSBorrar.comunicadocorto, "warning"))
        {
            int rpta = await http.GetFromJsonAsync<int>("api/Comunicado/EliminarComunicado/" + idComunicado);

            // 0 = OCURRIO UN ERROR     1 = SE BORRO CORRECTAMENTE
            switch (rpta)
            {
                case 0:
                    await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "OCURRIO UN ERROR, NO SE PUDO BORRAR", "error");
                    break;
                case 1:
                    await ijsruntime.InvokeVoidAsync("MostrarMensajetime", "OK, LA JORNADA SE ELIMINO", "success", 2000);
                    listadoComunicado = await http.GetFromJsonAsync<ComunicadoCLS[]>("api/Comunicado/ListarComunicado/" + idtorneoseleccionado);
                    break;
                default:
                    break;
            }
        }
    }

}


