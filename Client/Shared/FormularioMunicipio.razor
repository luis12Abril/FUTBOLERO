@using FUTBOLERO.Shared
@inject HttpClient http
@inject NavigationManager navigation
@inject IJSRuntime ijsruntime


@if (oMunicipioCLS == null)
{
    <button class="btn btn-primary">
        <span class="spinner-border spinner-border-sm"></span>
        Cargando...
    </button>
}
else
{
    <EditForm Model="@oMunicipioCLS" OnValidSubmit="GuardarDatos">

        <DataAnnotationsValidator />
        @*<ValidationSummary />*@

        <div class="form-group">
            <label class=" font-weight-bold">Nombre *</label>
            <InputText class="form form-control" @bind-Value="oMunicipioCLS.nombre" />
            <ValidationMessage For="@(()=>oMunicipioCLS.nombre)" />
        </div>

        <div class="form-group">
            <label class=" font-weight-bold">Estados *</label>
            <InputSelect @bind-Value="oMunicipioCLS.idestado" class="form form-control">
                <option value="">--- Seleccione ---</option>
                @foreach (EstadoCLS oEstadoCLS in listaEstados)
                    {
                    <option value="@oEstadoCLS.idestado">@oEstadoCLS.nombre</option>
                    }
            </InputSelect>
            <ValidationMessage For="@(()=>oMunicipioCLS.idestado)" />
        </div>

        <input type="submit" value="Guardar" class="btn btn-success" />

        <NavLink href="@ruta">
            <input type="button" value="Regresar" class="btn btn-info" />
        </NavLink>

    </EditForm>
    <div class="mb-2"></div>
}


@code {

    [Parameter]
    public MunicipioCLS oMunicipioCLS { get; set; } = new MunicipioCLS();

    [Parameter]
    public List<EstadoCLS> listaEstados { get; set; }

    public string ruta { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState> auth { get; set; }


    protected override async Task OnInitializedAsync()
    {
        string paginaEnviar = "ListaMunicipio";
        int idPag = await http.GetFromJsonAsync<int>("api/Pagina/RecuperarIdPagina/" + paginaEnviar);
        ruta = paginaEnviar + "/" + idPag;
    }


    public async Task<bool> GuardarDatos()
    {
        var authuser = await auth;
        var user = authuser.User;

        var claims = user.Claims.ToList();
        var torneo = claims[1].Value;

        //oJugadorCLS.idtorneo = int.Parse(claims[2].Value);

        //oJugadorCLS.torneo = torneo;

        var resultado = await http.PostAsJsonAsync("api/Municipio/GuardarDatosMunicipio", oMunicipioCLS);
        var content = await resultado.Content.ReadFromJsonAsync<object>();
        int rpta = int.Parse(content.ToString());

        // 0 = OCURRIO UN ERROR     1 = SE GRABO CORRECTAMENTE      3 = ESE NOMBRE DE JUGADOR YA EXISTE
        switch (rpta)
        {
            case 0:
                await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "OCURRIO UN ERROR, NO SE GUARDARON LOS DATOS", "error");
                break;
            case 1:
                await ijsruntime.InvokeVoidAsync("MostrarMensajeGuardar", "OK, DATOS GUARDADOS", "success");
                break;
            case 3:
                await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "ESE NOMBRE DE MUNICIPIO YA EXISTE", "warning");
                break;
            default:
                break;
        }
        if (rpta == 1)
        {
            navigation.NavigateTo(ruta);
        }

        return await Task.FromResult(true);
    }
}


