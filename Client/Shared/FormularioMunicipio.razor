@using FUTBOLERO.Shared
@inject HttpClient http
@inject NavigationManager navigation
@inject IJSRuntime ijsruntime


@if (oMunicipioCLS == null)
{
    <div class="modern-form-wrapper">
        <div class="modern-form-card text-center py-5">
            <button class="btn btn-cargando" disabled>
                <span class="spinner-border spinner-border-sm me-2"></span>
                Cargando...
            </button>
        </div>
    </div>
}
else
{
    <div class="modern-form-wrapper">
        <div class="modern-form-card">
            <div class="modern-form-header">
                <h4 class="mb-1">Formulario de Municipio</h4>
                <p class="mb-0">Registre o actualice el municipio con su estado correspondiente.</p>
            </div>

            <EditForm Model="@oMunicipioCLS" OnValidSubmit="GuardarDatos" class="modern-form-body">
                <DataAnnotationsValidator />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="modern-label">Nombre *</label>
                        <InputText class="form-control modern-input" @bind-Value="oMunicipioCLS.nombre" />
                        <ValidationMessage For="@(()=>oMunicipioCLS.nombre)" />
                    </div>

                    <div class="col-md-6">
                        <label class="modern-label">Estados *</label>
                        <InputSelect @bind-Value="oMunicipioCLS.idestado" class="form-control modern-input">
                            <option value="">--- Seleccione ---</option>
                            @foreach (EstadoCLS oEstadoCLS in listaEstados)
                            {
                                <option value="@oEstadoCLS.idestado">@oEstadoCLS.nombre</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="@(()=>oMunicipioCLS.idestado)" />
                    </div>
                </div>

                <div class="modern-form-actions">
                    <button type="submit" class="btn btn-guardar">Guardar</button>
                    <NavLink href="@ruta" class="btn btn-regresar">Regresar</NavLink>
                </div>
            </EditForm>
        </div>
    </div>
}

<style>
    .modern-form-wrapper {
        padding: 1.25rem 0;
        background: linear-gradient(135deg, #f8fafc 0%, #eef6f5 100%);
        border-radius: 1.25rem;
    }

    .modern-form-card {
        max-width: 920px;
        margin: 0 auto;
        background: #ffffff;
        border: 1px solid #e9ecef;
        border-radius: 1.2rem;
        box-shadow: 0 10px 30px rgba(45, 64, 89, 0.08);
        overflow: hidden;
    }

    .modern-form-header {
        padding: 1.2rem 1.4rem;
        background: linear-gradient(120deg, #5faea0 0%, #7cc6b4 55%, #9bd8ca 100%);
        color: #ffffff;
    }

    .modern-form-body {
        padding: 1.4rem;
    }

    .modern-label {
        font-weight: 600;
        color: #2f3e46;
        margin-bottom: 0.35rem;
        display: inline-block;
    }

    .modern-input {
        border-radius: 0.65rem;
        border: 1px solid #d6dde3;
        min-height: 42px;
    }

    .modern-input:focus {
        border-color: #5faea0;
        box-shadow: 0 0 0 0.2rem rgba(95, 174, 160, 0.2);
    }

    .modern-form-actions {
        margin-top: 1.4rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.65rem;
    }

    .btn-guardar {
        background: linear-gradient(120deg, #42a890 0%, #5fb8a1 100%);
        border: none;
        color: #fff;
        border-radius: 0.65rem;
        padding: 0.45rem 1.2rem;
        font-weight: 600;
    }

    .btn-regresar {
        background: #edf2f7;
        color: #344054;
        border: 1px solid #d0d7de;
        border-radius: 0.65rem;
        padding: 0.45rem 1.2rem;
        font-weight: 600;
        text-decoration: none;
    }

    .btn-cargando {
        background: linear-gradient(120deg, #5faea0 0%, #7cc6b4 100%);
        border: none;
        color: #fff;
        border-radius: 0.65rem;
        padding: 0.5rem 1rem;
    }
</style>


@code {

    [Parameter]
    public MunicipioCLS oMunicipioCLS { get; set; } = new MunicipioCLS();

    [Parameter]
    public List<EstadoCLS> listaEstados { get; set; }

    public string ruta { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState> auth { get; set; }


    protected override async Task OnInitializedAsync()
    {
        string paginaEnviar = "ListaMunicipio";
        int idPag = await http.GetFromJsonAsync<int>("api/Pagina/RecuperarIdPagina/" + paginaEnviar);
        ruta = paginaEnviar + "/" + idPag;
    }


    public async Task<bool> GuardarDatos()
    {
        var authuser = await auth;
        var user = authuser.User;

        var claims = user.Claims.ToList();
        var torneo = claims[1].Value;

        //oJugadorCLS.idtorneo = int.Parse(claims[2].Value);

        //oJugadorCLS.torneo = torneo;

        var resultado = await http.PostAsJsonAsync("api/Municipio/GuardarDatosMunicipio", oMunicipioCLS);
        var content = await resultado.Content.ReadFromJsonAsync<object>();
        int rpta = int.Parse(content.ToString());

        // 0 = OCURRIO UN ERROR     1 = SE GRABO CORRECTAMENTE      3 = ESE NOMBRE DE JUGADOR YA EXISTE
        switch (rpta)
        {
            case 0:
                await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "OCURRIO UN ERROR, NO SE GUARDARON LOS DATOS", "error");
                break;
            case 1:
                await ijsruntime.InvokeVoidAsync("MostrarMensajeGuardar", "OK, DATOS GUARDADOS", "success");
                break;
            case 3:
                await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "ESE NOMBRE DE MUNICIPIO YA EXISTE", "warning");
                break;
            default:
                break;
        }
        if (rpta == 1)
        {
            navigation.NavigateTo(ruta);
        }

        return await Task.FromResult(true);
    }
}


