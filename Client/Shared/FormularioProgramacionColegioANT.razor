    public async Task<bool> GuardarDatos()
    {
        var authuser = await auth;
        var user = authuser.User;

        var claims = user.Claims.ToList();
        var torneo = claims[1].Value;

        //oJuegoCLS.idtorneo = int.Parse(claims[2].Value);

        //oJuegoCLS.torneo = torneo;

        oProgramacionColegioCLS.fhorario = horario;

        //oJuegoCLS.idusuario = int.Parse(user.Identity.Name);

        var resultado = await http.PostAsJsonAsync("api/ProgramacionColegio/GuardarDatosProgramacionColegio", oProgramacionColegioCLS);
        var content = await resultado.Content.ReadFromJsonAsync<object>();
        int rpta = int.Parse(content.ToString());

        // 0 = ERROR    1 = OK  3 = ERROR EN GOLES DE LOS DOS EQUIPOS   4 = ERROR EN GOLES DEL EQUIPO 01    5 = ERROR EN GOLES DEL EQUIPO 02
        // 6 = SE GRABO EL COMENTARIO   7 = EL COMENTARIO ESTA EN BLANCO    8 = SON MAS DE 50 MCOMENTARIOS  10 = ERROR EN LOS RADIOS
        // 11 Y 12 PENDIENTE DE REVISAR

        switch (rpta)
        {
            case 0:
                await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "ERROR, NO SE GUARDARON LOS DATOS", "error");
                break;
            case 1:
                await ijsruntime.InvokeVoidAsync("MostrarMensajeGuardar", "OK, DATOS GUARDADOS", "success");
                navigation.NavigateTo(ruta);
                break;

            default:
                break;
        }

        return await Task.FromResult(true);
    }





