@inject HttpClient http;
@using FUTBOLERO.Shared;

<AuthorizeView>
    <Authorized>

        <div class="top-row pl-3 pr-2 navbar navbar-dark sidebar-brand-row">
            <a class="navbar-brand" href="">
                <span class="brand-badge">F</span>
                <span>futboleando.com.mx</span>
            </a>
            <button class="navbar-toggler sidebar-toggler" @onclick="ToggleNavMenu">
                <span class="navbar-toggler-icon"></span>
            </button>
        </div>

        <div class="@NavMenuCssClass" @onclick="ToggleNavMenu">
            <ul class="nav flex-column sidebar-nav-list">

                @foreach (PaginaCLS oPaginaCLS in lista)
                {
                    <li class="nav-item px-2">
                        <NavLink class="nav-link" href="@oPaginaCLS.accion" Match="NavLinkMatch.All">
                            <span class="oi oi-home" aria-hidden="true"></span>
                            <span class="nav-link-text">@oPaginaCLS.mensaje</span>
                        </NavLink>
                    </li>
                }

                <li class="nav-item px-2 nav-submenu-parent" @onclick:stopPropagation="true">
                    <button class="@ClaseBotonDocumentos" @onclick="ToggleDocumentos" @onclick:stopPropagation="true">
                        <span class="oi oi-document" aria-hidden="true"></span>
                        <span class="nav-link-text">Documentos</span>
                        <span class="@ClaseChevronDocumentos">&#9660;</span>
                    </button>
                    @if (documentosExpanded)
                    {
                        <ul class="nav flex-column submenu-list">
                            <li class="nav-item">
                                <NavLink class="nav-link submenu-link" href="documentos/credenciales" Match="NavLinkMatch.All">
                                    <span class="oi oi-badge" aria-hidden="true"></span>
                                    <span class="nav-link-text">Credenciales</span>
                                </NavLink>
                            </li>
                            <li class="nav-item">
                                <NavLink class="nav-link submenu-link" href="documentos/lista-jugadores" Match="NavLinkMatch.All">
                                    <span class="oi oi-list" aria-hidden="true"></span>
                                    <span class="nav-link-text">Lista de Jugadores</span>
                                </NavLink>
                            </li>
                            <li class="nav-item">
                                <NavLink class="nav-link submenu-link" href="documentos/cedula-arbitral" Match="NavLinkMatch.All">
                                    <span class="oi oi-clipboard" aria-hidden="true"></span>
                                    <span class="nav-link-text">Cédula Arbitral</span>
                                </NavLink>
                            </li>
                        </ul>
                    }
                </li>

                <li class="nav-item px-2">
                    <NavLink class="nav-link" href="SimuladorProgramacion" Match="NavLinkMatch.All">
                        <span class="oi oi-calendar" aria-hidden="true"></span>
                        <span class="nav-link-text">Simulador de Programación</span>
                    </NavLink>
                </li>

                @if (esAdminCartera)
                {
                    <li class="nav-item px-2">
                        <NavLink class="nav-link" href="@($"ResumenPagosEquipos/{idtorneoseleccionado}")" Match="NavLinkMatch.All">
                            <span class="oi oi-dollar" aria-hidden="true"></span>
                            <span class="nav-link-text">Cartera / Pagos</span>
                        </NavLink>
                    </li>
                }

            </ul>
        </div>

    </Authorized>
</AuthorizeView>

@code {
    public string idtorneoseleccionado;
    public int idtipousuario = 0;
    public bool esAdminCartera = false;

    private bool collapseNavMenu = true;
    private bool documentosExpanded = false;

    private string ClaseBotonDocumentos => documentosExpanded
        ? "nav-link nav-link-submenu-btn submenu-btn-active"
        : "nav-link nav-link-submenu-btn";

    private string ClaseChevronDocumentos => documentosExpanded
        ? "submenu-chevron chevron-open"
        : "submenu-chevron";

    public string rutaPrincipal;

    List<PaginaCLS> lista = new List<PaginaCLS>();

    [CascadingParameter]
    private Task<AuthenticationState> auth { get; set; }

    private string NavMenuCssClass => collapseNavMenu ? "collapse" : null;


    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private void ToggleDocumentos()
    {
        documentosExpanded = !documentosExpanded;
    }


    protected override async Task OnInitializedAsync()
    {
        var authuser = await auth;
        var user = authuser.User;

        var claims = user.Claims.ToList();

        //if(claims != null)
        //{
        //    //var torneo = claims[1].Value;

        //    // AQUI ESTOY RECIENDO EN CADENA EL ID DE TORNEO SELECCIONADO
        //    idtorneoseleccionado = claims[2].Value;

        //    if (user.Identity.IsAuthenticated)
        //    {
        //        string iidUsuario = user.Identity.Name;

        //        // MANDO EL ID DEL USUARIO Y EL TORNEO SELECCIONADO PARA VER SI EL USUARIO SIGUE COMO ADMOINISTRADOR  O PASA A SER UN USUARIO INVITADO
        //        lista = await http.GetFromJsonAsync<List<PaginaCLS>>("api/Usuario/ListarPaginaPorTipoUsuario/" + iidUsuario + "/" + idtorneoseleccionado);
        //    }
        //}


        if (user.Identity.IsAuthenticated)
        {
            var torneo = claims[1].Value;

            // AQUI ESTOY RECIENDO EN CADENA EL ID DE TORNEO SELECCIONADO
            idtorneoseleccionado = claims[2].Value;

            // LEEMOS EL TIPO DE USUARIO DESDE EL CLAIM
            var claimTipo = claims.FirstOrDefault(c => c.Type == "idtipousuario");
            if (claimTipo != null) int.TryParse(claimTipo.Value, out idtipousuario);

            // LEEMOS SI EL USUARIO ES ADMINISTRADOR DE CARTERA DEL TORNEO SELECCIONADO
            var claimAdmin = claims.FirstOrDefault(c => c.Type == "esAdminCartera");
            esAdminCartera = claimAdmin?.Value == "1";

            string iidUsuario = user.Identity.Name;

            // MANDO EL ID DEL USUARIO Y EL TORNEO SELECCIONADO PARA VER SI EL USUARIO SIGUE COMO ADMOINISTRADOR  O PASA A SER UN USUARIO INVITADO
            lista = await http.GetFromJsonAsync<List<PaginaCLS>>("api/Usuario/ListarPaginaPorTipoUsuario/" + iidUsuario + "/" + idtorneoseleccionado);
        }
    }
}
