@using FUTBOLERO.Shared
@inject HttpClient http
@inject NavigationManager navigation
@inject IJSRuntime ijsruntime

@if (oJuegoInvitadoCLS == null)
{
    <div class="modern-form-wrapper">
        <div class="modern-form-card text-center py-5">
            <button class="btn btn-cargando" disabled>
                <span class="spinner-border spinner-border-sm me-2"></span>
                Cargando...
            </button>
        </div>
    </div>
}
else
{
    <div class="modern-form-wrapper">
        <div class="modern-form-card modern-form-card-lg">
            <div class="modern-form-header">
                <h4 class="mb-1">Detalle del Juego</h4>
                <p class="mb-0">Visualice el juego y envíe comentarios.</p>
            </div>

            <EditForm Model="@oJuegoInvitadoCLS" class="font-weight-bold modern-form-body" OnValidSubmit="GuardarDatosJuegoInvitado">
        <DataAnnotationsValidator />

        <div class="modern-form-actions">
            <NavLink href="@ruta" class="btn btn-regresar">Regresar</NavLink>
        </div>
        <div class="mb-4"></div>

        <div class="form-group row">
            <label class="col-md-2 col-form-label font-weight-bold">Jornada</label>
            <div class="col-lg-10">
                <InputText class="form-control font-weight-bold" readOnly @bind-Value="oJuegoInvitadoCLS.jornadacadena" />
            </div>
        </div>

        <div class="form-group row equipo-resultado-row g-2">
            <label class="col-md-2 col-form-label font-weight-bold">Equipo 01</label>
            <div class="col-lg-4 col-md-5">
                <InputText class="form-control form-control-sm font-weight-bold equipo-nombre-input" readOnly @bind-Value="oJuegoInvitadoCLS.equipo01cadena" />
            </div>

            <div class="col-lg-3 col-md-7">
                <div class="resultado-radio-group">
                    <label class="resultado-radio-item"><span>G</span><input class="font-weight-bold" type="radio" disabled name="final01" id="G01" /></label>
                    <label class="resultado-radio-item"><span>E</span><input type="radio" disabled name="final01" id="E01" /></label>
                    <label class="resultado-radio-item"><span>P</span><input type="radio" disabled name="final01" id="P01" /></label>
                    <label class="resultado-radio-item"><span>GP</span><input type="radio" disabled name="final01" id="GP01" /></label>
                    <label class="resultado-radio-item"><span>GA</span><input type="radio" disabled name="final01" id="GA01" /></label>
                </div>
            </div>

            <div class="col marcador-pe-wrapper">
                <div class="marcador-pe-group">
                    <label class="col-form-label font-weight-bold mb-0">Goles</label>
                    <InputText class="form-control font-weight-bold marcador-input" style="text-align:center" readOnly @bind-Value="oJuegoInvitadoCLS.golesequipo01" />

                    @* PUNTOS EXTRAS *@
                    <label class="col-form-label font-weight-bold mb-0">PE</label>
                    <InputNumber class="form-control font-weight-bold marcador-input" style="text-align:center" readOnly @bind-Value="oJuegoInvitadoCLS.peequipo01" min="0" />
                </div>
            </div>

        </div>


        <div class="form-group row equipo-resultado-row g-2">
            <label class="col-md-2 col-form-label font-weight-bold">Equipo 02</label>
            <div class="col-lg-4 col-md-5">
                <InputText class="form-control form-control-sm font-weight-bold equipo-nombre-input" readOnly @bind-Value="oJuegoInvitadoCLS.equipo02cadena" />
            </div>

            <div class="col-lg-3 col-md-7">
                <div class="resultado-radio-group">
                    <label class="resultado-radio-item"><span>G</span><input class="font-weight-bold" type="radio" disabled name="final02" id="G02" /></label>
                    <label class="resultado-radio-item"><span>E</span><input type="radio" disabled name="final02" id="E02" /></label>
                    <label class="resultado-radio-item"><span>P</span><input type="radio" disabled name="final02" id="P02" /></label>
                    <label class="resultado-radio-item"><span>GP</span><input type="radio" disabled name="final02" id="GP02" /></label>
                    <label class="resultado-radio-item"><span>GA</span><input type="radio" disabled name="final02" id="GA02" /></label>
                </div>
            </div>

            <div class="col marcador-pe-wrapper">
                <div class="marcador-pe-group">
                    <label class="col-form-label font-weight-bold mb-0">Goles</label>
                    <InputText class="form-control font-weight-bold marcador-input" style="text-align:center" readOnly @bind-Value="oJuegoInvitadoCLS.golesequipo02" />


                    @* PUNTOS EXTRAS *@
                    <label class="col-form-label font-weight-bold mb-0">PE</label>
                    <InputNumber class="form-control font-weight-bold marcador-input" style="text-align:center" readOnly @bind-Value="oJuegoInvitadoCLS.peequipo02" min="0" />
                </div>
            </div>


        </div>

        <div class="form-group row">
            <label class="col-md-2 col-form-label font-weight-bold">Campo</label>
            <div class="col-lg-10">
                <InputText class="form-control font-weight-bold" readOnly @bind-Value="oJuegoInvitadoCLS.campocadena" />
            </div>
        </div>

        <div class="form-group row">
            <label class="col-md-2 col-form-label font-weight-bold">Arbitro</label>
            <div class="col-lg-10">
                <InputText class="form-control font-weight-bold" readOnly @bind-Value="oJuegoInvitadoCLS.arbitrocadena" />
            </div>
        </div>

        <div class="form-group row">
            <label class="col-md-2 col-form-label font-weight-bold">Horario</label>
            <div class="col-lg-10">
                <InputText class="form-control font-weight-bold" readOnly @bind-Value="oJuegoInvitadoCLS.fhorariocadena" />
            </div>
        </div>

        <div class="form-group row">
            <label class="col-md-2 col-form-label font-weight-bold">Estatus</label>
            <div class="col-lg-10">
                <InputText class="form-control font-weight-bold" readOnly @bind-Value="oJuegoInvitadoCLS.estatusjuegocadena" />
            </div>
        </div>

        <ListadoJugadoresGolesInvitado oJuegoInvitadoCLS="oJuegoInvitadoCLS" />

        <div class="form-group row" style="margin-top:20px;">
            <label class="col-md-2 col-form-label font-weight-bold">Nuevo Comentario</label>
            <div class="col-lg-10">
                <InputTextArea class="form form-control" @bind-Value="oJuegoInvitadoCLS.comentario" />
                <ValidationMessage For="@(() => oJuegoInvitadoCLS.comentario)" />
            </div>
        </div>

        <div style="display:flex; flex-direction:column; justify-content:flex-start; align-items:flex-end;">
            <button type="submit" class="btn btn-guardar">Enviar Comentario</button>
        </div>

        <ListadoComentario oComentarioCLS="oComentarioCLS" />

        <div class="modern-form-actions">
            <NavLink href="@ruta" class="btn btn-regresar">Regresar</NavLink>
        </div>

            </EditForm>
        </div>
    </div>

    <div class="mb-4"></div>
}

<style>
    .modern-form-wrapper {
        padding: 1.25rem 0;
        background: linear-gradient(135deg, #f8fafc 0%, #eef6f5 100%);
        border-radius: 1.25rem;
    }

    .modern-form-card {
        max-width: 920px;
        margin: 0 auto;
        background: #ffffff;
        border: 1px solid #e9ecef;
        border-radius: 1.2rem;
        box-shadow: 0 10px 30px rgba(45, 64, 89, 0.08);
        overflow: hidden;
    }

    .modern-form-card-lg {
        max-width: 1220px;
    }

    .modern-form-header {
        padding: 1.2rem 1.4rem;
        background: linear-gradient(120deg, #5faea0 0%, #7cc6b4 55%, #9bd8ca 100%);
        color: #ffffff;
    }

    .modern-form-body {
        padding: 1.4rem;
    }

    .modern-form-actions {
        margin-top: 0.2rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.65rem;
    }

    .btn-guardar {
        background: linear-gradient(120deg, #42a890 0%, #5fb8a1 100%);
        border: none;
        color: #fff;
        border-radius: 0.65rem;
        padding: 0.45rem 1.2rem;
        font-weight: 600;
    }

    .btn-regresar {
        background: #edf2f7;
        color: #344054;
        border: 1px solid #d0d7de;
        border-radius: 0.65rem;
        padding: 0.45rem 1.2rem;
        font-weight: 600;
        text-decoration: none;
    }

    .btn-cargando {
        background: linear-gradient(120deg, #5faea0 0%, #7cc6b4 100%);
        border: none;
        color: #fff;
        border-radius: 0.65rem;
        padding: 0.5rem 1rem;
    }

    .equipo-resultado-row {
        align-items: center;
    }

    .resultado-radio-group {
        display: flex;
        align-items: center;
        gap: 0.9rem;
        flex-wrap: nowrap;
    }

    .resultado-radio-item {
        display: flex;
        align-items: center;
        gap: 0.3rem;
        margin: 0;
        font-weight: 600;
    }

    .resultado-radio-item input {
        margin: 0;
    }

    .equipo-nombre-input {
        max-width: 420px;
    }

    .marcador-input {
        width: 70px;
    }

    .marcador-pe-wrapper {
        display: flex;
        justify-content: flex-end;
    }

    .marcador-pe-group {
        display: flex;
        align-items: center;
        gap: 0.6rem;
        flex-wrap: nowrap;
        white-space: nowrap;
    }
</style>


@code {
    public int yaentro = 0;

    [Parameter]
    public JuegoInvitadoCLS oJuegoInvitadoCLS { get; set; } = new JuegoInvitadoCLS();

    [Parameter]
    public ComentarioCLS[] oComentarioCLS { get; set; }

    public string cometariojuego { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState> auth { get; set; }

    // AQUI VAN LOS PARAMETROS DE LOS COMBOS DEL FORMULARIO

    // ESTA VARIABLE ES PARA QUE MUESTRE EL CONTROL DE LOS GOLES EN CASO DE SER UN EDITAR

    public string ruta { get; set; }

    protected async override Task OnParametersSetAsync()
    {
        string paginaEnviar = "ListaJuegoInvitado";
        int idPag = await http.GetFromJsonAsync<int>("api/Pagina/RecuperarIdPagina/" + paginaEnviar);
        ruta = paginaEnviar + "/" + idPag;

        // ESTE IF ES PORQUE CUANDO ES NUEVO NO ESTAN ACTIVADOS LOS RADIOS Y POR ESO NO DEBE ENTRAR
        if (oJuegoInvitadoCLS.idjuego != 0 && oJuegoInvitadoCLS != null)
        {
            // ESTE IF ES PORQUE CUANDO LE DOY CLICK EN CERRAR SESION ME DA UN ERROR DE RELOAD PORQUE VUELVE A ENTRAR, NO LO PUDE ARREGLAR DE OTRO MODO
            if (yaentro == 0)
            {
                string valid01 = oJuegoInvitadoCLS.resequipo01.Trim() + "01";
                string valid02 = oJuegoInvitadoCLS.resequipo02.Trim() + "02";

                await ijsruntime.InvokeVoidAsync("PonChecked", valid01, valid02);
                yaentro = yaentro + 1;
            }
        }
    }

    public async Task<bool> GuardarDatosJuegoInvitado()
    {
        var authuser = await auth;
        var user = authuser.User;

        var claims = user.Claims.ToList();
        var torneo = claims[1].Value;

        oJuegoInvitadoCLS.idusuario = int.Parse(user.Identity.Name);

        var resultado = await http.PostAsJsonAsync("api/Comentario/GuardarComentarioJuegoInvitado", oJuegoInvitadoCLS);
        var content = await resultado.Content.ReadFromJsonAsync<object>();
        int rpta = int.Parse(content.ToString());

        // 0 = OCURRIO UN ERROR     1 = SE GRABO CORRECTAMENTE     2 = EXCEDIO EL NUMERO DE COMENTARIOS PARA ESE JUEGO (50)
        // 3 = EL COMENTARIO ESTA VACIO Y NO SE GRABO

        switch (rpta)
        {
            case 0:
                await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "OCURRIO UN ERROR, EL COMENTARIO NO SE GUARDO", "error");
                break;
            case 1:
                //await ijsruntime.InvokeVoidAsync("MostrarMensajeGuardar", "OK, EL COMENTARIO SE HA ENVIADO", "success");
                oJuegoInvitadoCLS.comentario = "";
                oComentarioCLS = await http.GetFromJsonAsync<ComentarioCLS[]>("api/Comentario/RecuperarTodosComentario/" + oJuegoInvitadoCLS.idjuego);
                break;
            case 2:
                await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "SE HA EXCEDIDO EL NUMERO MAXIMO DE COMENTARIOS PERMITIDOS", "warning");
                break;
            case 3:
                break;
            default:
                break;
        }

        return await Task.FromResult(true);
    }
}

