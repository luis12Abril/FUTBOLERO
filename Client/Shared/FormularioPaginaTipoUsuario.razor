@using FUTBOLERO.Shared
@inject HttpClient http
@inject NavigationManager navigation


@if (oPaginaTipoUsuarioCLS == null)
{
    <div class="modern-form-wrapper">
        <div class="modern-form-card text-center py-5">
            <button class="btn btn-cargando" disabled>
                <span class="spinner-border spinner-border-sm me-2"></span>
                Cargando...
            </button>
        </div>
    </div>
}
else
{
    <div class="modern-form-wrapper">
        <div class="modern-form-card">
            <div class="modern-form-header">
                <h4 class="mb-1">Formulario Página Tipo Usuario</h4>
                <p class="mb-0">Asigne los botones permitidos para este perfil de página.</p>
            </div>

            <EditForm Model="@oPaginaTipoUsuarioCLS" OnValidSubmit="GuardarDatos" class="modern-form-body">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="row g-3">
                    <div class="col-md-4">
                        <label class="modern-label">Id Página</label>
                        <InputNumber readOnly class="form-control modern-input" @bind-Value="oPaginaTipoUsuarioCLS.idpaginatipousuario" />
                    </div>

                    <div class="col-12">
                        <label class="modern-label">Ingrese botones a seleccionar</label>
                        <div class="modern-table-wrapper">
                            <table class="table table-hover modern-table mb-0">
                                <thead>
                                    <tr>
                                        <td>Opción</td>
                                        <td>Nombre Botón</td>
                                    </tr>
                                </thead>

                                <tbody>
                                    @foreach (BotonesCLS oBotonesCLS in listaBoton)
                                    {
                                        <tr>
                                            <td>
                                                @if (oPaginaTipoUsuarioCLS.idboton.Contains(oBotonesCLS.idboton))
                                                {
                                                    <input type="checkbox" class="modern-check" checked @onchange="@(()=>CambiarValor(oBotonesCLS.idboton))" />
                                                }
                                                else
                                                {
                                                    <input type="checkbox" class="modern-check" @onchange="@(()=>CambiarValor(oBotonesCLS.idboton))" />
                                                }
                                            </td>
                                            <td>@oBotonesCLS.nombre</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                </div>

                <div class="modern-form-actions">
                    <button type="submit" class="btn btn-guardar">Guardar</button>
                    <NavLink href="@ruta" class="btn btn-regresar">Regresar</NavLink>
                </div>
            </EditForm>
        </div>
    </div>
}

<style>
    .modern-form-wrapper {
        padding: 1.25rem 0;
        background: linear-gradient(135deg, #f8fafc 0%, #eef6f5 100%);
        border-radius: 1.25rem;
    }

    .modern-form-card {
        max-width: 920px;
        margin: 0 auto;
        background: #ffffff;
        border: 1px solid #e9ecef;
        border-radius: 1.2rem;
        box-shadow: 0 10px 30px rgba(45, 64, 89, 0.08);
        overflow: hidden;
    }

    .modern-form-header {
        padding: 1.2rem 1.4rem;
        background: linear-gradient(120deg, #5faea0 0%, #7cc6b4 55%, #9bd8ca 100%);
        color: #ffffff;
    }

    .modern-form-body {
        padding: 1.4rem;
    }

    .modern-label {
        font-weight: 600;
        color: #2f3e46;
        margin-bottom: 0.35rem;
        display: inline-block;
    }

    .modern-input {
        border-radius: 0.65rem;
        border: 1px solid #d6dde3;
        min-height: 42px;
    }

    .modern-input:focus {
        border-color: #5faea0;
        box-shadow: 0 0 0 0.2rem rgba(95, 174, 160, 0.2);
    }

    .modern-table-wrapper {
        border: 1px solid #e4e9ef;
        border-radius: 0.8rem;
        overflow: hidden;
        background: #fff;
    }

    .modern-table thead {
        background: #f1f5f9;
        font-weight: 600;
    }

    .modern-check {
        width: 18px;
        height: 18px;
        accent-color: #4faa96;
    }

    .modern-form-actions {
        margin-top: 1.4rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.65rem;
    }

    .btn-guardar {
        background: linear-gradient(120deg, #42a890 0%, #5fb8a1 100%);
        border: none;
        color: #fff;
        border-radius: 0.65rem;
        padding: 0.45rem 1.2rem;
        font-weight: 600;
    }

    .btn-regresar {
        background: #edf2f7;
        color: #344054;
        border: 1px solid #d0d7de;
        border-radius: 0.65rem;
        padding: 0.45rem 1.2rem;
        font-weight: 600;
        text-decoration: none;
    }

    .btn-cargando {
        background: linear-gradient(120deg, #5faea0 0%, #7cc6b4 100%);
        border: none;
        color: #fff;
        border-radius: 0.65rem;
        padding: 0.5rem 1rem;
    }
</style>

@code {
    [Parameter]
    public PaginaTipoUsuarioCLS oPaginaTipoUsuarioCLS { get; set; } = new PaginaTipoUsuarioCLS();

    public List<BotonesCLS> listaBoton = new List<BotonesCLS>();

    public string ruta { get; set; }


    protected override async Task OnInitializedAsync()
    {
        listaBoton = await http.GetFromJsonAsync<List<BotonesCLS>>("api/PaginaTipoUsuario/ListarBotones");
        //oPagTipoUsuarioCLS = await http.GetFromJsonAsync<PaginaTipoUsuarioCLS>("api/PaginaTipoUsuario/RecuperarBotones/+Id");

        string paginaEnviar = "ListaPaginaTipoUsuarioBoton";
        int idPag = await http.GetFromJsonAsync<int>("api/Pagina/RecuperarIdPagina/" + paginaEnviar);
        ruta = paginaEnviar + "/" + idPag;
    }


    public async Task GuardarDatos()
    {
        var resultado = await http.PostAsJsonAsync("api/PaginaTipoUsuario/GuardarDatosPaginaTipoUsuario", oPaginaTipoUsuarioCLS);
        var content = await resultado.Content.ReadFromJsonAsync<object>();
        int rpta = int.Parse(content.ToString());

        if (rpta == 1)
        {
            navigation.NavigateTo(ruta);
        }
    }


    public void CambiarValor(int iidButton)
    {
        if (oPaginaTipoUsuarioCLS.idboton.Contains(iidButton))
        {
            oPaginaTipoUsuarioCLS.idboton.Remove(iidButton);
        }
        else
        {
            oPaginaTipoUsuarioCLS.idboton.Add(iidButton);
        }
    }
}
