@using FUTBOLERO.Shared
@inject HttpClient http
@inject NavigationManager navigation


@if (oTipoUsuarioCLS == null)
{
    <button class="btn btn-primary">
        <span class="spinner-border spinner-border-sm"></span>
        Cargando...
    </button>
}
else
{
    <EditForm Model="@oTipoUsuarioCLS" OnValidSubmit="GuardarTipoUsuarioFormulario">
        <DataAnnotationsValidator />
        @*<ValidationSummary />*@

        <div class="form-group">
            <label class=" font-weight-bold">Id Tipo Usuario</label>
            <InputNumber readOnly @bind-Value="oTipoUsuarioCLS.iidTipoUsuario" class="form form-control" />
        </div>

        <div class="form-group">
            <label class=" font-weight-bold">Nombre *</label>
            <InputText @bind-Value="oTipoUsuarioCLS.nombre" class="form form-control" />
            <ValidationMessage For="@(()=>oTipoUsuarioCLS.nombre)" />
        </div>

        <div class="form-group">
            <label class=" font-weight-bold">Descrpción *</label>
            <InputTextArea @bind-Value="oTipoUsuarioCLS.descripcion" class="form form-control" />
            <ValidationMessage For="@(()=>oTipoUsuarioCLS.descripcion)" />
        </div>

        <div class="form-group">
            <label class=" font-weight-bold">Seleccione las páginas</label>
            <table class="table">
                <thead>
                    <tr>
                        <td>Opción</td>
                        <td>Nombre Página</td>
                    </tr>
                </thead>
                <tbody>
                    @foreach (PaginaCLS oPagina in pagina)
                    {
                        <tr>
                            <td>
                                @if (oTipoUsuarioCLS.listaid.Contains(oPagina.idpagina))
                                {
                                    <input type="checkbox" checked @onchange="@(()=>CambiarValor(oPagina.idpagina))" />
                                }
                                else
                                {
                                    <input type="checkbox" @onchange="@(()=>CambiarValor(oPagina.idpagina))" />
                                }
                            </td>
                            <td>@oPagina.mensaje</td>
                        </tr>
                    }
                </tbody>
            </table>
        </div>

        <input type="submit" value="Guardar" class="btn btn-success" />

        <NavLink href="@ruta">
            <input type="button" value="Regresar" class="btn btn-info" />
        </NavLink>


    </EditForm>
    <div class="mb-2"></div>
}

@code {
    [Parameter]
    public TipoUsuarioCLS oTipoUsuarioCLS { get; set; } = new TipoUsuarioCLS();

    public List<PaginaCLS> pagina = new List<PaginaCLS>();

    public string ruta { get; set; }


    protected override async Task OnInitializedAsync()
    {
        pagina = await http.GetFromJsonAsync<List<PaginaCLS>>("api/pagina/listarPagina");
        string paginaEnviar = "ListaTipoUsuario";
        int idPag = await http.GetFromJsonAsync<int>("api/Pagina/RecuperarIdPagina/" + paginaEnviar);
        ruta = paginaEnviar + "/" + idPag;
    }


    public async Task GuardarTipoUsuarioFormulario()
    {
        var resultado = await http.PostAsJsonAsync("api/TipoUsuario/GuardarDatosTipoUsuario", oTipoUsuarioCLS);
        var content = await resultado.Content.ReadFromJsonAsync<object>();
        int rpta = int.Parse(content.ToString());

        if (rpta == 1)
        {
            navigation.NavigateTo(ruta);
        }
    }


    public void CambiarValor(int id)
    {
        if (oTipoUsuarioCLS.listaid.Contains(id))
        {
            oTipoUsuarioCLS.listaid.Remove(id);
        }
        else
        {
            oTipoUsuarioCLS.listaid.Add(id);
        }
    }
}

