@using FUTBOLERO.Shared
@inject HttpClient http
@inject NavigationManager navigation
@inject IJSRuntime ijsruntime


@if (oTorneoCLS == null)
{
    <div class="modern-form-wrapper">
        <div class="modern-form-card text-center py-5">
            <button class="btn btn-cargando" disabled>
                <span class="spinner-border spinner-border-sm me-2"></span>
                Cargando...
            </button>
        </div>
    </div>
}
else
{
    <div class="modern-form-wrapper">
        <div class="modern-form-card">
            <div class="modern-form-header">
                <h4 class="mb-1">Formulario de Torneo</h4>
                <p class="mb-0">Registre el torneo y configure su visibilidad en el sistema.</p>
            </div>

            <EditForm Model="@oTorneoCLS" OnValidSubmit="GuardarDatosFTorneo" class="modern-form-body">
                <DataAnnotationsValidator />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="modern-label">Nombre *</label>
                        <InputText class="form-control modern-input" @bind-Value="oTorneoCLS.nombre" />
                        <ValidationMessage For="@(() => oTorneoCLS.nombre)" />
                    </div>

                    <div class="col-md-6">
                        <label class="modern-label">Ligas *</label>
                        <InputSelect @bind-Value="oTorneoCLS.idliga" class="form-control modern-input">
                            <option value="">--- Seleccione ---</option>
                            @foreach (LigaCLS oLigaCLS in listaLigas)
                            {
                                <option value="@oLigaCLS.idliga">@oLigaCLS.nombre</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="@(()=>oTorneoCLS.idliga)" />
                    </div>

                    <div class="col-md-4">
                        <label class="modern-label">Orden en que se mostrará *</label>
                        <InputNumber class="form-control modern-input" @bind-Value="oTorneoCLS.ordentorneo" min="1" />
                    </div>

                    <div class="col-md-3 d-flex align-items-end">
                        <div class="modern-checkbox-wrap">
                            <InputCheckbox @bind-Value="@oTorneoCLS.visible" class="modern-check" />
                            <label class="modern-checkbox-label">Visible</label>
                        </div>
                    </div>
                </div>

                <div class="modern-form-actions">
                    <button type="submit" class="btn btn-guardar">Guardar</button>
                    <NavLink href="@ruta" class="btn btn-regresar">Regresar</NavLink>
                </div>
            </EditForm>
        </div>
    </div>
}

<style>
    .modern-form-wrapper {
        padding: 1.25rem 0;
        background: linear-gradient(135deg, #f8fafc 0%, #eef6f5 100%);
        border-radius: 1.25rem;
    }

    .modern-form-card {
        max-width: 920px;
        margin: 0 auto;
        background: #ffffff;
        border: 1px solid #e9ecef;
        border-radius: 1.2rem;
        box-shadow: 0 10px 30px rgba(45, 64, 89, 0.08);
        overflow: hidden;
    }

    .modern-form-header {
        padding: 1.2rem 1.4rem;
        background: linear-gradient(120deg, #5faea0 0%, #7cc6b4 55%, #9bd8ca 100%);
        color: #ffffff;
    }

    .modern-form-body {
        padding: 1.4rem;
    }

    .modern-label {
        font-weight: 600;
        color: #2f3e46;
        margin-bottom: 0.35rem;
        display: inline-block;
    }

    .modern-input {
        border-radius: 0.65rem;
        border: 1px solid #d6dde3;
        min-height: 42px;
    }

    .modern-input:focus {
        border-color: #5faea0;
        box-shadow: 0 0 0 0.2rem rgba(95, 174, 160, 0.2);
    }

    .modern-checkbox-wrap {
        display: flex;
        align-items: center;
        gap: 0.5rem;
        background: #f8fafc;
        border: 1px solid #d6dde3;
        border-radius: 0.65rem;
        padding: 0.55rem 0.8rem;
        width: 100%;
    }

    .modern-check {
        width: 18px;
        height: 18px;
        accent-color: #4faa96;
    }

    .modern-checkbox-label {
        margin: 0;
        font-weight: 600;
        color: #2f3e46;
    }

    .modern-form-actions {
        margin-top: 1.4rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.65rem;
    }

    .btn-guardar {
        background: linear-gradient(120deg, #42a890 0%, #5fb8a1 100%);
        border: none;
        color: #fff;
        border-radius: 0.65rem;
        padding: 0.45rem 1.2rem;
        font-weight: 600;
    }

    .btn-regresar {
        background: #edf2f7;
        color: #344054;
        border: 1px solid #d0d7de;
        border-radius: 0.65rem;
        padding: 0.45rem 1.2rem;
        font-weight: 600;
        text-decoration: none;
    }

    .btn-cargando {
        background: linear-gradient(120deg, #5faea0 0%, #7cc6b4 100%);
        border: none;
        color: #fff;
        border-radius: 0.65rem;
        padding: 0.5rem 1rem;
    }
</style>


@code {

    public bool semodifica { get; set; } = true;

    [Parameter]
    public TorneoCLS oTorneoCLS { get; set; } = new TorneoCLS();

    [Parameter]
    public List<LigaCLS> listaLigas { get; set; }

    public string ruta { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState> auth { get; set; }

    protected override async Task OnParametersSetAsync()
    {
        string paginaEnviar = "ListaTorneo";
        int idPag = await http.GetFromJsonAsync<int>("api/Pagina/RecuperarIdPagina/" + paginaEnviar);
        ruta = paginaEnviar + "/" + idPag;
    }


    public async Task<bool> GuardarDatosFTorneo()
    {
        var authuser = await auth;
        var user = authuser.User;

        var claims = user.Claims.ToList();
        var torneo = claims[1].Value;

        var resultado = await http.PostAsJsonAsync("api/Torneo/GuardarDatosTorneo", oTorneoCLS);
        var content = await resultado.Content.ReadFromJsonAsync<object>();
        int rpta = int.Parse(content.ToString());

        // 0 = OCURRIO UN ERROR     1 = SE BORRO ON     2 = HAY JUEGOS CON ESE Torneo
        switch (rpta)
        {
            case 1:
                await ijsruntime.InvokeVoidAsync("MostrarMensajeGuardar", "Ok, datos guardados", "success");
                navigation.NavigateTo(ruta);
                break;
            case 100:
                await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "Ocurrio un error, no se guardaron los datos", "error");
                break;
            default:
                break;
        }

        return await Task.FromResult(true);
    }
}

