@using FUTBOLERO.Shared
@inject HttpClient http
@inject NavigationManager navigation
@inject IJSRuntime ijsruntime


@if (oArbitroCLS == null)
{
    <div class="modern-form-wrapper">
        <div class="modern-form-card text-center py-5">
            <button class="btn btn-cargando" disabled>
                <span class="spinner-border spinner-border-sm me-2"></span>
                Cargando...
            </button>
        </div>
    </div>
}
else
{
    <div class="modern-form-wrapper">
        <div class="modern-form-card">
            <div class="modern-form-header">
                <h4 class="mb-1">Formulario de Árbitro</h4>
                <p class="mb-0">Registre o actualice la información del árbitro.</p>
            </div>

            <EditForm Model="@oArbitroCLS" OnValidSubmit="GuardarDatos" class="modern-form-body">
                <DataAnnotationsValidator />

                <div class="row g-3">
                    <div class="col-md-4">
                        @if (semodifica)
                        {
                            <label class="modern-label">Nombre *</label>
                            <InputText class="form-control modern-input" @bind-Value="oArbitroCLS.nombre" />
                            <ValidationMessage For="@(() => oArbitroCLS.nombre)" />
                        }
                        else
                        {
                            <label class="modern-label">Nombre</label>
                            <InputText class="form-control modern-input" @bind-Value="oArbitroCLS.nombre" readOnly />
                        }
                    </div>

                    <div class="col-md-4">
                        @if (semodifica)
                        {
                            <label class="modern-label">Apellido Paterno *</label>
                            <InputText class="form-control modern-input" @bind-Value="oArbitroCLS.appaterno" />
                            <ValidationMessage For="@(() => oArbitroCLS.appaterno)" />
                        }
                        else
                        {
                            <label class="modern-label">Apellido Paterno</label>
                            <InputText class="form-control modern-input" @bind-Value="oArbitroCLS.appaterno" readOnly />
                        }
                    </div>

                    <div class="col-md-4">
                        @if (semodifica)
                        {
                            <label class="modern-label">Apellido Materno</label>
                            <InputText class="form-control modern-input" @bind-Value="oArbitroCLS.apmaterno" />
                            <ValidationMessage For="@(() => oArbitroCLS.apmaterno)" />
                        }
                        else
                        {
                            <label class="modern-label">Apellido Materno</label>
                            <InputText class="form-control modern-input" @bind-Value="oArbitroCLS.apmaterno" readOnly />
                        }
                    </div>
                </div>

                <div class="modern-form-actions">
                    <button type="submit" class="btn btn-guardar">Guardar</button>
                    <NavLink href="@ruta" class="btn btn-regresar">Regresar</NavLink>
                </div>
            </EditForm>
        </div>
    </div>
}

<style>
    .modern-form-wrapper {
        padding: 1.25rem 0;
        background: linear-gradient(135deg, #f8fafc 0%, #eef6f5 100%);
        border-radius: 1.25rem;
    }

    .modern-form-card {
        max-width: 920px;
        margin: 0 auto;
        background: #ffffff;
        border: 1px solid #e9ecef;
        border-radius: 1.2rem;
        box-shadow: 0 10px 30px rgba(45, 64, 89, 0.08);
        overflow: hidden;
    }

    .modern-form-header {
        padding: 1.2rem 1.4rem;
        background: linear-gradient(120deg, #5faea0 0%, #7cc6b4 55%, #9bd8ca 100%);
        color: #ffffff;
    }

    .modern-form-body {
        padding: 1.4rem;
    }

    .modern-label {
        font-weight: 600;
        color: #2f3e46;
        margin-bottom: 0.35rem;
        display: inline-block;
    }

    .modern-input {
        border-radius: 0.65rem;
        border: 1px solid #d6dde3;
        min-height: 42px;
    }

    .modern-input:focus {
        border-color: #5faea0;
        box-shadow: 0 0 0 0.2rem rgba(95, 174, 160, 0.2);
    }

    .modern-form-actions {
        margin-top: 1.4rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.65rem;
    }

    .btn-guardar {
        background: linear-gradient(120deg, #42a890 0%, #5fb8a1 100%);
        border: none;
        color: #fff;
        border-radius: 0.65rem;
        padding: 0.45rem 1.2rem;
        font-weight: 600;
    }

    .btn-regresar {
        background: #edf2f7;
        color: #344054;
        border: 1px solid #d0d7de;
        border-radius: 0.65rem;
        padding: 0.45rem 1.2rem;
        font-weight: 600;
        text-decoration: none;
    }

    .btn-cargando {
        background: linear-gradient(120deg, #5faea0 0%, #7cc6b4 100%);
        border: none;
        color: #fff;
        border-radius: 0.65rem;
        padding: 0.5rem 1rem;
    }
</style>

@code {
    [Parameter]
    public bool semodifica { get; set; } = true;

    [Parameter]
    public ArbitroCLS oArbitroCLS { get; set; } = new ArbitroCLS();

    public string ruta { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState> auth { get; set; }


    protected override async Task OnParametersSetAsync()
    {
        string paginaEnviar = "ListaArbitro";
        int idPag = await http.GetFromJsonAsync<int>("api/Pagina/RecuperarIdPagina/" + paginaEnviar);
        ruta = paginaEnviar + "/" + idPag;

        if (oArbitroCLS.idarbitro > 0)
        {
            if (oArbitroCLS.nombre.Contains("PENDIENTE"))
            {
                semodifica = false;
            }
        }
    }


    public async Task<bool> GuardarDatos()
    {
        var authuser = await auth;
        var user = authuser.User;

        var claims = user.Claims.ToList();
        var torneo = claims[1].Value;

        oArbitroCLS.torneo = torneo;

        oArbitroCLS.idtorneo = int.Parse(claims[2].Value);

        var resultado = await http.PostAsJsonAsync("api/Arbitro/GuardarDatosArbitro", oArbitroCLS);
        var content = await resultado.Content.ReadFromJsonAsync<object>();
        int rpta = int.Parse(content.ToString());

        // 0 = OCURRIO UN ERROR     1 = SE GRABO CORRECTAMENTE     2 = ES EL ARBITRO PENDIENTE ( NO SE DEBE MODIFICAR)
        // 3 = ESE NOMBRE DE ARBITRO YA EXISTE      // 4 =  EL NOMBRE DE ARBITRO PENDIENTE NO SE DEBBE AGREGAR
        switch (rpta)
        {
            case 0:
                await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "OCURRIO UN ERROR, NO SE GUARDARON LOS DATOS", "error");
                break;
            case 1:
                await ijsruntime.InvokeVoidAsync("MostrarMensajeGuardar", "OK, DATOS GUARDADOS", "success");
                break;
            case 2:
                await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "PENDIENTE NO DEBE MODIFICAR", "warning");
                break;
            case 3:
                await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "ESE NOMBRE DE ARBITRO YA EXISTE", "warning");
                break;
            case 4:
                await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "ESE NOMBRE DE ARBITRO PENDIENTE NO SE DEBE AGREGAR", "warning");
                break;
            default:
                break;
        }
        if (rpta == 1)
        {
            navigation.NavigateTo(ruta);
        }

        return await Task.FromResult(true);
    }
}

