@using FUTBOLERO.Shared
@inject HttpClient http
@inject NavigationManager navegarA
@inject IJSRuntime ijsruntime
@*ES DE PRUEBA, NO QUIERO QUE ME PINTE EL MENU LATERAL*@
@*@layout LoginLayout*@

@if (oNuevoUsuarioCLS == null)
{
    <div class="registro-wrapper">
        <div class="registro-card text-center py-5">
            <button class="btn btn-cargando" disabled>
                <span class="spinner-border spinner-border-sm me-2"></span>
                Cargando...
            </button>
        </div>
    </div>
}
else
{
    <div class="registro-wrapper">
        <div class="registro-card">
            <EditForm Model="@oNuevoUsuarioCLS" OnValidSubmit="GuardarDatosFormulario" class="registro-body">
                <DataAnnotationsValidator />

                <div class="text-center">
                    <img class="registro-logo" src="images/FUTBOLEANDO0.jpg" />
                </div>

                <h1 class="registro-title">Crear cuenta</h1>
                <p class="registro-subtitle">Registra tus credenciales para comenzar.</p>

                <div class="form-group mb-3">
                    <label class="registro-label">Usuario *</label>
                    <InputText class="form-control registro-input" @bind-Value="oNuevoUsuarioCLS.nombreusuario" />
                    <ValidationMessage For="@(() => oNuevoUsuarioCLS.nombreusuario)" />
                </div>

                <div class="form-group mb-3">
                    <label class="registro-label">Contraseña *</label>
                    <InputText type="password" class="form-control registro-input" @bind-Value="oNuevoUsuarioCLS.contra" />
                    <ValidationMessage For="@(() => oNuevoUsuarioCLS.contra)" />
                </div>

                <button type="submit" class="btn btn-guardar btn-block">Guardar</button>

                <div class="registro-actions">
                    <NavLink href="/" class="btn btn-regresar btn-block">Regresar al inicio</NavLink>
                </div>
            </EditForm>
        </div>
    </div>
    <div class="mb-2"></div>
}

<style>
    .registro-wrapper {
        min-height: 100vh;
        display: flex;
        justify-content: center;
        align-items: center;
        padding: 1.25rem;
        background: linear-gradient(180deg, #eef2ff 0%, #f3e8ff 100%);
    }

    .registro-card {
        width: 100%;
        max-width: 520px;
        background: #ffffff;
        border-radius: 16px;
        padding: 2rem;
        box-shadow: 0 12px 30px rgba(0, 0, 0, 0.10);
    }

    .registro-body {
        padding: 0;
    }

    .registro-logo {
        max-width: 55%;
        margin-bottom: 0.65rem;
    }

    .registro-title {
        text-align: center;
        color: #1d4ed8;
        font-size: 2rem;
        font-weight: 700;
        margin-bottom: 0.2rem;
    }

    .registro-subtitle {
        text-align: center;
        color: #6b7280;
        margin-bottom: 1.25rem;
    }

    .registro-label {
        font-weight: 700;
        color: #111827;
        margin-bottom: 0.35rem;
        display: inline-block;
    }

    .registro-input {
        border-radius: 8px;
        border: 1px solid #cbd5e1;
        min-height: 42px;
    }

    .registro-input:focus {
        border-color: #60a5fa;
        box-shadow: 0 0 0 0.2rem rgba(96, 165, 250, 0.2);
    }

    .registro-actions {
        margin-top: 0.9rem;
        display: flex;
        justify-content: center;
    }

    .btn-guardar {
        background: linear-gradient(120deg, #16a34a 0%, #22c55e 100%);
        border: none;
        color: #fff;
        border-radius: 8px;
        padding: 0.55rem 1.2rem;
        font-weight: 600;
    }

    .btn-regresar {
        background: #2563eb;
        color: #ffffff;
        border: none;
        border-radius: 8px;
        padding: 0.55rem 1.2rem;
        font-weight: 600;
        text-decoration: none;
        width: 220px;
        text-align: center;
    }

    .btn-cargando {
        background: linear-gradient(120deg, #2563eb 0%, #3b82f6 100%);
        border: none;
        color: #fff;
        border-radius: 0.65rem;
        padding: 0.55rem 1rem;
    }
</style>


@code {

    [Parameter]
    public NuevoUsuarioCLS oNuevoUsuarioCLS { get; set; } = new NuevoUsuarioCLS();

    public async Task<bool> GuardarDatosFormulario()
    {
        var resultado = await http.PostAsJsonAsync("api/Usuario/GuardarDatosNuevoUsuario", oNuevoUsuarioCLS);
        var content = await resultado.Content.ReadFromJsonAsync<object>();
        int rpta = int.Parse(content.ToString());

        switch (rpta)
        {
            case 0:
                await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "Error, NO se pudo registrar", "error");
                break;
            case 1:
                await ijsruntime.InvokeVoidAsync("MostrarMensajetime", "Ok, Registro aceptado", "success", 2000);

                //AQUI LE DIGO A QUE PAGINA DEBE IR CUANDO LA CLAVE Y CONTRASEÑA SEAN CORRECTAS
                //string paginaEnviar = "SeleccioneTorneo";


                //AQUI VOY Y BUSCO EN EL CONTROLADO LA PAGINA DESEADA Y EL ME REGRESARA EL IDPAGINA QUE TENGA EN LA TABLA
                ////int idPag = await http.GetFromJsonAsync<int>("api/Pagina/RecuperarIdPagina/" + paginaEnviar);

                // AQUI ARMO LA RUTA A LA QUE VA A NAVEGAR EJ. navigate.NavigateTo("SeleccioneTorneo/3")
                ////string ruta = paginaEnviar + "/" + idPag;
                navegarA.NavigateTo("/");

                //navigation.NavigateTo("/");
                break;
            case 2:
                await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "El usuario " + oNuevoUsuarioCLS.nombreusuario + " ya esta registrado", "error");
                break;
            default:
                break;
        }

        return await Task.FromResult(true);
    }
}

