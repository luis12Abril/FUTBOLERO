@using FUTBOLERO.Shared
@inject HttpClient http
@inject NavigationManager navigation                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                                             
@inject IJSRuntime ijsruntime


@if (oJugadorCLS == null)
{
    <div class="jugador-form-wrapper">
        <div class="jugador-form-card text-center py-5">
            <button class="btn btn-cargando" disabled>
                <span class="spinner-border spinner-border-sm me-2"></span>
                Cargando...
            </button>
        </div>
    </div>
}
else
{
    <div class="jugador-form-wrapper">
        <div class="jugador-form-card">
            <div class="jugador-form-header">
                <h4 class="mb-1">Formulario de Jugador</h4>
                <p class="mb-0">Complete los datos para registrar o actualizar un jugador.</p>
            </div>

            <EditForm Model="@oJugadorCLS" OnValidSubmit="GuardarDatos" class="jugador-form-body">
                <DataAnnotationsValidator />

                <div class="row g-3">
                    <div class="col-md-6">
                        <label class="modern-label">Nombre *</label>
                        <InputText class="form-control modern-input" @bind-Value="oJugadorCLS.nombre" />
                        <ValidationMessage For="@(()=>oJugadorCLS.nombre)" />
                    </div>

                    <div class="col-md-6">
                        <label class="modern-label">Apellido Paterno *</label>
                        <InputText class="form-control modern-input" @bind-Value="oJugadorCLS.appaterno" />
                        <ValidationMessage For="@(()=>oJugadorCLS.appaterno)" />
                    </div>

                    <div class="col-md-6">
                        <label class="modern-label">Apellido Materno</label>
                        <InputText class="form-control modern-input" @bind-Value="oJugadorCLS.apmaterno" />
                    </div>

                    <div class="col-md-6">
                        <label class="modern-label">Fecha de Nacimiento *</label>
                        <InputDate class="form-control modern-input" @bind-Value="oJugadorCLS.fnacimiento" />
                        <ValidationMessage For="@(()=>oJugadorCLS.fnacimiento)" />
                    </div>

                    <div class="col-12">
                        <label class="modern-label">Equipos *</label>
                        <InputSelect @bind-Value="oJugadorCLS.idequipo" class="form-control modern-input">
                            <option value="">--- Seleccione ---</option>
                            @foreach (EquipoCLS oEquipoCLS in listaEquipos)
                            {
                                <option value="@oEquipoCLS.idequipo">@oEquipoCLS.nombre</option>
                            }
                        </InputSelect>
                        <ValidationMessage For="@(()=>oJugadorCLS.idequipo)" />
                    </div>
                </div>

                <div class="jugador-form-actions">
                    <button type="submit" class="btn btn-guardar">Guardar</button>
                    <NavLink href="@ruta" class="btn btn-regresar">Regresar</NavLink>
                </div>
            </EditForm>
        </div>
    </div>
}

<style>
    .jugador-form-wrapper {
        padding: 1.25rem 0;
        background: linear-gradient(135deg, #f8fafc 0%, #eef6f5 100%);
        border-radius: 1.25rem;
    }

    .jugador-form-card {
        max-width: 920px;
        margin: 0 auto;
        background: #ffffff;
        border: 1px solid #e9ecef;
        border-radius: 1.2rem;
        box-shadow: 0 10px 30px rgba(45, 64, 89, 0.08);
        overflow: hidden;
    }

    .jugador-form-header {
        padding: 1.2rem 1.4rem;
        background: linear-gradient(120deg, #5faea0 0%, #7cc6b4 55%, #9bd8ca 100%);
        color: #ffffff;
    }

    .jugador-form-body {
        padding: 1.4rem;
    }

    .modern-label {
        font-weight: 600;
        color: #2f3e46;
        margin-bottom: 0.35rem;
        display: inline-block;
    }

    .modern-input {
        border-radius: 0.65rem;
        border: 1px solid #d6dde3;
        min-height: 42px;
    }

    .modern-input:focus {
        border-color: #5faea0;
        box-shadow: 0 0 0 0.2rem rgba(95, 174, 160, 0.2);
    }

    .jugador-form-actions {
        margin-top: 1.4rem;
        display: flex;
        flex-wrap: wrap;
        gap: 0.65rem;
    }

    .btn-guardar {
        background: linear-gradient(120deg, #42a890 0%, #5fb8a1 100%);
        border: none;
        color: #fff;
        border-radius: 0.65rem;
        padding: 0.45rem 1.2rem;
        font-weight: 600;
    }

    .btn-regresar {
        background: #edf2f7;
        color: #344054;
        border: 1px solid #d0d7de;
        border-radius: 0.65rem;
        padding: 0.45rem 1.2rem;
        font-weight: 600;
        text-decoration: none;
    }

    .btn-cargando {
        background: linear-gradient(120deg, #5faea0 0%, #7cc6b4 100%);
        border: none;
        color: #fff;
        border-radius: 0.65rem;
        padding: 0.5rem 1rem;
    }
</style>


@code {

    [Parameter]
    public JugadorCLS oJugadorCLS { get; set; } = new JugadorCLS();

    [Parameter]
    public List<EquipoCLS> listaEquipos { get; set; }

    public string ruta { get; set; }

    [CascadingParameter]
    private Task<AuthenticationState> auth { get; set; }

   
    protected override async Task OnInitializedAsync()
    {
        string paginaEnviar = "ListaJugador";
        int idPag = await http.GetFromJsonAsync<int>("api/Pagina/RecuperarIdPagina/" + paginaEnviar);
        ruta = paginaEnviar + "/" + idPag;
    }


    public async Task<bool> GuardarDatos()
    {
        var authuser = await auth;
        var user = authuser.User;

        var claims = user.Claims.ToList();
        var torneo = claims[1].Value;

        oJugadorCLS.idtorneo = int.Parse(claims[2].Value);

        oJugadorCLS.torneo = torneo;

        var resultado = await http.PostAsJsonAsync("api/Jugador/GuardarDatosJugador", oJugadorCLS);
        var content = await resultado.Content.ReadFromJsonAsync<object>();
        int rpta = int.Parse(content.ToString());

        // 0 = OCURRIO UN ERROR     1 = SE GRABO CORRECTAMENTE      3 = ESE NOMBRE DE JUGADOR YA EXISTE      4 = EQUIPO CON TOPE DE 30
        switch (rpta)
        {
            case 0:
                await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "OCURRIO UN ERROR, NO SE GUARDARON LOS DATOS", "error");
                break;
            case 1:
                await ijsruntime.InvokeVoidAsync("MostrarMensajeGuardar", "OK, DATOS GUARDADOS", "success");
                break;
            case 3:
                await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "ESE NOMBRE DE JUGADOR YA EXISTE", "warning");
                break;
            case 4:
                await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "NO SE PUEDE AGREGAR, EL EQUIPO YA TIENE 30 JUGADORES ACTIVOS", "warning");
                break;
            default:
                break;
        }
        if (rpta == 1)
        {
            navigation.NavigateTo(ruta);
        }

        return await Task.FromResult(true);
    }
}

