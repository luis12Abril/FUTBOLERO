@using FUTBOLERO.Shared
@inject HttpClient http
@inject NavigationManager navigation
@inject IJSRuntime ijsruntime

@if (oJuegoCLS == null)
{
    <div class="modern-form-wrapper">
        <div class="modern-form-card text-center py-5">
            <button class="btn btn-cargando" disabled>
                <span class="spinner-border spinner-border-sm me-2"></span>
                Cargando...
            </button>
        </div>
    </div>
}
else
{
    <div class="modern-form-wrapper">
        <div class="modern-form-card modern-form-card-lg">
            <div class="modern-form-header">
                <h4 class="mb-1">Formulario de Juego</h4>
                <p class="mb-0">Administre programación, resultado, estatus y comentarios del juego.</p>
            </div>

            <EditForm Model="@oJuegoCLS" OnValidSubmit="GuardarDatos" class="modern-form-body">
        <DataAnnotationsValidator />

        <div class="modern-form-actions">
            <button type="submit" class="btn btn-guardar">Guardar</button>
            <NavLink href="@ruta" class="btn btn-regresar">Regresar</NavLink>
        </div>
        <div class="mb-4"></div>

        @if (visiblegolesequipo)        // CUANDO ES UN EDITAR
        {
            <div class="form-group row">
                <label class="col-md-2 col-form-label font-weight-bold">Jornada</label>
                <div class="col-lg-10">
                    <InputText class="form-control" readOnly @bind-Value="oJuegoCLS.jornadacadena" />
                </div>
            </div>
        }
        else
        {
            <div class="form-group row">
                <label class="col-md-2 col-form-label font-weight-bold">Jornada *</label>
                <div class="col-lg-10">
                    <InputSelect @bind-Value="oJuegoCLS.idjornada" class="form-control">
                        <option value="">--- Seleccione ---</option>
                        @foreach (JornadaCLS oJornadaCLS in listaJornadas)
                                {
                            <option value="@oJornadaCLS.idjornada">@oJornadaCLS.nombre</option>
                                }
                    </InputSelect>
                    <ValidationMessage For="@(() => oJuegoCLS.idjornada)" />
                </div>
            </div>
        }


        @if (visiblegolesequipo)        // CUANDO ES UN EDITAR
        {
            <div class="form-group row equipo-resultado-row g-2">
                <label class="col-md-2 col-form-label font-weight-bold">Equipo 01</label>
                <div class="col-lg-4 col-md-5">
                    <InputText class="form-control form-control-sm equipo-nombre-input" readOnly @bind-Value="oJuegoCLS.equipo01cadena" />
                    @*<InputSelect @bind-Value="oJuegoCLS.idequipo01" class="form-control" @oninput="@(() =>CambioEquipo01(oJuegoCLS))">*@
                    @*<InputSelect @bind-Value="oJuegoCLS.idequipo01" class="form-control" readonly>
                            <option value="">--- Seleccione ---</option>
                            @foreach (EquipoCLS oEquipo01CLS in listaEquipo01)
                                {
                                <option value="@oEquipo01CLS.idequipo">@oEquipo01CLS.nombre</option>
                                }
                        </InputSelect>*@
                </div>

                <div class="col-lg-3 col-md-7">
                    <div class="resultado-radio-group">
                        <label class="resultado-radio-item"><span>G</span><input type="radio" name="final01" @onchange="@(() => MuestraCambio01("G"))" id="G01" /></label>
                        <label class="resultado-radio-item"><span>E</span><input type="radio" name="final01" @onchange="@(() => MuestraCambio01("E"))" id="E01" /></label>
                        <label class="resultado-radio-item"><span>P</span><input type="radio" name="final01" @onchange="@(() => MuestraCambio01("P"))" id="P01" /></label>
                        <label class="resultado-radio-item"><span>GP</span><input type="radio" name="final01" @onchange="@(() => MuestraCambio01("GP"))" id="GP01" /></label>
                        <label class="resultado-radio-item"><span>GA</span><input type="radio" name="final01" @onchange="@(() => MuestraCambio01("GA"))" id="GA01" /></label>
                    </div>
                </div>

                <div class="col marcador-pe-wrapper">
                    <div class="marcador-pe-group">
                        <label class="col-form-label font-weight-bold mb-0">Goles</label>
                        <InputNumber class="form-control font-weight-bold marcador-input" style="text-align:center" @bind-Value="oJuegoCLS.golesequipo01" min="0" />

                        @* PUNTOS EXTRAS *@
                        <label class="col-form-label font-weight-bold mb-0">PE</label>
                        <InputNumber class="form-control font-weight-bold marcador-input" style="text-align:center" @bind-Value="oJuegoCLS.peequipo01" min="0" />
                    </div>
                </div>

            </div>

            <div class="form-group row equipo-resultado-row g-2">
                <label class="col-md-2 col-form-label font-weight-bold">Equipo 02</label>
                <div class="col-lg-4 col-md-5">
                    <InputText class="form-control form-control-sm equipo-nombre-input" readOnly @bind-Value="oJuegoCLS.equipo02cadena" />
                </div>
                <div class="col-lg-3 col-md-7">
                    <div class="resultado-radio-group">
                        <label class="resultado-radio-item"><span>G</span><input type="radio" name="final02" @onchange="@(() => MuestraCambio02("G"))" id="G02" /></label>
                        <label class="resultado-radio-item"><span>E</span><input type="radio" name="final02" @onchange="@(() => MuestraCambio02("E"))" id="E02" /></label>
                        <label class="resultado-radio-item"><span>P</span><input type="radio" name="final02" @onchange="@(() => MuestraCambio02("P"))" id="P02" /></label>
                        <label class="resultado-radio-item"><span>GP</span><input type="radio" name="final02" @onchange="@(() => MuestraCambio02("GP"))" id="GP02" /></label>
                        <label class="resultado-radio-item"><span>GA</span><input type="radio" name="final02" @onchange="@(() => MuestraCambio02("GA"))" id="GA02" /></label>
                    </div>
                </div>

                <div class="col marcador-pe-wrapper">
                    <div class="marcador-pe-group">
                        <label class="col-form-label font-weight-bold mb-0">Goles</label>
                        <InputNumber class="form-control font-weight-bold marcador-input" style="text-align:center" @bind-Value="oJuegoCLS.golesequipo02" min="0" />


                        @* PUNTOS EXTRAS *@
                        <label class="col-form-label font-weight-bold mb-0">PE</label>
                        <InputNumber class="form-control font-weight-bold marcador-input" style="text-align:center" @bind-Value="oJuegoCLS.peequipo02" min="0" />
                    </div>
                </div>

            </div>
        }
        else
        {                               // CUANDO ES UNA ALTA
            <div class="form-group row">
                <label class="col-md-2 col-form-label font-weight-bold">Equipo 01 *</label>
                <div class="col-lg-10">
                    <InputSelect @bind-Value="oJuegoCLS.idequipo01" class="form-control">
                        <option value="">--- Seleccione ---</option>
                        @foreach (EquipoCLS oEquipo01CLS in listaEquipo01)
                                {
                            <option value="@oEquipo01CLS.idequipo">@oEquipo01CLS.nombre</option>
                                }
                    </InputSelect>
                    <ValidationMessage For="@(() => oJuegoCLS.idequipo01)" />
                </div>
            </div>

            <div class="form-group row">
                <label class="col-md-2 col-form-label font-weight-bold">Equipo 02 *</label>
                <div class="col-lg-10">
                    <InputSelect @bind-Value="oJuegoCLS.idequipo02" class="form-control">
                        <option value="">--- Seleccione ---</option>
                        @foreach (EquipoCLS oEquipo02CLS in listaEquipo02)
                                {
                            <option value="@oEquipo02CLS.idequipo">@oEquipo02CLS.nombre</option>
                                }
                    </InputSelect>
                    <ValidationMessage For="@(() => oJuegoCLS.idequipo02)" />
                </div>
            </div>
        }

        <div class="form-group row">
            <label class="col-md-2 col-form-label font-weight-bold">Campo *</label>
            <div class="col-lg-10">
                <InputSelect @bind-Value="oJuegoCLS.idcampo" class="form-control">
                    <option value="">--- Seleccione ---</option>
                    @foreach (CampoCLS oCampoCLS in listaCampos)
                        {
                        <option value="@oCampoCLS.idcampo">@oCampoCLS.nombre</option>
                        }
                </InputSelect>
                <ValidationMessage For="@(() => oJuegoCLS.idcampo)" />
            </div>
        </div>

        <div class="form-group row">
            <label class="col-md-2 col-form-label font-weight-bold">Arbitro *</label>
            <div class="col-lg-10">
                <InputSelect @bind-Value="oJuegoCLS.idarbitro" class="form-control">
                    <option value="">--- Seleccione ---</option>
                    @foreach (ArbitroCLS oArbitroCLS in listaArbitros)
                        {
                        <option value="@oArbitroCLS.idarbitro">@oArbitroCLS.nombrecompleto</option>
                        }
                </InputSelect>
                <ValidationMessage For="@(() => oJuegoCLS.idarbitro)" />
            </div>
        </div>

        <div class="form-group row">
            <label class="col-md-2 col-form-label font-weight-bold">Horario *</label>
            <div class="col-lg-10">
                <input type="datetime-local" @bind="horario" @bind:format="yyyy-MM-ddTHH:mm" class="form-control" />
                @*<InputDate type="datetime-local" class="form-control" @bind-Value="oJuegoCLS.fhorario" />*@
                @*<InputDate class="form-control" @bind-Value="oJuegoCLS.fhorario" @bind:format="dd/MM/yyyy" />
                    <InputDate class="form-control" @bind-Value="oJuegoCLS.fhorario" format-Value="dd/MM/yyyy hh:mm" />*@
            </div>
        </div>

        @if (visiblegolesequipo)        // CUANDO ES UN EDITAR
        {
            <div class="form-group row">
                <label class="col-md-2 col-form-label font-weight-bold">Estatus del Juego *</label>
                <div class="col-lg-10">
                    <InputSelect @bind-Value="oJuegoCLS.idestatusjuego" class="form-control">
                        <option value="">--- Seleccione ---</option>
                        @foreach (EstatusJuegoCLS oEstatusJuegoCLS in listaEstatusJuegos)
                                {
                            <option value="@oEstatusJuegoCLS.idestatusjuego">@oEstatusJuegoCLS.nombre</option>
                                }
                    </InputSelect>
                    <ValidationMessage For="@(() => oJuegoCLS.idestatusjuego)" />
                </div>
            </div>
        }
        else
        {
            <div class="form-group row">
                <label class="col-md-2 col-form-label font-weight-bold">Estatus del Juego</label>
                <div class="col-lg-10">
                    <InputText class="form-control" readOnly @bind-Value="oJuegoCLS.estatusjuegocadena" />
                </div>
            </div>
        }

        <div class="form-group row">
            <label class="col-md-5 col-form-label font-weight-bold">Cuenta para los PUNTOS de la tabla general?</label>
            <div class="col-md-1">
                <InputCheckbox @bind-Value="@oJuegoCLS.cuentaparapuntos" class="form form-control" />
                <ValidationMessage For="@(() => oJuegoCLS.cuentaparapuntos)" />
            </div>
            <label class="col-md-5 col-form-label font-weight-bold">Cuenta para los GOLES de la tabla general?</label>
            <div class="col-md-1">
                <InputCheckbox @bind-Value="@oJuegoCLS.cuentaparagoles" class="form form-control" />
                <ValidationMessage For="@(() => oJuegoCLS.cuentaparagoles)" />
            </div>
        </div>


        @if (visiblegolesequipo)        // CUANDO ES UN EDITAR
        {
            <ListadoJugadoresGoles oJuegoCLS="oJuegoCLS" />
        }

        @if (visiblegolesequipo)        // CUANDO ES UN EDITAR, LOS COMENTARIOS NO SE VERAN CUANDO SE ESTA AGREGANDO UN JUEGO
        {
            <div class="form-group row" style="margin-top:20px;">
                <label class="col-md-2 col-form-label font-weight-bold">Nuevo Comentario</label>
                <div class="col-lg-10">
                    <InputTextArea class="form form-control" @bind-Value="oJuegoCLS.comentario" />
                    <ValidationMessage For="@(() => oJuegoCLS.comentario)" />
                </div>
            </div>

            <div style="display:flex; flex-direction:column; justify-content:flex-start; align-items:flex-end;">
                <button type="submit" class="btn btn-guardar">Enviar Comentario</button>
            </div>

            <ListadoComentario oComentarioCLS="oComentarioCLS" />
        }

        <div class="mb-4"></div>
        <div class="modern-form-actions">
            <button type="submit" class="btn btn-guardar">Guardar</button>
            <NavLink href="@ruta" class="btn btn-regresar">Regresar</NavLink>
        </div>

            </EditForm>
        </div>
    </div>
}

