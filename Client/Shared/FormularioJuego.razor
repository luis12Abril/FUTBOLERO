@code {
    public int yaentro = 0;

    [CascadingParameter]
    private Task<AuthenticationState> auth { get; set; }

    [Parameter]
    public JuegoCLS oJuegoCLS { get; set; } = new JuegoCLS();

    [Parameter]
    public ComentarioCLS[] oComentarioCLS { get; set; }

    [Parameter]
    public DateTime horario { get; set; } = DateTime.Now;

    public int ganado01 { get; set; } = 1;

    public int empatado01 { get; set; }

    public int perdido01 { get; set; }

    public int ganadoempatado01 { get; set; }

    public int ganadoadmo01 { get; set; }

    public int ganado02 { get; set; }

    public int empatado02 { get; set; }

    public int perdido02 { get; set; } = 0;

    public int ganadoempatado02 { get; set; }

    public int ganadoadmo02 { get; set; }

    [Parameter]
    public JuegoCLS oJuegoCLS2 { get; set; } = new JuegoCLS();

    public string error { get; set; } = "Sin Error";

    public string mensaje { get; set; } = "-1";

    // AQUI VAN LOS PARAMETROS DE LOS COMBOS DEL FORMULARIO
    [Parameter]
    public List<JornadaCLS> listaJornadas { get; set; }
    [Parameter]
    public List<EquipoCLS> listaEquipo01 { get; set; }
    [Parameter]
    public List<EquipoCLS> listaEquipo02 { get; set; }
    [Parameter]
    public List<CampoCLS> listaCampos { get; set; }
    [Parameter]
    public List<ArbitroCLS> listaArbitros { get; set; }
    [Parameter]
    public List<EstatusJuegoCLS> listaEstatusJuegos { get; set; }

    // ESTA VARIABLE ES PARA QUE MUESTRE EL CONTROL DE LOS GOLES EN CASO DE SER UN EDITAR
    [Parameter]
    public bool visiblegolesequipo { get; set; } = false;

    public string ruta { get; set; }


    protected async override Task OnParametersSetAsync()
    {
        string paginaEnviar = "ListaJuego";
        int idPag = await http.GetFromJsonAsync<int>("api/Pagina/RecuperarIdPagina/" + paginaEnviar);
        ruta = paginaEnviar + "/" + idPag;

        // ESTE IF ES PORQUE CUANDO ES NUEVO NO ESTAN ACTIVADOS LOS RADIOS Y POR ESO NO DEBE ENTRAR
        if (oJuegoCLS.idjuego != 0)
        {
            // ESTE IF ES PORQUE CUANDO LE DOY CLICK EN CERRAR SESION ME DA UN ERROR DE RELOAD PORQUE VUELVE A ENTRAR, NO LO PUDE ARREGLAR DE OTRO MODO
            if (yaentro == 0)
            {
                string valid01 = oJuegoCLS.resequipo01.Trim() + "01";
                string valid02 = oJuegoCLS.resequipo02.Trim() + "02";

                await ijsruntime.InvokeVoidAsync("PonChecked", valid01, valid02);
                yaentro = yaentro + 1;
            }
        }
    }


    public async Task<bool> GuardarDatos()
    {
        var authuser = await auth;
        var user = authuser.User;

        var claims = user.Claims.ToList();
        var torneo = claims[1].Value;

        oJuegoCLS.idtorneo = int.Parse(claims[2].Value);

        oJuegoCLS.torneo = torneo;

        oJuegoCLS.fhorario = horario;

        oJuegoCLS.idusuario = int.Parse(user.Identity.Name);

        var resultado = await http.PostAsJsonAsync("api/Juego/GuardarDatosJuego", oJuegoCLS);
        var content = await resultado.Content.ReadFromJsonAsync<object>();
        int rpta = int.Parse(content.ToString());

        // 0 = ERROR    1 = OK  3 = ERROR EN GOLES DE LOS DOS EQUIPOS   4 = ERROR EN GOLES DEL EQUIPO 01    5 = ERROR EN GOLES DEL EQUIPO 02
        // 6 = SE GRABO EL COMENTARIO   7 = EL COMENTARIO ESTA EN BLANCO    8 = SON MAS DE 50 MCOMENTARIOS  10 = ERROR EN LOS RADIOS
        // 11 Y 12 PENDIENTE DE REVISAR

        switch (rpta)
        {
            case 0:
                await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "ERROR, NO SE GUARDARON LOS DATOS", "error");
                break;
            case 1:
                await ijsruntime.InvokeVoidAsync("MostrarMensajeGuardar", "OK, DATOS GUARDADOS", "success");
                navigation.NavigateTo(ruta);
                break;
            case 3:
                await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "LA SUMA DE GOLES NO ES IGUAL EN NINGUN EQUIPO", "error");
                break;
            case 4:
                await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "REVISA LOS GOLES DE " + oJuegoCLS.equipo01cadena, "error");
                break;
            case 5:
                await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "REVISA LOS GOLES DE " + oJuegoCLS.equipo02cadena, "error");
                break;                  
            case 6:
                oJuegoCLS.comentario = "";
                await ijsruntime.InvokeVoidAsync("MostrarMensajeGuardar", "OK, SE GUARDARON LOS DATOS Y SE ENVIO EL MENSAJE", "success");
                oComentarioCLS = await http.GetFromJsonAsync<ComentarioCLS[]>("api/Comentario/RecuperarTodosComentario/" + oJuegoCLS.idjuego);
                break;
            case 7:
                oJuegoCLS.comentario = "";
                await ijsruntime.InvokeVoidAsync("MostrarMensajeGuardar", "OK, DATOS GUARDADOS", "success");
                navigation.NavigateTo(ruta);
                break;
            case 8:
                oJuegoCLS.comentario = "";
                await ijsruntime.InvokeVoidAsync("MostrarMensajeGuardar", "OK, DATOS GUARDADOS, PERO NO EL COMENTARIO, EXEDIO EL LIMITE", "success");
                navigation.NavigateTo(ruta);
                break;
            case 10:
                await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "REVISA G  E  P  GP  GA", "error");
                break;
            case 11:
                await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "SI " + oJuegoCLS.equipo01cadena + " GANO ADMINISTRATIVAMENTE EL RESULTADO DEBE SER 2 - 0", "error");
                break;
            case 12:
                await ijsruntime.InvokeVoidAsync("MostrarMensajeAlerta", "SI " + oJuegoCLS.equipo02cadena + " GANO ADMINISTRATIVAMENTE EL RESULTADO DEBE SER 0 - 2", "error");
                break;
            default:
                break;
        }

        return await Task.FromResult(true);
    }


    public void MuestraCambio01(string valSel)
    {
        oJuegoCLS.resequipo01 = valSel;

        switch (valSel)
        {
            case "G":
                oJuegoCLS.puntosequipo01 = 3;
                break;
            case "E":
                oJuegoCLS.puntosequipo01 = 1;
                break;
            case "P":
                oJuegoCLS.puntosequipo01 = 0;
                break;
            case "GP":
                oJuegoCLS.puntosequipo01 = 2;
                break;
            case "GA":
                oJuegoCLS.puntosequipo01 = 3;
                break;
            default:
                break;
        }
    }


    public void MuestraCambio02(string valSel)
    {
        oJuegoCLS.resequipo02 = valSel;
        switch (valSel)
        {
            case "G":
                oJuegoCLS.puntosequipo02 = 3;
                break;
            case "E":
                oJuegoCLS.puntosequipo02 = 1;
                break;
            case "P":
                oJuegoCLS.puntosequipo02 = 0;
                break;
            case "GP":
                oJuegoCLS.puntosequipo02 = 2;
                break;
            case "GA":
                oJuegoCLS.puntosequipo02 = 3;
                break;
            default:
                break;
        }
    }
}

